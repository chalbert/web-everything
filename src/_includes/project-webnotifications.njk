<section id="protocol-push-delivery" class="section-card">
  <h3 id="how-it-works">Push Delivery Protocol</h3>
  <p>
    A producer never bundles a push service. It resolves a <strong>CustomPushProvider</strong> &mdash;
    native Web Push by default, a hub provider by override &mdash; and the same subscribe/send/unsubscribe
    contract drives every backend. Closed-app only: this is the path that wakes a service worker when the
    tab is gone.
  </p>
  {% highlight "typescript" %}
// The lock — the provider contract. Native Web Push is the default; a hub plugs in behind it.
interface PushSubscriptionInfo {
  endpoint: string;                       // the push-service URL the provider delivers to
  keys?: { p256dh: string; auth: string }; // Web Push encryption keys (VAPID-authenticated)
  provider: string;                        // which CustomPushProvider owns this subscription
}

interface DeliveryReceipt {
  target: string;                          // the subscription endpoint / provider target id
  status: 'queued' | 'delivered' | 'failed';
  at: string;                              // ISO — what an audit/report trail records
  reason?: string;
}

interface CustomPushProvider {
  readonly id: string;                     // 'web-push' (native default) | 'fcm' | 'onesignal' | …
  subscribe(options: { vapidKey?: string }): Promise<PushSubscriptionInfo>;
  send(target: PushSubscriptionInfo, payload: unknown): Promise<DeliveryReceipt>;
  unsubscribe(target: PushSubscriptionInfo): Promise<void>;
}

// 1. Default native path — the browser's Web Push, no third party.
const provider = resolvePushProvider();            // nearest-scope wins; default 'web-push'
const sub = await provider.subscribe({ vapidKey });

// 2. Swap to a hub WITHOUT touching the call sites — same contract.
//    register('fcm', new FcmPushProvider(...));   // a project override / custom plug

// 3. Send — the receipt is what Web Reporting / Web Audit record.
const receipt = await provider.send(sub, { title: 'Build green', body: '#456 shipped' });
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>Native-first:</strong> the Web Push API is the default provider; a hub is an opt-in
      enhancement behind the same seam, never a requirement.</li>
    <li><strong>Transport, not render:</strong> the protocol owns subscription + payload + receipt; the OS
      render is the <code>system-notification</code> intent, and permission state is the cross-cutting
      <a href="/intents/permission/">Permissions intent</a> &mdash; both separate homes.</li>
    <li><strong>Closed-app scoped:</strong> the open-app realtime transports are deliberately excluded
      (<a href="/backlog/455-server-to-client-delivery-transport-home-by-purpose-vs-by-me/">#455</a>) — they
      can't degrade to push and earn their own home.</li>
  </ul>
</section>

