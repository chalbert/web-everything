{{ pc.standardSection('id="protocol-transport-negotiation"') }}
  <h3 id="how-it-works">Transport Negotiation Protocol</h3>
  <p>
    A producer never hard-wires a socket. It resolves a <strong>CustomTransportProvider</strong> and
    declares a preference order; the provider probes top-down &mdash; capability-gated channels are tested,
    never assumed &mdash; and connects on the best available, falling to the long-poll floor. The same
    <code>Connection</code> contract drives every channel.
  </p>
  {% highlight "typescript" %}
// The lock — the provider contract. SSE + WebSocket are the native defaults; a hub plugs in behind it.
type TransportKind = 'websocket' | 'sse' | 'webtransport' | 'long-poll';

interface Connection {
  readonly kind: TransportKind;            // which channel won negotiation
  send?(data: unknown): void;              // present only where the transport is bidirectional
  onmessage(handler: (data: unknown) => void): void;
  onclose(handler: (reason?: string) => void): void;
  close(): void;
}

interface CustomTransportProvider {
  readonly id: string;                     // 'native' (default) | 'socket-io' | 'signalr' | 'centrifugo' | …
  // Probe `prefer` top-down; capability-gated kinds are feature-detected, never assumed.
  connect(options: {
    url: string;
    prefer?: TransportKind[];              // default: ['websocket', 'sse', 'long-poll']
  }): Promise<Connection>;
}

// 1. Default native path — negotiate the best channel, no third party.
const provider = resolveTransportProvider();                 // nearest-scope wins; default 'native'
const conn = await provider.connect({ url: '/live',
  prefer: ['webtransport', 'websocket', 'sse', 'long-poll'] }); // gated kinds degrade gracefully
conn.onmessage((msg) => render(msg));

// 2. Swap to a hub WITHOUT touching the call sites — same contract.
//    register('socket-io', new SocketIoTransportProvider(...));

// 3. WebTransport is probed, not assumed — absent (Safari) → falls to websocket, then the poll floor.
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>Native-first:</strong> SSE and WebSocket are the default channels; a hub provider is an
      opt-in enhancement behind the same seam, never a requirement.</li>
    <li><strong>Capability-gated, never assumed:</strong> WebTransport is feature-probed (Chrome/Edge
      only); when absent the negotiation degrades to WebSocket, then the long-poll floor that always
      works.</li>
    <li><strong>Open-app scoped:</strong> closed-app push is the non-fungible sibling
      (<a href="/projects/webnotifications/">Web Notifications</a>) — a separate home, never a fallback
      target of this protocol.</li>
  </ul>
{{ pc.endStandardSection() }}

