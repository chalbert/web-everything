<h3>Interaction Model</h3>
<ol>
    <li><strong>Trigger</strong> &mdash; User clicks a button, submits a form, or invokes a command. The action element acquires <code>busy</code> state via <a href="/intents/action/">Action Intent</a>.</li>
    <li><strong>Execute</strong> &mdash; The mutation is dispatched through <a href="/resources/clients/">Custom Client</a> (with <a href="/resources/middleware/">Middleware</a> for auth, logging, tracing).</li>
    <li><strong>Feedback</strong> &mdash; On success: toast notification, cache invalidation, UI update. On error: toast/alert, optimistic revert if applicable.</li>
    <li><strong>Unlock</strong> &mdash; Trigger element exits busy state. Double-submit prevention releases.</li>
</ol>

<h3>Lifecycle State Machine</h3>
<table>
    <thead>
        <tr><th>State</th><th>Description</th><th>Trait Behavior</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><code>idle</code></td>
            <td>No mutation in progress.</td>
            <td>Trigger element interactive. No indicators.</td>
        </tr>
        <tr>
            <td><code>pending</code></td>
            <td>Mutation started, timing threshold not reached.</td>
            <td><code>withBusyTrigger</code> locks width, applies <code>aria-disabled</code>. If optimistic: predicted result applied immediately.</td>
        </tr>
        <tr>
            <td><code>success</code></td>
            <td>Mutation completed.</td>
            <td>Trigger restored. <code>withFeedbackOnComplete</code> fires toast. Cache invalidated.</td>
        </tr>
        <tr>
            <td><code>error</code></td>
            <td>Mutation failed.</td>
            <td>Trigger restored. Error toast surfaced. If optimistic: <code>withOptimisticMutation</code> reverts to previous state.</td>
        </tr>
    </tbody>
</table>

<h3>Usage Examples</h3>

<h4>Form Submission</h4>
{% highlight "html" %}
<form resource-action="saveUser" resource-action-on="submit">
    <input name="name" />
    <button type="submit">Save</button>
</form>
{% endhighlight %}

<h4>Delete with Confirmation</h4>
{% highlight "html" %}
<button resource-action="deleteItem"
        resource-action-detail='{"id": "123"}'
        resource-action-confirm="Are you sure?">
    Delete
</button>
{% endhighlight %}

<h4>Optimistic Update</h4>
{% highlight "typescript" %}
// Register mutation handler with optimistic prediction
docInjector.set('customContexts:resourceAction', {
  async toggleFavorite({ params, signal }) {
    return fetch(`/api/favorites/${params.id}`, {
      method: 'POST', signal
    });
  }
});

// The optimistic trait applies the predicted result immediately
// If the mutation fails, the trait auto-reverts
{% endhighlight %}

<h3>Events</h3>
<p>
    Resource Action dispatches typed event classes registered via <a href="/projects/webevents/">Web Events</a> provider keys.
    Enables <code>listenForScoped</code> discrimination between concurrent mutations.
</p>
<table>
    <thead>
        <tr><th>Event</th><th>Class</th><th>Provider Key</th><th>Detail</th><th>Cancelable</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><code>resource-action-start</code></td>
            <td><code>ResourceActionStartEvent</code></td>
            <td><code>customEvents:resource-action-start</code></td>
            <td><code>{ operation, trigger }</code></td>
            <td>Yes</td>
        </tr>
        <tr>
            <td><code>resource-action-end</code></td>
            <td><code>ResourceActionEndEvent</code></td>
            <td><code>customEvents:resource-action-end</code></td>
            <td><code>{ operation, result }</code></td>
            <td>No</td>
        </tr>
        <tr>
            <td><code>resource-action-error</code></td>
            <td><code>ResourceActionErrorEvent</code></td>
            <td><code>customEvents:resource-action-error</code></td>
            <td><code>{ operation, error }</code></td>
            <td>No</td>
        </tr>
        <tr>
            <td><code>resource-action-revert</code></td>
            <td><code>ResourceActionRevertEvent</code></td>
            <td><code>customEvents:resource-action-revert</code></td>
            <td><code>{ operation, previousState }</code></td>
            <td>No</td>
        </tr>
    </tbody>
</table>

<h3>Interface</h3>
<pre><code class="language-typescript">/**
 * Resource Action configuration — provided via
 * customContexts:resourceAction on the injector chain.
 *
 * Named mutation functions resolved by name from the
 * resource-action attribute value.
 */
type ResourceActionHandler = (params: {
    params: Record&lt;string, unknown&gt;;
    signal: AbortSignal;
    formData?: FormData;
}) => Promise&lt;unknown&gt;;

/** Optimistic prediction for immediate UI update */
interface OptimisticPrediction&lt;T&gt; {
    predict: (params: Record&lt;string, unknown&gt;) => T;
    apply: (prediction: T) => void;
    revert: (previous: T) => void;
}</code></pre>

