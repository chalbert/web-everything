</dialog>
{% endhighlight %}

<h3>Step Indicator</h3>
<p>
    The <code>&lt;workflow-indicator&gt;</code> element renders a step rail with accessible markup.
    It reads step definitions from its parent workflow and renders an ordered list.
</p>
{% highlight "html" %}
<!-- Generated accessible markup -->
<workflow-indicator>
    <ol role="list">
        <li aria-current="step" data-state="active">
            <span class="step-number">1</span>
            <span class="step-label">Personal Information</span>
        </li>
        <li data-state="pending">
            <span class="step-number">2</span>
            <span class="step-label">Address</span>
        </li>
        <li data-state="pending">
            <span class="step-number">3</span>
            <span class="step-label">Review</span>
        </li>
    </ol>
</workflow-indicator>
{% endhighlight %}

<h3>Validation</h3>
<p>
    <code>withGateValidation</code> uses the native
    <a href="https://developer.mozilla.org/en-US/docs/Web/HTML/Guides/Constraint_validation">Constraint Validation API</a>
    to validate the active step before allowing advancement.
</p>
<ol>
    <li><strong>User clicks Next</strong> &mdash; <code>--workflow-next</code> command fires.</li>
    <li><strong>Gate check</strong> &mdash; <code>activeFieldset.checkValidity()</code> called. If valid, fires <code>workflow-step-before-change</code>.</li>
    <li><strong>If invalid</strong> &mdash; <code>activeFieldset.reportValidity()</code> shows browser-native error bubbles. Fires <code>workflow-error</code> event with invalid fields.</li>
    <li><strong>Custom validation</strong> &mdash; Listen for <code>workflow-step-before-change</code> (cancelable). Run async validation, call <code>event.preventDefault()</code> to block advancement.</li>
</ol>

{% highlight "typescript" %}
// Custom async validation on step change
workflowEl.addEventListener('workflow-step-before-change', async (e) => {
  if (e.detail.from === 'email-step') {
    const email = form.elements.email.value;
    const exists = await checkEmailExists(email);
    if (exists) {
      form.elements.email.setCustomValidity('Email already registered');
      form.elements.email.reportValidity();
      e.preventDefault(); // Block step advancement
    }
  }
});
{% endhighlight %}

<h3>State Persistence</h3>
<p>
    <code>withAutoSave</code> persists form data on each step change so users can resume after
    interruptions. Respects the configured storage backend.
</p>
<table>
    <thead>
        <tr><th>Storage</th><th>Scope</th><th>Cleared On</th><th>Use Case</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><code>sessionStorage</code></td>
            <td>Tab/session</td>
            <td>Tab close</td>
            <td>Checkout flows (single session)</td>
        </tr>
        <tr>
            <td><code>localStorage</code></td>
            <td>Browser</td>
            <td>Manual clear</td>
            <td>Onboarding, long forms (resumable)</td>
        </tr>
        <tr>
            <td><code>none</code></td>
            <td>In-memory only</td>
            <td>Page refresh</td>
            <td>Short modal wizards</td>
        </tr>
    </tbody>
</table>

{% highlight "html" %}
<form workflow progression="linear" persistence="sessionStorage"
      persistence-key="checkout-v1">
    <!-- Data auto-saved to sessionStorage on step change -->
    <!-- On mount, hydrates form from stored data and restores step position -->
</form>
{% endhighlight %}

<h3>Invoker Commands</h3>
<p>
    Step navigation uses the <a href="https://developer.mozilla.org/en-US/docs/Web/API/Invoker_Commands_API">Invoker Commands API</a>
    for declarative, no-JS navigation buttons.
</p>
<table>
    <thead>
        <tr><th>Command</th><th>Behavior</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><code>--workflow-next</code></td>
            <td>Advance to next step (after validation if gate mode). On last step, fires <code>workflow-complete</code>.</td>
        </tr>
        <tr>
            <td><code>--workflow-prev</code></td>
            <td>Return to previous step. Skips validation (data already validated on entry).</td>
        </tr>
        <tr>
            <td><code>--workflow-goto</code></td>
            <td>Jump to a specific step by ID (non-linear mode only). Requires <code>command</code> value format: <code>--workflow-goto:stepId</code>.</td>
        </tr>
        <tr>
            <td><code>--workflow-reset</code></td>
            <td>Reset to first step, clearing all step states. Optionally clears persisted data.</td>
        </tr>
    </tbody>
</table>

<h3>Events</h3>
<p>
    Workflow dispatches typed event classes registered via <a href="/projects/webevents/">Web Events</a> provider keys.
    The <code>workflow-step-before-change</code> and <code>workflow-complete</code> events are cancelable for validation gating.
</p>
<table>
    <thead>
        <tr><th>Event</th><th>Class</th><th>Provider Key</th><th>Detail</th><th>Cancelable</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><code>workflow-step-before-change</code></td>
            <td><code>WorkflowStepBeforeChangeEvent</code></td>
            <td><code>customEvents:workflow-step-before-change</code></td>
            <td><code>{ from, to, direction, trigger }</code></td>
            <td>Yes</td>
        </tr>
        <tr>
            <td><code>workflow-step-change</code></td>
            <td><code>WorkflowStepChangeEvent</code></td>
            <td><code>customEvents:workflow-step-change</code></td>
            <td><code>{ from, to, direction, trigger }</code></td>
            <td>No</td>
        </tr>
        <tr>
            <td><code>workflow-complete</code></td>
            <td><code>WorkflowCompleteEvent</code></td>
            <td><code>customEvents:workflow-complete</code></td>
            <td><code>{ data, steps }</code></td>
            <td>Yes</td>
        </tr>
        <tr>
            <td><code>workflow-error</code></td>
            <td><code>WorkflowErrorEvent</code></td>
            <td><code>customEvents:workflow-error</code></td>
            <td><code>{ step, fields, errors }</code></td>
            <td>No</td>
        </tr>
    </tbody>
</table>

<h3>Interface</h3>
<pre><code class="language-typescript">/** Step definition parsed from DOM */
interface WorkflowStepDefinition {
    id: string;                    // workflow-step attribute value
    fieldset: HTMLFieldSetElement; // The step's fieldset element
    label: string;                // From &lt;legend&gt; text
    optional: boolean;            // workflow-optional attribute
    branch?: string;              // workflow-branch condition
    state: 'pending' | 'active' | 'completed' | 'error' | 'skipped';
}

/** Workflow configuration — from attributes or injector */
interface WorkflowConfig {
    progression: 'linear' | 'non-linear' | 'branching';
    validation: 'gate' | 'on-submit' | 'none';
    persistence: 'sessionStorage' | 'localStorage' | 'none';
    persistenceKey?: string;      // Storage key prefix
}

/** Step change event detail */
interface WorkflowStepChangeDetail {
    from: string | null;          // Previous step ID (null on initial)
    to: string;                   // Target step ID
    direction: 'forward' | 'backward';
    trigger: HTMLElement | null;  // Button that triggered the change
}

/** Workflow complete event detail */
interface WorkflowCompleteDetail {
    data: Record&lt;string, FormDataEntryValue&gt;; // All form data
    steps: WorkflowStepDefinition[];           // Final step states
}</code></pre>

