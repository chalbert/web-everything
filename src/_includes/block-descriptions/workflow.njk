<h3>Progression Modes</h3>
<p>
    The progression mode determines how users navigate between steps. Each mode is a trait
    that composes independently with validation and persistence traits.
</p>
<table>
    <thead>
        <tr><th>Mode</th><th>Trait</th><th>Behavior</th><th>Use Case</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><strong>Linear</strong></td>
            <td><code>withLinearProgression</code></td>
            <td>Steps must be completed in order. Future steps are disabled. Back navigation allowed to completed steps.</td>
            <td>Checkout, onboarding, account setup</td>
        </tr>
        <tr>
            <td><strong>Non-linear</strong></td>
            <td><code>withNonLinearProgression</code></td>
            <td>Any step can be visited at any time. Step indicator is clickable. Validation on final submit or per-step.</td>
            <td>Settings pages, profile editing, surveys</td>
        </tr>
        <tr>
            <td><strong>Branching</strong></td>
            <td><code>withBranchingLogic</code></td>
            <td>Step sequence adapts based on user input. Steps can be added/removed dynamically (progressive wizard).</td>
            <td>Insurance quotes, tax filing, diagnostic flows</td>
        </tr>
    </tbody>
</table>

<h3>Step Lifecycle</h3>
<table>
    <thead>
        <tr><th>State</th><th>Description</th><th>DOM State</th></tr>
    </thead>
    <tbody>
        <tr>
            <td><code>pending</code></td>
            <td>Step not yet reached (linear mode). Cannot be activated.</td>
            <td><code>hidden</code>, <code>&lt;fieldset disabled&gt;</code></td>
        </tr>
        <tr>
            <td><code>active</code></td>
            <td>Currently visible step. User is interacting with it.</td>
            <td>Visible, <code>&lt;fieldset&gt;</code> enabled, <code>aria-current="step"</code> on indicator</td>
        </tr>
        <tr>
            <td><code>completed</code></td>
            <td>Step passed validation and user advanced past it.</td>
            <td><code>hidden</code>, <code>&lt;fieldset disabled&gt;</code>, indicator shows checkmark</td>
        </tr>
        <tr>
            <td><code>error</code></td>
            <td>Step has validation errors (returned to after failed advancement).</td>
            <td>Visible, <code>&lt;fieldset&gt;</code> enabled, indicator shows error icon</td>
        </tr>
        <tr>
            <td><code>skipped</code></td>
            <td>Optional step that user chose to bypass.</td>
            <td><code>hidden</code>, <code>&lt;fieldset disabled&gt;</code>, indicator shows skip marker</td>
        </tr>
    </tbody>
</table>

<h3>Declarative Structure</h3>

<h4>Basic Linear Workflow</h4>
{% highlight "html" %}
<form workflow progression="linear" validation="gate">
    <!-- Step indicator (auto-generated or manual) -->
    <workflow-indicator></workflow-indicator>

    <!-- Steps as fieldsets in an exclusive group -->
    <fieldset workflow-step="personal" name="steps">
        <legend>Personal Information</legend>
        <input name="firstName" required />
        <input name="lastName" required />
        <input name="email" type="email" required />
    </fieldset>

    <fieldset workflow-step="address" name="steps" hidden>
        <legend>Address</legend>
        <input name="street" required />
        <input name="city" required />
        <input name="zip" pattern="[0-9]{5}" required />
    </fieldset>

    <fieldset workflow-step="review" name="steps" hidden>
        <legend>Review & Submit</legend>
        <!-- Summary of collected data -->
    </fieldset>

    <!-- Navigation via Invoker Commands -->
    <footer>
        <button commandfor="workflow" command="--workflow-prev">Back</button>
        <button commandfor="workflow" command="--workflow-next">Next</button>
    </footer>
</form>
{% endhighlight %}

