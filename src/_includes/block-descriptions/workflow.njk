<h4>Branching Workflow (Progressive)</h4>
{% highlight "html" %}
<form workflow progression="branching" validation="gate">
    <workflow-indicator></workflow-indicator>

    <fieldset workflow-step="type" name="steps">
        <legend>Account Type</legend>
        <label><input type="radio" name="type" value="personal" /> Personal</label>
        <label><input type="radio" name="type" value="business" /> Business</label>
    </fieldset>

    <!-- Shown only if type=personal -->
    <fieldset workflow-step="personal-details" name="steps" hidden
              workflow-branch="type:personal">
        <legend>Personal Details</legend>
        <!-- ... -->
    </fieldset>

    <!-- Shown only if type=business -->
    <fieldset workflow-step="business-details" name="steps" hidden
              workflow-branch="type:business">
        <legend>Business Details</legend>
        <!-- ... -->
    </fieldset>

    <fieldset workflow-step="review" name="steps" hidden>
        <legend>Review</legend>
    </fieldset>
</form>
{% endhighlight %}

<h4>Modal Wizard</h4>
{% highlight "html" %}
<dialog id="setup-wizard">
    <form workflow progression="linear" validation="gate" method="dialog">
        <workflow-indicator></workflow-indicator>

        <fieldset workflow-step="welcome" name="wizard-steps">
