{# Research-freshness badge scaffold (#441 Fork 4 / #476).
   Foundation only: renders the review state from the registry fields. The staleness *derivation*
   (is this past lastReviewed + reviewHorizon?) and the resulting fresh/stale styling are #477 — it
   hangs off the data-freshness / data-review-horizon hooks below without touching this markup.
   Global review-horizon fallback is P6M (mirrors RESEARCH_REVIEW_HORIZON_DEFAULT in check-standards.mjs). #}
{% macro freshnessBadge(topic) %}
<span class="research-freshness"
      data-freshness="{% if topic.lastReviewed %}reviewed{% else %}unreviewed{% endif %}"
      data-last-reviewed="{{ topic.lastReviewed or '' }}"
      data-review-horizon="{{ topic.reviewHorizon or 'P6M' }}"
      style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.1rem 0.5rem; border-radius: 9999px; background: var(--color-surface-alt, #f1f5f9); color: var(--color-text-muted, #64748b); font-size: 0.72em; font-weight: 600; white-space: nowrap;"
      title="{% if topic.lastReviewed %}Last reviewed {{ topic.lastReviewed }} · review horizon {{ topic.reviewHorizon or 'P6M' }}{% else %}Not yet reviewed{% endif %}">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="opacity: 0.7;"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
    {% if topic.lastReviewed %}Reviewed {{ topic.lastReviewed }}{% else %}Not reviewed{% endif %}
</span>
{% endmacro %}

{# Revision-history block (#441 Fork 1): renders the bidirectional supersedes / supersededBy chain.
   Foundation scaffold — refresh-as-new-report authoring is #478. #}
{% macro revisionHistory(topic, researchTopics) %}
{% set supersedesList = topic.supersedes if topic.supersedes is iterable and topic.supersedes is not string else ([topic.supersedes] if topic.supersedes else []) %}
{% set supersededByList = topic.supersededBy if topic.supersededBy is iterable and topic.supersededBy is not string else ([topic.supersededBy] if topic.supersededBy else []) %}
{% if supersedesList.length or supersededByList.length %}
<div class="research-revision-history">
    <h2>Revision history</h2>
    {% if supersededByList.length %}
    <p style="margin: 0 0 0.5rem 0; color: var(--color-text-muted, #64748b); font-size: 0.9em;">
        Superseded by:
        {% for id in supersededByList %}
            {% for t in researchTopics %}{% if t.id == id %}<a href="/research/{{ t.id }}/">{{ t.title }}</a>{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}
        {% endfor %}
    </p>
    {% endif %}
    {% if supersedesList.length %}
    <p style="margin: 0; color: var(--color-text-muted, #64748b); font-size: 0.9em;">
        Supersedes:
        {% for id in supersedesList %}
            {% for t in researchTopics %}{% if t.id == id %}<a href="/research/{{ t.id }}/">{{ t.title }}</a>{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}
        {% endfor %}
    </p>
    {% endif %}
</div>
{% endif %}
{% endmacro %}
