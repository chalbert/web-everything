{#
  Declarative ↔ Class source toggle for <component> examples.

  Reuses the global mode-selector.js handler (loaded in base.njk) — it keys off
  .mode-selector-container / .mode-tab[data-mode] / [data-mode-content][data-mode],
  so this emits that same structure with two modes: "declarative" and "class".

  Usage:
    {% from "component-source-toggle.njk" import sourceToggle, classSource, endSource %}
    {{ sourceToggle("user-card") }}
      {% highlight "html" %}<component name="user-card">…</component>{% endhighlight %}
    {{ classSource("user-card") }}
      {% highlight "typescript" %}class UserCard extends HTMLElement { … }{% endhighlight %}
    {{ endSource() }}

  The "class" pane is the deterministic output of the build-time AST transform
  (the declarative-component adapter). Static for now; live transform is tier 2.
#}

{% macro sourceToggle(id) %}
<div class="mode-selector-container" data-mode-selector="{{ id }}" style="border: 1px solid #e5e7eb; border-radius: 0.375rem; overflow: hidden; margin-bottom: 1rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0.75rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
        <span style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: #9ca3af;">Source</span>
        <div class="mode-tabs" style="display: flex; gap: 0; border: 1px solid #d1d5db; border-radius: 0.25rem; overflow: hidden;">
            <button class="mode-tab active" data-mode="declarative" style="padding: 0.25rem 0.75rem; font-size: 0.75rem; font-weight: 500; background: #059669; color: white; border: none; cursor: pointer;">
                Declarative
            </button>
            <button class="mode-tab" data-mode="class" style="padding: 0.25rem 0.75rem; font-size: 0.75rem; font-weight: 500; background: white; color: #6b7280; border: none; border-left: 1px solid #d1d5db; cursor: pointer;">
                Class
            </button>
        </div>
    </div>
    <div class="mode-content" data-mode-content="{{ id }}" data-mode="declarative" style="display: block;">
{% endmacro %}

{% macro classSource(id) %}
    </div>
    <div class="mode-content" data-mode-content="{{ id }}" data-mode="class" style="display: none;">
{% endmacro %}

{% macro endSource() %}
    </div>
</div>
{% endmacro %}
