{% import "product-components.njk" as pc %}

<section class="intro-section mb-12">
    <h3 id="mission">Mission</h3>
    <p>The <strong>Web Blocks</strong> project aims to establish a set of standard protocols for interoperable modules—both visual components and behavioral traits. By focusing on the <em>protocol</em> rather than the implementation, we ensure that parts from different libraries can work together to provide consistent UX and accessibility.</p>
    <p>This initiative defines the "how it works" and "how it communicates" portion of web development, leaving the "how it looks" to the implementer.</p>
</section>
<section class="standards-section">
    <h3 id="proposed-standards">Proposed Standards</h3>

    <!-- Filters -->
    <div class="blocks-filters" style="margin-bottom: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
        <div class="filter-search" style="flex: 1; min-width: 200px;">
            <input
                type="text"
                id="blocks-search"
                placeholder="Search blocks..."
                style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;"
            >
        </div>
        <div class="filter-type" style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <button class="filter-btn active" data-type="all" style="padding: 0.375rem 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; background: #f8fafc; font-size: 0.75rem; cursor: pointer;">All</button>
            {% set types = [] %}
            {% for block in blocks %}
                {% if block.type not in types %}
                    {% set types = (types.push(block.type), types) %}
                {% endif %}
            {% endfor %}
            {% for type in types | sort %}
            <button class="filter-btn" data-type="{{ type }}" style="padding: 0.375rem 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; background: #f8fafc; font-size: 0.75rem; cursor: pointer;">{{ type }}</button>
            {% endfor %}
        </div>
    </div>

    <div class="standards-grid" id="blocks-grid">
        {% for block in blocks %}
        <a href="/blocks/{{ block.id }}/" class="standard-card" data-type="{{ block.type }}" data-name="{{ block.name | lower }}" data-summary="{{ block.summary | lower }}">
            <div class="flex justify-between items-start mb-3" style="gap: 12px; display: flex; justify-content: space-between;">
                <h4 id="block-name" class="text-lg font-bold m-0 text-gray-900">{{ block.name }}</h4>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800" style="white-space: nowrap;">
                    {{ block.type }}
                </span>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{{ block.summary }}</p>
            <div style="margin-bottom: 1rem;">
                {{ projectStatus(block.status) }}
            </div>
        </a>
        {% endfor %}
    </div>

    <p id="no-results" style="display: none; text-align: center; color: #475569; padding: 2rem;">No blocks match your filters.</p>
</section>

{{ pc.standardSection('id="governance"') }}
    <h3 id="block-standard-governance">Block Standard — governance &amp; schema</h3>
    <p>
        A <strong>block</strong> is a declarative, registry-rendered UI standard: a <strong>contract</strong>
        (what it exposes and which intents it realizes) that a Frontier&nbsp;UI implementation satisfies. The
        spec is <strong>data, not code</strong> — a JSON file under <code>src/_data/blocks/&lt;id&gt;.json</code>
        plus a prose description; WE owns the contract, the impl is <code>@frontierui/blocks/*</code>.
    </p>
    <p>
        The full <strong>block-spec schema reference</strong> — every declarable field
        (<code>id</code>/<code>name</code>/<code>status</code>/<code>type</code>/<code>exports</code>/
        <code>attributes</code>/<code>properties</code>/<code>events</code>/<code>slots</code>/
        <code>cssParts</code>/<code>traits</code>/<code>implementsIntent</code>/<code>composesIntents</code>/
        <code>intentDimensions</code>/<code>dependsOn</code>/…) and its meaning, plus the authoring guide and
        the validation rules the gate enforces — is the governance home for the Web Blocks umbrella
        (<a href="/backlog/1040-webblocks-protocol-surface-governance-umbrella-79-block-stan/">#1040</a>):
        <strong><code>docs/agent/block-standard.md</code></strong>.
    </p>
    <p style="font-size: 0.9rem; color: var(--color-text-muted);">
        The per-area governance sections hang off that schema home: <strong>lifecycle</strong>
        (<a href="/backlog/1092-block-status-lifecycle-governance/">#1092</a>), <strong>taxonomy</strong> of the
        six block types (<a href="/backlog/1093-block-protocol-taxonomy-governance/">#1093</a>), and
        <strong>composability</strong> — implements-vs-composes, trait/dimension discipline
        (<a href="/backlog/1094-block-composability-rules-governance/">#1094</a>).
    </p>
{{ pc.endStandardSection() }}

<style>
.filter-btn.active {
    background: #3b82f6 !important;
    color: white !important;
    border-color: #3b82f6 !important;
}
.filter-btn:hover:not(.active) {
    background: #e2e8f0;
}
.standard-card.hidden {
    display: none !important;
}
</style>

<script>
(function() {
    const searchInput = document.getElementById('blocks-search');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('#blocks-grid .standard-card');
    const noResults = document.getElementById('no-results');

    let currentType = 'all';
    let currentSearch = '';

    function filterCards() {
        let visibleCount = 0;

        cards.forEach(card => {
            const type = card.dataset.type;
            const name = card.dataset.name;
            const summary = card.dataset.summary;

            const matchesType = currentType === 'all' || type === currentType;
            const matchesSearch = !currentSearch ||
                name.includes(currentSearch) ||
                summary.includes(currentSearch);

            if (matchesType && matchesSearch) {
                card.classList.remove('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });

        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    searchInput.addEventListener('input', (e) => {
        currentSearch = e.target.value.toLowerCase();
        filterCards();
    });

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentType = btn.dataset.type;
            filterCards();
        });
    });
})();
</script>
