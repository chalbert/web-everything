{% from "mode-selector.njk" import pluggedContent, unpluggedContent, comparisonContent, endContent %}

<h3 id="overview">Overview</h3>
<p>Registry for expression parsers, standardizing how strings are parsed into executable expressions.</p>

<h3 id="interface">Interface</h3>
{% highlight "typescript" %}
interface CustomExpressionParserRegistry extends CustomRegistry<
    CustomExpressionParser
> {
    readonly localName = 'customExpressionParsers';
    define(
        name: string,
        parser: CustomExpressionParser
    ): void;

    // Returns a Consumable that provides the resolved parser
    query(): Consumable<CustomExpressionParser>;
}
{% endhighlight %}

<h3 id="usage-example">Usage Example</h3>

{{ pluggedContent("expr-parser-reg-example", code=true) }}
{% highlight "javascript" %}
// Access the global registry
const registry = window.customExpressionParsers;

// Define an expression parser
customExpressionParsers.define('keypath', keypathParser);

// Query for the active parser
const parser = customExpressionParsers.query();
{% endhighlight %}

{{ unpluggedContent("expr-parser-reg-example", code=true) }}
{% highlight "javascript" %}
consume { customExpressionParsers } of '@web-expressions';

// Access the consumed registry
const registry = customExpressionParsers;

// Define an expression parser
customExpressionParsers.define('keypath', keypathParser);

// Query for the active parser
const parser = customExpressionParsers.query();
{% endhighlight %}

{{ comparisonContent("expr-parser-reg-example", code=true) }}
