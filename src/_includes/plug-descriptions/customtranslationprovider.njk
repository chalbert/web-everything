<h3 id="interface">Interface</h3>
{% highlight "typescript" %}
/** The common message shape — runtime (MF2) and compile-time messages alike. */
type MessageFn = (params?: Record<string, unknown>) => string;

/** The one contract every translation provider implements. */
abstract class CustomTranslationProvider {
    // Return a MessageFn to own the key for that locale, or null to decline.
    abstract resolve(key: string, locale: string): MessageFn | null;
}
{% endhighlight %}

<h3 id="implementing">Implementing a Provider</h3>
{% highlight "typescript" %}
// Example: an MF2 provider backed by a lazily-loaded catalog per locale.
class Mf2Provider extends CustomTranslationProvider {
    private catalogs = new Map<string, Record<string, string>>();

    constructor(private formatter: MessageFormatter) {}

    resolve(key: string, locale: string): MessageFn | null {
        const source = this.catalogs.get(locale)?.[key];
        if (source === undefined) return null;          // Decline — walk the fallback chain.
        return this.formatter.compile(source, locale);  // Compile MF2 → MessageFn.
    }
}

// Register at bootstrap.
customTranslations.define('app', new Mf2Provider(mf2Formatter));
{% endhighlight %}

<h3 id="design-decisions">Design Decisions</h3>
<ul class="text-sm text-gray-600 list-disc pl-5">
    <li><strong>Null means decline.</strong> A provider returning <code>null</code> declines a key without side effects; resolution continues down the fallback chain. No separate <code>has()</code> predicate needed — <code>resolve()</code> is atomic.</li>
    <li><strong>Returns a function, not a string.</strong> <code>resolve()</code> yields a <code>MessageFn</code> so the same resolved message can be re-formatted with different parameters, and so compile-time message functions slot in with no shape change.</li>
    <li><strong>Native-first formatting.</strong> The default provider composes native <code>Intl</code> output. Providers add catalog lookup and message composition — they do not re-implement value formatting.</li>
</ul>

