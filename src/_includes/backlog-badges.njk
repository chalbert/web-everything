{#
  backlog-badges.njk — the SINGLE source of truth for every backlog item badge / chip / circle.

  Imported (with context, so the global `backlogMeta` resolves) by BOTH backlog item surfaces so they
  cannot drift:
    {% import "backlog-badges.njk" as bk with context %}
  and called as bk.kindBadge(...), bk.statusBadge(...), etc.
    • src/backlog.njk        — /backlog/ tile + Prioritisation table   (scale 'sm', the dense card grid)
    • src/backlog-pages.njk  — /backlog/{id}/ detail page              (scale 'md', the full page)

  The vocabulary (colours/labels/tooltips) lives in src/_data/backlogMeta.js (global `backlogMeta`); these
  macros only render it. `scale` ∈ 'sm' | 'md' sizes the pill while the colour/branch/label logic stays
  identical across surfaces — so a status like `preparing` or an epic state like `program` is coloured the
  same everywhere by construction. Each macro is SELF-CONTAINED (inlines its own scale) so it survives
  `import`. check:standards forbids re-defining these macros locally (anti-drift).

  Dogfood seam (#777): these macro bodies render via the FUI components, one seam, not duplicated defs.
    • Status surfaces  → `<we-badge>`  (#1598): statusBadge, epicStatusBadge, reasonPill.
    • Taxonomy surfaces → `<we-tag>`   (#1208, prereq #1817): kindBadge, sizeBadge, tierBadge, tagsRow,
      metaBadge, unslicedBadge — categorical (set,value) mode (#1670), palette in we:src/css/style.css.
    • Filter pills (interactive) → `<we-filter-chip>`: the backlog.njk filter row — its own slice (the
      interactive half is an aria-pressed/data-* JS rewrite across the page filter scripts, split off #1208).
  All loaded transient-CE via the cross-origin embed entries in we:src/_layouts/base.njk (mode C, rule 6/7).
  Link-pills (`blockerChip`/`childCircle`) stay native `<a>`.
#}

{# The item KIND badge — the one merged nature+hierarchy axis (#466/#487): story | epic | task | decision.
   `epic`/`task` self-name here (they replaced the old unsized-stand-in `workItemBadge`); a `story` shows
   its kind alongside the size badge; a `decision` keeps the indigo it had as a `type`. #}
{% macro kindBadge(kind, scale='sm') %}{# #1208: KIND taxonomy → FUI `<we-tag>` categorical (set,value) mode (#1670); per-value palette in we:src/css/style.css. `scale` kept for call-site compat but no longer sizes the pill (the FUI tag owns its geometry). #}
<we-tag set="kind" value="{{ kind }}" title="{% if kind == 'epic' %}epic — umbrella; rolls up its child stories/tasks{% elif kind == 'task' %}task — bounded sub-work; points roll up to its parent{% elif kind == 'decision' %}decision — a design fork to ratify (Tier B){% else %}story — an independently valuable, sized deliverable{% endif %}">{{ kind }}</we-tag>
{% endmacro %}

{# Status Indicator surface (#1621 status half) — lifecycle state → FUI `<we-badge>` (transient CE, loaded
   by the #1758 cross-origin loader in we:src/_layouts/base.njk). Tone maps onto the badge's CLOSED 5-tone
   enum (per #1319 — categorical taxonomy never rides the status enum): open→warning, active/preparing→info,
   resolved→success, else→neutral. The bespoke purple `preparing` shade is intentionally folded into `info`
   (the "Prepping" label carries the distinction). `scale` is kept for call-site compatibility but no longer
   sizes the pill — the FUI badge owns its own geometry; the we:src/css/style.css `we-badge[tone]` baseline
   styles it before upgrade (no FOUC). Includes the `preparing` → "Prepping" branch on BOTH surfaces. #}
{% macro statusBadge(status, scale='sm') %}{% set tone = 'warning' if status == 'open' else ('info' if (status == 'active' or status == 'preparing') else ('success' if status == 'resolved' else 'neutral')) %}<we-badge tone="{{ tone }}">{% if status == 'preparing' %}Prepping{% else %}{{ status | title }}{% endif %}</we-badge>
{% endmacro %}

{# BUILD STATE badge (#2474 → #2472) — the first "backlog-driven console" increment: where the item sits in
   the LOCAL loop pipeline, joined from the batch skill's offline loop-state files (claims.json / queued.json)
   by src/_data/backlog.js `deriveBuildState`. `bs` is that item's `buildState` object `{ state, session? }`.
   PURELY ADDITIVE — it renders ONLY for the two states that come FROM those files: `claimed` (a live session
   holds the item) and `queued` (a lane pushed it, ready-to-merge). `resolved` and the plain statuses (open/
   active/preparing/parked) render nothing here — statusBadge already shows them — so when the local files are
   absent (buildState === status for every item) this badge draws nothing and the tracker is visually
   unchanged. Same FUI `<we-badge>` idiom as statusBadge; tone claimed→info (in flight), queued→success
   (ready to land). The stable `data-build-state` attr is the tile/detail + interaction-test hook. #}
{% macro buildStateBadge(bs, scale='sm') %}
{%- if bs and bs.state == 'claimed' -%}
<we-badge tone="info" data-build-state="claimed" icon="&#9881;" title="Build state: claimed — a live session has this item (the status:open→active lock) and is working it{% if bs.session %} · {{ bs.session }}{% endif %}. Joined from the batch skill's local claims.json.">claimed{% if bs.session %} &middot; {{ bs.session }}{% endif %}</we-badge>
{%- elif bs and bs.state == 'queued' -%}
<we-badge tone="success" data-build-state="queued" icon="&#10003;" title="Build state: queued — a lane pushed this item and marked it ready-to-merge; it lands when the drain runs. Joined from the batch skill's local queued.json.">queued</we-badge>
{%- endif -%}
{% endmacro %}

{% macro sizeBadge(size, scale='sm') %}{# #1208: size taxonomy → FUI `<we-tag>` (`set="size"` keys the neutral + tabular-nums rule in style.css). #}
<we-tag set="size" value="{{ size }}" title="Estimate: {{ size }} agile point{% if size != 1 %}s{% endif %}">{{ size }} pt{% if size != 1 %}s{% endif %}</we-tag>
{% endmacro %}

{# Agent-readiness chip. Heuristic HINT (loader-derived from structured fields), not authoritative. #}
{% macro tierBadge(tier, scale='sm') %}{# #1208: agent-readiness tier → FUI `<we-tag>` categorical (set,value); palette in we:src/css/style.css. #}
{% if tier %}<we-tag set="tier" value="{{ tier }}" title="Agent-readiness hint — {{ backlogMeta.tierMeaning[tier] }}. Heuristic from structured fields only (type + resolved prerequisites); not authoritative — the selection pass still refines it.">{{ backlogMeta.tierLabel[tier] }}</we-tag>{% endif %}
{% endmacro %}

{# HAS-PREDICTED-SCOPE lens (#2618) — a Definition-of-Ready hint that sits BESIDE the agent-ready tier badge:
   an OPEN, unblocked, Tier-A build item that carries NO predicted `scope:` (loader `unshapedNoScope`) reads
   as dev-ready but is not fully shaped. The conveyor dispatcher (scripts/readiness/dispatch-plan.mjs) holds
   exactly this `unshaped-no-scope`/needs-probe item and NEVER launches it blind — it is auto-prepared (its
   `scope:` authored) before it can build. A SURFACING lens, NOT a hard gate (the item stays Tier A), so it is
   a warning-tone `<we-badge>`, not a reasonPill ⊗ hold. `data-unshaped-scope` is the stable tile/test hook. #}
{% macro unshapedScopeBadge(item, scale='sm') %}{%- if item.unshapedNoScope -%}
<we-badge tone="warning" data-unshaped-scope="1" icon="◇" title="Missing predicted scope — this item is agent-ready but carries no `scope:` touch-set, so it isn't fully shaped: the conveyor holds it `unshaped-no-scope` and auto-prepares its scope before it can build (never dispatched blind). A surfacing lens, not a blocker — add a `scope:` to parallelize it.">needs scope</we-badge>
{%- endif -%}{% endmacro %}

{# The "unsliced" badge for a childless epic — "unsliced · <why>" (colour/tooltip from backlogMeta) or a bare "unsliced". #}
{% macro unslicedBadge(reason, scale='sm') %}{# #1208: epic "unsliced·reason" → FUI `<we-tag>`; the per-reason palette (backlogMeta.childlessReasonMeta) is injected as inline `--cat-*`/background custom props so it survives the transient upgrade without duplicating the vocabulary into CSS. #}{% set m = backlogMeta.childlessReasonMeta[reason] %}
{% if m %}<we-tag set="unsliced" value="{{ reason }}" title="{{ m.tip }}" style="background:{{ m.bg }}; color:{{ m.fg }}; --cat-bg:{{ m.bg }}; --cat-color:{{ m.fg }};">unsliced &middot; {{ m.label }}</we-tag>{% else %}<we-tag set="unsliced" value="none" title="Unsliced epic — no child stories cut yet, and no reason recorded (add a childlessReason).">unsliced</we-tag>{% endif %}
{% endmacro %}

{# A labelled meta pill (e.g. "PARENT #314", "STARTED 2026-06-11") — detail-page header chips. #}
{% macro metaBadge(label, value, scale='md') %}{# #1208: labelled meta pill → FUI `<we-tag>` (neutral); the inner uppercase label span survives the transient upgrade (TransientElement MOVES childNodes onto the native span, doesn't flatten to text). #}
<we-tag shape="pill"><span style="text-transform: uppercase; letter-spacing: 0.03em; opacity: 0.7;">{{ label }}</span>&nbsp;{{ value }}</we-tag>
{% endmacro %}

{# The epic-status badge cluster — picks exactly one of: ongoing program / unsliced·why / all slices done /
   ⚠ open slice. ONE place so the tile and the detail page read identically. #}
{% macro epicStatusBadge(item, scale='sm') %}
{% if item.kind == 'epic' %}
{%- if item.ongoing and item.status != 'resolved' -%}
<we-badge tone="info" title="Ongoing program — a continuous effort, not a fixed deliverable. It legitimately has every child resolved between slices and is NEVER a resolve cue; the next slice is added as the program advances.">ongoing program</we-badge>
{%- elif not (item.children | length) -%}{{ unslicedBadge(item.childlessReason, scale) }}
{%- elif item.openChildCount == 0 and (item.status == 'open' or item.status == 'active') -%}
<we-badge tone="success" title="Every child slice is resolved but the epic is still open — its scope looks delivered. Resolve it, or add the remaining child work.">all slices done</we-badge>
{%- elif item.openChildCount and item.status == 'resolved' -%}
<we-badge tone="error" icon="&#9888;" title="The epic is resolved but {{ item.openChildCount }} child slice(s) are still open — a contradiction. Reopen the epic, re-parent, or resolve the children.">{{ item.openChildCount }} open slice{% if item.openChildCount != 1 %}s{% endif %}</we-badge>
{%- endif -%}
{% endif %}
{% endmacro %}

{# The item's topic tags row (the `tags:` frontmatter) — identical pill styling on every surface. #}
{% macro tagsRow(tags, scale='sm') %}{# #1208: topic tags (the `tags:` frontmatter) → FUI `<we-tag>` (neutral). #}
{% if tags %}<div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin: 0 0 0.75rem;">{% for tag in tags %}<we-tag shape="pill">{{ tag }}</we-tag>{% endfor %}</div>{% endif %}
{% endmacro %}

{# A child of an epic, drawn as a numbered circle coloured by the agent-readiness palette (resolved=grey ·
   active=blue · preparing=purple · ready=green · decision=amber · not-ready=slate). z-index keeps it
   clickable above a card overlay (harmless on the detail page). #}
{% macro childCircle(child) %}
{% set bg = "#f1f5f9" %}{% set bd = "#94a3b8" %}{% set fg = "#475569" %}
{% if child.status == 'resolved' %}{% set bg = "#f8fafc" %}{% set bd = "#cbd5e1" %}{% set fg = "#475569" %}
{% elif child.status == 'active' %}{% set bg = "#dbeafe" %}{% set bd = "#2563eb" %}{% set fg = "#1e40af" %}
{% elif child.status == 'preparing' %}{% set bg = "#ede9fe" %}{% set bd = "#7c3aed" %}{% set fg = "#6d28d9" %}
{% elif child.tier == 'A' %}{% set bg = "#dcfce7" %}{% set bd = "#16a34a" %}{% set fg = "#166534" %}
{% elif child.tier == 'B' %}{% set bg = "#fef3c7" %}{% set bd = "#d97706" %}{% set fg = "#92400e" %}{% endif %}
<a href="/backlog/{{ child.id }}/" title="#{{ child.num }} {{ child.title }} · {% if child.size %}{{ child.size }} pt{% if child.size != 1 %}s{% endif %}{% else %}{{ child.kind }}{% endif %} · {{ child.status }}" style="position: relative; z-index: 2; display: inline-flex; align-items: center; justify-content: center; min-width: 1.7rem; height: 1.7rem; padding: 0 0.35rem; border-radius: 9999px; background: {{ bg }}; border: 1.5px solid {{ bd }}; color: {{ fg }}; font-size: 0.72em; font-weight: 700; font-variant-numeric: tabular-nums; text-decoration: none;">{{ child.num }}</a>
{% endmacro %}

{# A prerequisite (`blockedBy`) drawn as a pill: a still-open blocker is red with ⛔, a resolved one green
   with ✓ (kept so the dependency reads in full). z-index keeps it clickable above a card overlay. #}
{% macro blockerChip(b) %}
{% if b.status == 'resolved' %}
<a href="/backlog/{{ b.id }}/" title="#{{ b.num }} {{ b.title }} · resolved — cleared" style="position: relative; z-index: 2; display: inline-flex; align-items: center; gap: 0.15rem; padding: 0.05rem 0.45rem; border-radius: 9999px; font-size: 0.72em; font-weight: 700; font-variant-numeric: tabular-nums; text-decoration: none; background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0;">&#10003; #{{ b.num }}</a>
{% else %}
<a href="/backlog/{{ b.id }}/" title="#{{ b.num }} {{ b.title }} · {{ b.status }} — still blocking" style="position: relative; z-index: 2; display: inline-flex; align-items: center; gap: 0.15rem; padding: 0.05rem 0.45rem; border-radius: 9999px; font-size: 0.72em; font-weight: 700; font-variant-numeric: tabular-nums; text-decoration: none; background: #fef2f2; color: #991b1b; border: 1px solid #fecaca;">&#9940; #{{ b.num }}</a>
{% endif %}
{% endmacro %}

{# Not-ready REASON pill — sits next to the "Not ready" tier badge in the Readiness column and says WHY an
   item isn't agent-ready (the "what" badge alone doesn't). Driven straight off the loader fields the
   ranker's held sections read (humanGate / openBlockers / projectPending / stopTheWorld), so the table and
   `check:readiness` always agree. Precedence mirrors the loader's `notBatchableReason` chain
   (stop-the-world → human-gate → blocked → project-pending) and renders exactly one pill. Epic-INCLUSIVE
   on purpose: a project-pending / human-gated epic (e.g. #170) carries no `notBatchableReason` yet must
   still show its hold. Emits nothing for an agent-ready (A) or ready-to-ratify (B) item — none of these
   fields fire there. Vocabulary/colours come from backlogMeta (single source of truth). #}
{# Status Indicator surface (#1621 status half) — the "why not ready" hold renders as FUI `<we-badge>`
   (tone = severity on the closed 5-tone enum; the leading ⊗/⏸/▽ glyph rides the badge `icon=` slot; the
   bespoke per-reason palette collapses onto the tone). The `project-pending` branch is a LINK to the
   project page, so it stays a native `<a>` (the #1621 link-pill rule — a `role=status` badge can't be an
   anchor); it keeps the inline `base`/`pad`/`fs` styling, the sole remaining consumer of them here. #}
{% macro reasonPill(item, scale='sm') %}{% set pad = '0.15rem 0.6rem' if scale == 'md' else '0.05rem 0.4rem' %}{% set fs = '0.78em' if scale == 'md' else '0.62em' %}{% set base = 'border-radius:9999px; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; white-space:nowrap; padding:' + pad + '; font-size:' + fs + ';' %}
{%- if item.stopTheWorld %}{% set nb = backlogMeta.notBatchableMeta['stop-the-world'] %} <we-badge tone="error" icon="⊗" title="{{ nb.tip }}">{{ nb.label }}</we-badge>
{%- elif item.humanGate %}{% set hg = backlogMeta.humanGateMeta[item.humanGateKind] %} <we-badge tone="error" icon="⊗" title="{{ hg.tip if hg else 'Held on a human-only action — an agent can’t clear it. See the item for what to do.' }}{% if item.humanGate.what %} — {{ item.humanGate.what }}{% endif %}">{{ hg.label if hg else 'human-gated' }}</we-badge>
{%- elif item.openBlockers.length %} <we-badge tone="error" icon="⊗" title="Blocked — waiting on an unresolved prerequisite (blockedBy). Not workable until it resolves.">blocked by {% for n in item.openBlockers %}#{{ n }}{% if not loop.last %}, {% endif %}{% endfor %}</we-badge>
{%- elif item.projectPending and item.kind != 'epic' %}{% set nb = backlogMeta.notBatchableMeta['project-pending'] %} <a href="/projects/{{ item.relatedProject }}/" title="{{ nb.tip }} — held on project `{{ item.relatedProject }}` ({{ item.relatedProjectStatus }}); open it to ship/graduate, or re-home this item." style="{{ base }} background:{{ nb.bg }}; color:{{ nb.fg }}; text-decoration:none;">⊗ {{ nb.label }} · {{ item.relatedProject }}</a>
{%- elif item.status == 'parked' and item.parkedReason %}{% set pr = backlogMeta.parkedReasonMeta[item.parkedReason] %} <we-badge tone="warning" icon="⏸" title="{{ pr.tip if pr else 'Parked — a deliberate hold; see the item for the reason.' }}">{{ pr.label if pr else item.parkedReason }}</we-badge>
{%- elif item.priority == 'low' %}{% set pm = backlogMeta.priorityMeta.low %} <we-badge tone="neutral" icon="▽" title="{{ pm.tip }}">{{ pm.label }}</we-badge>
{%- endif %}{% endmacro %}
