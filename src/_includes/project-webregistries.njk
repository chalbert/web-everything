        {{ pc.standardSection('id="examples"') }}
            <h3 id="userland-examples">Userland Examples</h3>
            
            <h4 id="example-1-icon-system">Example 1: Icon System</h4>
            <p>You can define your own registries for application-specific needs. Here is how you might build an Icon Registry that supports overriding icons in different contexts.</p>

            {% highlight "javascript" %}
import { CustomRegistry } from '@web-plugs/web-registries';

// 1. Define the Registry Class
class IconRegistry extends CustomRegistry {
  localName = 'icons'; // Used for debugging/identification
}

// 2. Create the registries
const globalIcons = new IconRegistry();
globalIcons.define('menu', '<svg viewBox="0 0 24 24">...</svg>');
globalIcons.define('close', '<svg viewBox="0 0 24 24">...</svg>');

// 3. Create a Scoped Registry (e.g., for a specific Admin module)
// It inherits everything from globalIcons, but can shadow them
const adminIcons = new IconRegistry({ 
  extends: [globalIcons] 
});

// Override 'menu' only for this scope
adminIcons.define('menu', '<svg viewBox="0 0 24 24">...<!-- Admin Menu --></svg>');
            {% endhighlight %}

            <p><strong>Connecting to Components:</strong> A theoretical <code>&lt;ui-icon&gt;</code> component illustrating how to consume the registry.</p>

            {% highlight "html" %}
<script type="module">
  // Hypothetical component that consumes our IconRegistry
  class UIIcon extends HTMLElement {
    connectedCallback() {
      // In a real app, 'adminIcons' might be provided via Context or Dependency Injection
      // For this POC demonstration, we import it directly.
      const registry = this.hasAttribute('admin') ? adminIcons : globalIcons;
      
      const iconName = this.getAttribute('name');
      if (registry.has(iconName)) {
         this.innerHTML = registry.get(iconName);
      }
    }
  }
  customElements.define('ui-icon', UIIcon);
</script>

<!-- Usage -->
<ui-icon name="menu"></ui-icon>         <!-- Renders standard menu -->
<ui-icon name="menu" admin></ui-icon>   <!-- Renders admin menu (via scoped registry) -->
            {% endhighlight %}
        {{ pc.endStandardSection() }}

{{ pc.standardSection('id="ssr"') }}
    <h3 id="ssr-contract">SSR Contract</h3>
    <p>
        This section defines the server-side rendering contract for <strong>Web Registries</strong>.
        The server MUST resolve all registry lookups at render time and emit the resolved content in the HTML.
    </p>

    <h4 id="ssr-server-output">Server Output Requirements</h4>
    <div class="comparison-table-wrapper mt-4">
        <we-data-table><table class="comparison-table">
            <thead>
                <tr>
                    <th>Feature</th>
                    <th>Server Output HTML</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Icon registry</strong></td>
                    <td>Inline SVG or resolved icon markup</td>
                    <td>Server MUST resolve <code>registry.get('menu')</code> and emit the SVG directly. No runtime lookup needed.</td>
                </tr>
                <tr>
                    <td><strong>Formatter registry</strong></td>
                    <td>Formatted text output</td>
                    <td>Server MUST apply registered formatters and emit the formatted result.</td>
                </tr>
                <tr>
                    <td><strong>Scoped registry lookups</strong></td>
                    <td>Scope-appropriate resolved values</td>
                    <td>Server MUST respect registry inheritance chains. A scoped override (e.g., admin icons) MUST apply to its subtree.</td>
                </tr>
            </tbody>
        </table></we-data-table>
    </div>

    <h4 id="ssr-hydration-expectations">Client Hydration Expectations</h4>
    <ul class="list-disc ml-6 text-gray-600 text-sm">
        <li><strong>Registry recreation:</strong> Client creates registry instances and populates them with definitions.</li>
        <li><strong>No DOM mutation needed:</strong> If the server resolved all lookups correctly, the client registry produces the same values — no visual changes on hydration.</li>
        <li><strong>Scope matching:</strong> Client-side scoped registries MUST match the server's inheritance chains to ensure consistency.</li>
    </ul>

    <h4 id="ssr-progressive-baseline">Progressive Enhancement Baseline</h4>
    <p class="text-gray-600 text-sm">
        With zero JavaScript, all registry-resolved content (icons, formatted text, etc.) is fully visible as static HTML.
        Icons are inline SVGs. Formatted values are plain text.
    </p>

    <h4 id="ssr-client-only">Client-Only Features</h4>
    <ul class="list-disc ml-6 text-gray-600 text-sm">
        <li><strong>Registry API:</strong> <code>define()</code>, <code>get()</code>, <code>has()</code></li>
        <li><strong>Dynamic registration:</strong> Adding or overriding definitions at runtime</li>
        <li><strong>Scoped overrides:</strong> Creating child registries with <code>{ extends: [parent] }</code></li>
        <li><strong>Lazy loading:</strong> Registering definitions on demand</li>
    </ul>

    <div class="comparison-block" style="background: rgba(251, 191, 36, 0.1); padding: 1.25rem; border-radius: 8px; border-left: 4px solid #f59e0b; margin: 1.5rem 0;">
        <h4 id="ssr-implementor-note" style="margin-top: 0; color: #d97706; font-size: 1rem;">Implementor Note</h4>
        <p style="margin-bottom: 0; font-size: 0.95rem;">
            This contract defines compliance requirements. The build system or server framework
            is responsible for resolving registry lookups and emitting the resolved content.
            Web Registries does not ship an SSR runtime — it ships this specification.
        </p>
    </div>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="protocol-provider-consumer-graph"') }}
    <h3 id="provider-consumer-graph-heading">Provider–Consumer Graph Protocol</h3>
    <p>
        Everything in Web Everything resolves through <strong>introspectable</strong> registries, injectors,
        <a href="/projects/webcontexts/">contexts</a>, and <a href="/projects/webevents/">events</a> — so that
        introspection <em>is</em> a dependency graph. This Protocol fixes the <strong>graph-model schema</strong>
        (the node/edge shape that introspection materializes) and the <strong>seam-contract</strong> declared at each
        provider↔consumer edge. It is the open, self-hostable half of
        <a href="/backlog/092-provider-consumer-graph-platform-manager/">#092</a>'s ruling — the
        <code>@webeverything</code>-scoped "nothing to lock into" guarantee. The cross-repo aggregation, the graph UI,
        and the governance workflows that <em>consume</em> this schema are the licensed plateau-app product and are
        <strong>not</strong> defined here.
    </p>
    <p>
        <strong>This is a technical contract, not a UX preference</strong> — a Protocol, not an Intent, surfaced under
        <code>/protocols/</code>. Unlike Backstage's hand-authored <code>catalog-info.yaml</code>, the graph is
        <strong>build-time auto-derived from WE introspection</strong> (the most-permissive, lowest-operational-cost
        ingestion default — no live agent to run); a runtime drift-detection agent is a deferred enrichment (#092
        Fork&nbsp;1), and edges it would add are marked <em>potential until trace-confirmed</em>. The provider side is
        already introspectable; <a href="/backlog/400-verify-extend-we-introspection-to-emit-provider-consumer-edg/">#400</a>
        added the consumer side at the DI seam (<code>Injector.consumptionEdges()</code>, opt-in via
        <code>Injector.trackConsumption</code>).
    </p>

    <h4 id="provider-consumer-graph-model">1 · Graph-model schema</h4>
    <p>
        A directed multigraph. <strong>Nodes</strong> are the introspectable units (a project, a registered provider,
        a protocol). <strong>Edges</strong> are of two kinds, both already surfaced by introspection: a
        <em>provides</em> edge (a provider implements a protocol, at a conformance tier — read from
        <a href="/protocols/">protocols.json</a> + the provider's declared tier) and a <em>consumes</em> edge
        (a consumer depends on a provider — read from <code>Injector.consumptionEdges()</code>). Consumption is
        <strong>bidirectional by construction</strong>: the same edge answers both "what do I depend on?" and "who
        depends on me?" (the latter is what makes impact analysis possible).
    </p>
{% highlight "typescript" %}
// Auto-derived at build time by walking the introspection surface (registry
// entries(), injector childInjectors/parentInjector + consumptionEdges(),
// contexts/events provide-sides). The schema is the lock; the walker is a build tool.
interface GraphNode {
  id: string;                          // stable: project id, provider key, or protocol id
  kind: 'project' | 'provider' | 'protocol';
  label?: string;
}
interface GraphEdge {
  from: string;                        // node id
  to: string;                          // node id
  kind: 'provides' | 'consumes';
  // 'potential' until a runtime trace confirms it (build-derived edges are 'confirmed').
  confidence: 'confirmed' | 'potential';
  seam?: SeamContract;                 // the contract declared at this edge — §2
}
interface ProviderConsumerGraph {
  nodes: GraphNode[];
  edges: GraphEdge[];
  derivedAt?: string;                  // provenance: build timestamp / commit
}
{% endhighlight %}

    <h4 id="provider-consumer-graph-seam">2 · Seam-contract at each edge</h4>
    <p>
        The contract at a provider↔consumer edge <strong>reuses the existing protocol conformance contract</strong>
        rather than coining a parallel Pact-style format (#092 Fork&nbsp;2). The provider side already exists: a
        provider declares the <strong>conformance tier</strong> it implements for a protocol. The
        <strong>consumer-driven projection is net-new</strong> — the consumer declares the subset of a protocol's
        dimensions/capabilities it actually depends on. One definition then feeds drift detection, impact analysis,
        and continuous verification alike; "compatible" means the consumer's required subset is contained in what the
        provider's tier supplies.
    </p>
{% highlight "typescript" %}
interface SeamContract {
  protocol: string;                    // a protocols.json id — the shared vocabulary at this seam
  // Provider side (REUSED — already modelled by protocols.json + the provider's tier):
  providerTier?: string;               // the conformance tier the provider implements
  // Consumer side (NET-NEW — the consumer-driven projection, the only new schema here):
  consumerRequires?: string[];         // the dimension/capability subset the consumer depends on
}
// Compatible ⇔ consumerRequires ⊆ (what providerTier supplies). A drift is any change
// that removes a member of consumerRequires from the provider's tier. The contract is
// the lock; the broker/aggregator that stores & compares contracts cross-repo is
// plateau-app's licensed product, NOT this standard.
{% endhighlight %}
    <p class="text-gray-600 text-sm">
        <strong>Boundary.</strong> Web Registries ships this schema + contract specification (open, self-hostable);
        it ships no aggregator and no UI. npm + git remain the source of bytes — this Protocol tracks
        <em>relationships</em>, not packages. Composes with the
        <a href="/projects/webinjectors/">injector</a> introspection (consumption edges), the
        <a href="/protocols/">protocol</a> registry (the provider-side conformance contract it reuses), and the
        Decision/Audit protocols where a governance product records why an edge changed.
    </p>
{{ pc.endStandardSection() }}