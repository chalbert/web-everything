{# Per-section display tool: expanding search filter + grid/list density toggle.
   Driven by /assets/js/home-display.js — scopes to the nearest <section> and
   filters/toggles its .project-card children. Used on the home page and /backlog/. #}
{% macro displayToolbar(label) %}
<div class="home-display-toolbar" data-home-display>
    <div class="home-search">
        <button type="button" class="home-search-btn" aria-label="Search {{ label }}" aria-expanded="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
        <input type="search" class="home-filter" placeholder="Filter&hellip;" aria-label="Filter {{ label }} by name or description">
    </div>
    <div class="view-toggle" role="group" aria-label="Display density">
        <button type="button" class="view-toggle-btn is-active" data-view="grid" aria-pressed="true" title="Default view">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            <span class="sr-only">Default</span>
        </button>
        <button type="button" class="view-toggle-btn" data-view="list" aria-pressed="false" title="Compact list">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
            <span class="sr-only">Compact</span>
        </button>
    </div>
</div>
{% endmacro %}
