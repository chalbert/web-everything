        <tr><td><strong>Number / currency / unit</strong></td><td>Any value</td><td>Locale-aware formatting</td><td>✅ <code>Intl.NumberFormat</code></td><td>—</td></tr>
        <tr><td><strong>Date / time / relative</strong></td><td>Any value</td><td>Locale-aware date, time, "2 days ago"</td><td>✅ <code>Intl.DateTimeFormat</code> / <code>RelativeTimeFormat</code></td><td>—</td></tr>
        <tr><td><strong>Plural category</strong></td><td>Any value</td><td>one / few / many / other for a count</td><td>✅ <code>Intl.PluralRules</code></td><td>—</td></tr>
        <tr><td><strong>List / display names</strong></td><td>Any value</td><td>"A, B, and C"; localized language/region names</td><td>✅ <code>Intl.ListFormat</code> / <code>DisplayNames</code></td><td>—</td></tr>
