        <tr><td><strong>Message formatting</strong></td><td>Translation key</td><td>Variable interpolation, plural/gender selection</td><td>✅ MF2 formatter</td><td>🔌 ICU 1.0 / Fluent adapter</td></tr>
        <tr><td><strong>Fallback locale chains</strong></td><td>Catalog lookup</td><td><code>fr-CA</code> → <code>fr</code> → <code>en</code> resolution</td><td>✅ registry walk</td><td>—</td></tr>
