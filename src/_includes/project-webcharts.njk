<section class="intro-section mb-12">
    <h3 id="mission">Mission</h3>
    <p>
        <strong>Web Charts</strong> brings the chart / data-visualization domain into the platform on the
        same terms as every other Web Everything standard: a chart is declared by its <em>semantic intent</em>
        &mdash; what the data is and what it means &mdash; kept strictly separate from its <em>presentation</em>,
        which is drawn natively and themed through <a href="/projects/webtheme/">Web Theme</a> tokens. A consuming
        app describes the chart it wants; the platform renders it, swaps the renderer behind one contract, and
        proves it accessible.
    </p>
</section>

<section id="scope" class="section-card">
    <h3 id="scope-heading">Scope</h3>
    <p>
        The standard adopts a thin <strong>Vega-Lite L1 profile</strong> as its semantic core (higher tiers are
        additive, never required), and defines a renderer-swap <strong>Protocol</strong> with a native-first SVG
        default so incumbent engines plug in behind it rather than leaking into the spec. Ratified in
        <a href="/backlog/105-data-visualization-charts/">#105</a> and scaffolded under epic
        <a href="/backlog/570-scaffold-the-webcharts-project-vega-lite-l1-profile-customch/">#570</a>.
    </p>
    <div class="standards-grid">
        <div class="standard-card flex flex-col">
            <h4 id="scope-semantic" class="text-lg font-bold m-0 text-gray-900">Semantic plane</h4>
            <p class="text-gray-600 text-sm leading-relaxed mb-0">
                A Vega-Lite L1 profile schema describes the chart's meaning &mdash; marks, encodings, and data
                &mdash; with no presentation coupling. Kept deliberately separate from the theme plane.
            </p>
        </div>
        <div class="standard-card flex flex-col">
            <h4 id="scope-presentation" class="text-lg font-bold m-0 text-gray-900">Presentation plane</h4>
            <p class="text-gray-600 text-sm leading-relaxed mb-0">
                Drawing consumes <a href="/projects/webtheme/">Web Theme</a> tokens, with a native-first SVG
                renderer as the default. A <code>CustomChartRenderer</code> Protocol lets Vega / Plotly / ECharts
                adapters swap in behind one contract <span class="text-gray-400">(authored in a later slice)</span>.
            </p>
        </div>
        <div class="standard-card flex flex-col">
            <h4 id="scope-conformance" class="text-lg font-bold m-0 text-gray-900">Conformance</h4>
            <p class="text-gray-600 text-sm leading-relaxed mb-0">
                A suite scores three axes &mdash; semantic fidelity, theme application, and
                <strong>accessibility</strong> as a first-class axis &mdash; so a renderer either conforms or
                is told exactly where it falls short.
            </p>
        </div>
    </div>
    <div class="bg-blue-50 border-l-4 border-blue-400 p-3 mt-6 text-xs text-blue-800">
        <strong>Status:</strong> concept &mdash; this is the project skeleton (slice a of
        <a href="/backlog/570-scaffold-the-webcharts-project-vega-lite-l1-profile-customch/">#570</a>). The
        Vega-Lite L1 schema, the <code>CustomChartRenderer</code> protocol, and the conformance suite land in
        the following slices.
    </div>
</section>

<section id="vega-lite-l1" class="section-card">
    <h3 id="profile-schema">Vega-Lite L1 Profile</h3>
    <p>
        The portable webcharts artifact is a <strong>Vega-Lite L1 profile</strong> — a thin, semantic core.
        It declares <em>what the data means</em> (data &rarr; mark &rarr; encoding) and nothing about
        <em>how it is drawn</em>: concrete palettes, animation, and alignment are the presentation/theme
        plane, resolved separately from <a href="/projects/webtheme/">Web Theme</a> tokens. <code>color</code>
        and <code>size</code> are <strong>semantic</strong> encodings — they say <em>"encode this field by
        hue/magnitude"</em>, never <code>#3b82f6</code>; the resolved value is theme. L1 is deliberately
        small; selections, transforms, and view composition are additive <strong>L2+ tiers</strong>, never
        required to render a basic chart.
    </p>
    {% highlight "typescript" %}
// The portable webcharts artifact — a Vega-Lite L1 profile. SEMANTIC plane ONLY: what the data
// means. The presentation/theme plane (concrete palettes, animation, alignment) is resolved from
// webtheme tokens and never appears here. Borrows Vega-Lite's vocabulary; standardizes the L1 subset.
interface ChartSpec {
  data: DataSource;            // the rows, or a named dataset
  mark: Mark;                  // the geometric primitive the data becomes
  encoding: Encoding;          // data field → visual channel (the semantic mapping)
}

// L1 marks — the basic primitives. Layered/composite marks are L2+.
type Mark = 'bar' | 'line' | 'point' | 'area' | 'arc';

interface DataSource {
  values?: Record<string, unknown>[];   // inline rows
  name?: string;                        // a named dataset (resolved by the host)
}

// Each channel binds a data field to a meaning. color/size are SEMANTIC: which field drives the
// channel — the concrete hue/scale is resolved from webtheme, so the same spec re-themes for free.
interface Encoding {
  x?: PositionChannel;
  y?: PositionChannel;
  color?: FieldChannel;        // semantic: which field drives hue; resolved palette = theme
  size?: FieldChannel;         // semantic: which field drives magnitude; resolved range = theme
  // tooltip / selection / facet / detail are L2+ tiers (additive), not part of L1.
}

interface PositionChannel {
  field: string;
  type: MeasurementType;       // drives the default scale + the a11y-derivable axis label
  scale?: Scale;               // L1 scales only
  axis?: Axis;                 // title / grid — the labels a screen-reader description derives from
}

interface FieldChannel {
  field: string;
  type: MeasurementType;
  legend?: Legend;             // title — also a11y-derivable
}

// The four Vega-Lite measurement types — the semantic kind of a field, NOT its presentation.
type MeasurementType = 'quantitative' | 'temporal' | 'ordinal' | 'nominal';

interface Scale { type: 'linear' | 'log' | 'time' | 'band' | 'point'; }  // L1 scales; more are L2+
interface Axis { title?: string; grid?: boolean; }
interface Legend { title?: string; }
    {% endhighlight %}
    <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
        <li><strong>Semantic plane, kept separate:</strong> the spec carries meaning (field &rarr; channel, measurement type), never concrete pixels. A renderer + <a href="/projects/webtheme/">Web Theme</a> resolve the presentation, so one spec re-themes without edits.</li>
        <li><strong>Color/size are semantic, resolved values are theme:</strong> <code>color: { field: 'category' }</code> says <em>encode category by hue</em>; the palette is a theme token, not a literal in the artifact.</li>
        <li><strong>Thin L1 core, additive tiers:</strong> data/mark/encoding + scales/axes/legends is all L1 requires. Selections, transforms, and composition are L2+ — a conformant L1 renderer ignores them gracefully.</li>
        <li><strong>Accessibility is derivable:</strong> axis/legend titles + measurement types let an a11y description be generated from the semantic spec — the conformance suite (slice d) scores it as a first-class axis.</li>
    </ul>
</section>

<section id="protocol-custom-chart-renderer" class="section-card">
    <h3 id="renderer-protocol">CustomChartRenderer Protocol</h3>
    <p>
        The standard is the <strong>spec, not the renderer</strong>. <code>CustomChartRenderer</code> is the
        renderer-swap contract: any drawing engine renders a <a href="#vega-lite-l1">Vega-Lite L1
        <code>ChartSpec</code></a> behind one interface, taking the semantic spec plus resolved
        <a href="/projects/webtheme/">Web Theme</a> tokens and producing output. The <strong>native-first
        default</strong> is an SVG renderer that ships with the standard; adapters (Vega, Plotly, ECharts)
        register as alternative impls — the same impl-swap shape as
        <a href="/projects/webpositioning/#protocol-anchor-positioning">CustomPositioner</a> and
        <a href="/projects/webrealtime/#protocol-transport-negotiation">CustomTransportProvider</a>.
    </p>
    {% highlight "typescript" %}
// The renderer-swap contract — the only lock. A renderer consumes the SEMANTIC spec + resolved
// theme tokens; swapping the SVG default for a Vega/Plotly/ECharts adapter never touches the ChartSpec.
interface CustomChartRenderer {
  // Which profile tier this renderer supports. L1 is required; L2+ is additive (selections/
  // transforms/composition) — an L1 renderer ignores higher-tier fields gracefully.
  readonly tier: 'L1' | 'L2' | 'L3';

  // Draw a semantic spec into `target`, resolving presentation from theme tokens. The renderer
  // never reads literal palettes from the spec — color/size are semantic, the values are theme.
  render(spec: ChartSpec, theme: ResolvedTheme, target: Element): ChartHandle;
}

// webtheme tokens already resolved for this chart — the presentation plane the spec defers to.
interface ResolvedTheme {
  palette: string[];                 // categorical hues, in order
  scaleRange?: [number, number];     // size/magnitude range
  // typography / spacing / animation tokens flow through here too (webtheme).
}

interface ChartHandle {
  update(spec: ChartSpec): void;     // re-render on data/encoding change
  destroy(): void;
  // The a11y description derivable from the spec's encodings + measurement types — the
  // conformance suite scores accessibility as a first-class axis (slice d).
  describe(): string;
}
    {% endhighlight %}
    <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
        <li><strong>Native-first default:</strong> an SVG renderer ships with the standard, so a chart draws with zero adapters. Vega/Plotly/ECharts are opt-in impls registered behind the same contract — the standard is engine-agnostic.</li>
        <li><strong>The spec is the only lock:</strong> a renderer reads the semantic <code>ChartSpec</code> + theme tokens and never the reverse, so swapping engines leaves the artifact untouched.</li>
        <li><strong>Tiered conformance:</strong> a renderer declares the L-tier it supports (L1 required, L2+ additive) and is scored on <em>semantic fidelity</em> + <em>theme application</em>, with <em>accessibility</em> a first-class axis (a description derivable from the spec).</li>
        <li><strong>Protocol, not intent:</strong> this fixes the renderer contract, the tier declaration, and the conformance axes — it owns no chart schema (that is the Vega-Lite L1 profile) and no picker/legend UX.</li>
    </ul>
</section>
