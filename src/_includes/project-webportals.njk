{{ pc.endStandardSection() }}

{{ pc.standardSection('id="primitives"') }}
  <h3 id="proposed-primitives">Proposed Primitives (Draft)</h3>
  <p>
    To enable native portal functionality equivalent to framework implementations, we propose the following browser primitives. These build on <a href="/projects/webinjectors/">Web Injectors</a> and <a href="/projects/webcontexts/">Web Contexts</a>.
  </p>

  <div class="comparison-block" style="background: rgba(99, 102, 241, 0.05); padding: 1.25rem; border-radius: 8px; border-left: 4px solid var(--color-primary); margin: 1.5rem 0;">
    <h4 style="margin-top: 0; color: var(--color-primary); font-size: 1rem;">Design Principle</h4>
    <p style="margin-bottom: 0; font-size: 0.95rem;">
      The key insight from framework research is that portals require a <strong>logical tree</strong> independent of the DOM tree. We use the <strong>injector hierarchy</strong> as this logical backbone, since injectors already provide context propagation, lifecycle management, and parent-child relationships.
    </p>
  </div>

  <h4 id="primitive-1">1. Node.logicalParent</h4>
  <p>
    A new DOM property that allows nodes to specify a <em>logical parent</em> different from their physical DOM parent. This is the foundation for all portal behavior.
  </p>
  {% highlight "typescript" %}
interface Node {
  // The logical parent for context/event propagation (defaults to parentNode).
  // Writable element-reference property — mirrors button.popoverTargetElement, and
  // reflects the declarative `logicalparent="id"` IDREF content attribute. Setting it
  // validates the logical graph (throws DOMException "HierarchyRequestError" on a cycle),
  // detaches from the prior logical parent, and fires a "logicalparentchange" event.
  // (ratified #1000, Fork 1)
  logicalParent: Node | null;

  // Read-only: the injector resolved via logical ancestry
  readonly logicalInjector: Injector | null;

  // Read-only: walk the resolved logical ancestor chain (derived, like parentNode)
  logicalAncestors(): IterableIterator<Node>;

  // Check if this node is a logical descendant of another
  isLogicalDescendantOf(ancestor: Node): boolean;
}
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>Declarative front door:</strong> the <code>logicalparent="id"</code> IDREF content attribute sets the relationship in pure HTML (matching <code>for</code>/<code>slot</code>/<code>popovertarget</code>), reflected by the writable <code>logicalParent</code> property — the <code>popovertarget</code>/<code>popoverTargetElement</code> pattern. Setting either validates the graph (<code>HierarchyRequestError</code> on a cycle) and fires <code>logicalparentchange</code> (ratified #1000, Fork 1)</li>
    <li><strong>Default behavior:</strong> When <code>logicalParent</code> is <code>null</code>, it defaults to <code>parentNode</code> (normal DOM behavior)</li>
    <li><strong>Context resolution:</strong> <code>getContext()</code> walks <code>logicalParent</code> chain, not <code>parentNode</code></li>
    <li><strong>Injector chain:</strong> <code>logicalInjector</code> resolves via logical ancestry</li>
  </ul>

  <h4 id="primitive-2" style="margin-top: 2rem;">2. Event Logical Propagation</h4>
  <p>
    Events need to bubble through the <em>logical</em> tree for handlers on logical ancestors to work. We propose extending <code>EventInit</code> and adding a new propagation path.
  </p>
  {% highlight "typescript" %}
interface EventInit {
  // New: should this event bubble through logical tree? (default: false)
  bubblesLogical?: boolean;

  // New: cross logical (portal) boundaries. ORTHOGONAL to native `composed`, which
  // crosses the target's SHADOW boundary — a separate flag, never an overload.
  // Default false (preserves encapsulation). (ratified #1000, Fork 2)
  composedLogical?: boolean;
}

interface Event {
  // The logical propagation path (if bubblesLogical is true). Computed PRE-retarget as a
  // parallel pass over the logical chain; a fresh retarget runs at each logical hop whose
  // host is the portal's DECLARATION element (not its mount/outlet), so a listener's
  // event.target stays inside its own logical tree. (ratified #1000, Fork 2)
  readonly logicalPath: EventTarget[];

  // Logical analogue of composedPath(), for events with composedLogical: true.
  composedLogicalPath(): EventTarget[];

  // Stop propagation through both DOM and logical trees
  stopLogicalPropagation(): void;
}

// Portaled content dispatches events with logical bubbling
button.dispatchEvent(new MouseEvent('click', {
  bubbles: true,
  bubblesLogical: true  // Will also bubble through logicalParent chain
}));
  {% endhighlight %}

  <div class="content-box" style="margin-top: 1rem;">
    <h5 style="margin: 0 0 0.5rem 0; color: var(--color-primary);">Event Flow</h5>
    <p style="font-size: 0.85rem; margin: 0; color: var(--color-text-muted);">
      When <code>bubblesLogical: true</code>, the event first bubbles through the DOM tree normally, then continues up the <code>logicalParent</code> chain from the portal root to the logical ancestors. Handlers can use <code>event.logicalPath</code> to inspect the full path. A fresh retarget runs at each logical hop whose host is the portal's <em>declaration</em> element (not its mount/outlet), so a listener's <code>event.target</code> stays inside its own logical tree; <code>stopLogicalPropagation()</code> halts the logical leg only.
    </p>
    <p style="font-size: 0.8rem; margin: 0.5rem 0 0 0; color: var(--color-text-muted);">
      <strong>Status:</strong> implemented in <code>we:plugs/webportals/Event.logical.patch.ts</code> (slice #1149 of epic #1001) — <code>logicalPath</code>, <code>composedLogicalPath()</code>, <code>stopLogicalPropagation()</code>, and the <code>dispatchLogical</code> driver (the non-invasive <code>#606</code> surface).
    </p>
  </div>

  <h4 id="primitive-3" style="margin-top: 2rem;">3. PortalOutlet Element</h4>
  <p>
    A dedicated element for portal targets that integrates with the injector system and manages multiple incoming portals.
  </p>
  {% highlight "typescript" %}
interface PortalOutlet extends HTMLElement {
  // Currently attached portals (in attachment order)
  readonly portals: ReadonlyArray<PortalDirective>;

  // Callback when portals attach/detach
  onportalchange: ((event: PortalChangeEvent) => void) | null;
}

// Registration
customElements.define('portal-outlet', PortalOutlet);
  {% endhighlight %}
  {% highlight "html" %}
<!-- Define portal outlets at strategic locations -->
<body>
  <div id="app">
    <!-- App content with deeply nested modals/tooltips -->
  </div>

  <!-- Portal outlets outside stacking contexts -->
  <portal-outlet id="modals"></portal-outlet>
  <portal-outlet id="tooltips"></portal-outlet>
  <portal-outlet id="notifications"></portal-outlet>
</body>
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>Ordering:</strong> Multiple portals to the same outlet append in attachment order (like Vue)</li>
    <li><strong>Top Layer Integration:</strong> Can be combined with <code>popover</code> attribute for automatic top-layer rendering</li>
    <li><strong>Named outlets:</strong> Target by ID, CSS selector, or direct reference</li>
  </ul>

  <h4 id="primitive-4" style="margin-top: 2rem;">4. Focus containment — composed, not owned</h4>
  <div class="content-box">
    <p style="margin: 0; font-size: 0.95rem;">
      Focus management is <strong>not</strong> a Web Portals primitive. Confining focus to the portaled surface, marking the rest of the page <code>inert</code>, choosing where focus lands on open, and restoring it on close are owned by the <a href="/intents/focus-containment/">Focus Containment Intent</a> — which the <a href="/intents/modal/">Modal</a>, <a href="/intents/anchor/">Anchor</a>, and <a href="/intents/autofocus-on-activation/">Autofocus-on-Activation</a> intents already <em>compose</em> rather than redefine. A portaled surface adopts containment the same way; its native substrate is <code>&lt;dialog&gt;.showModal()</code> (auto-<code>inert</code> + top layer + <code>:modal</code>). The two concerns are orthogonal: you can portal without a trap (toast, tooltip) and trap without a portal (an in-place <code>&lt;dialog&gt;</code> wizard step). The earlier <code>focusscope</code> / <code>createFocusScope()</code> primitive proposed here is <strong>struck</strong>. (Ratified #1000, Fork 3.)
    </p>
  </div>

  <h4 id="primitive-5" style="margin-top: 2rem;">5. The Portal Directive</h4>
  <p>
    The high-level API using <a href="/projects/webdirectives/">CustomTemplateDirective</a>. This is what developers typically interact with.
  </p>
  {% highlight "typescript" %}
class PortalDirective extends CustomTemplateDirective {
  static observedAttributes = ['target', 'disabled', 'required'];

  // The target outlet (selector, element reference, or 'body')
  target: string | Element = 'body';

  // Disable the portal (content stays in place)
  disabled: boolean = false;

  // Fail-fast: throw synchronously in connectedCallback if the target is absent,
  // instead of the deferred-by-default attach-or-observe behavior. (ratified #1000, Fork 4)
  required: boolean = false;

  // The rendered content
  readonly content: DocumentFragment | null;

  // Lifecycle
  connectedCallback(): void {
    // 1. Resolve target outlet (deferred-by-default — ratified #1000, Fork 4):
    //      present -> attach immediately;
    //      absent  -> observe via the shared root InjectorRoot MutationObserver and attach
    //                 when it appears. An unresolved target is warned at a STRUCTURAL trigger
    //                 (DOMContentLoaded on initial load, or one requestAnimationFrame after a
    //                 post-load connection) — never a wall-clock timeout. `required` instead
    //                 throws synchronously here.
    // 2. Instantiate template content
    // 3. Set logicalParent on content root to this directive's parent (the declaration element)
    // 4. Append content to target
    // 5. Set up event proxying (logical retarget host = this declaration element — Fork 2)
  }

  disconnectedCallback(): void {
    // 1. Remove content from target
    // 2. Clean up event listeners (incl. the deferred-resolution observer subscription)
  }
}

customElements.define('portal', PortalDirective, { extends: 'template' });
  {% endhighlight %}

  <p style="margin-top: 1.5rem;">Usage example:</p>
  {{ formatSelector("portal-directive-usage") }}
{% highlight "html" %}
<!-- Usage: content renders to #modals but maintains logical context -->
<my-widget>
  <template is="portal" target="#modals">
    <dialog class="widget-modal">
      <!-- Focus trap/restore via the Focus Containment Intent (dialog.showModal), not a portal primitive -->
      <!-- Full access to my-widget's contexts and injectors -->
      <h2 data-bind="widgetTitle"></h2>
      <button on-click="closeModal">Close</button>
    </dialog>
  </template>
</my-widget>
{% endhighlight %}
  {{ jsxContent("portal-directive-usage") }}
{% highlight "tsx" %}
// Usage: content renders to #modals but maintains logical context
