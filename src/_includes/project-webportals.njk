  const { widgetTitle, closeModal } = useWidgetContext();

  return (
    <Portal target="#modals">
      <dialog className="widget-modal">
        {/* Focus via the Focus Containment Intent (dialog.showModal), not a portal primitive */}
        {/* Full access to my-widget's contexts */}
        <h2>{widgetTitle}</h2>
        <button onClick={closeModal}>Close</button>
      </dialog>
    </Portal>
  );
}
{% endhighlight %}
  {{ templateContent("portal-directive-usage") }}
{% highlight "typescript" %}
// Usage: content renders to #modals but maintains logical context
html`
  <my-widget>
    <Portal target="#modals">
      <dialog class="widget-modal">
        <!-- Focus via the Focus Containment Intent (dialog.showModal), not a portal primitive -->
