{{ pc.standardSection('id="protocol-audit-trail"') }}
  <h3 id="how-it-works">Audit Trail Protocol</h3>
  <p>
    A producer never bundles an audit store. It constructs an <strong>AuditEvent</strong>, resolves the
    application's <strong>audit provider</strong> through the injector chain, and appends. The provider
    guarantees the write is append-only and durable; readers query by entity to render the timeline. The
    protocol fixes only the seam &mdash; the store behind the provider is swappable.
  </p>
  {% highlight "typescript" %}
// The AuditEvent — normalized, with before/after reusing the Web States ChangeRecord shape.
interface AuditEvent {
  target: { type: string; id: string };       // the entity audited (e.g. { type: 'loan', id: 'L-1042' })
  action: string;                              // verb, e.g. 'lifecycle.transition' | 'document.rejected'
  actor: { id?: string; role: string };        // who did it
  at: string;                                  // ISO timestamp
  before?: ChangeRecord[];                     // optional prior state (Web States shape)
  after?: ChangeRecord[];                      // optional new state
  correlationId?: string;                      // links related events / a Web Traces span
}

// The provider seam — the ONLY lock. Append-only by contract; an in-memory log, an event-sourced
// store, or an OSCAL backend satisfy it alike.
interface CustomAuditProvider {
  append(event: AuditEvent): Promise<void>;                          // immutable write
  queryByEntity(id: string, filters?: AuditQuery): Promise<AuditEvent[]>;
  subscribe?(id: string, onAppend: (e: AuditEvent) => void): () => void;
}

// 1. The application registers ONE provider (default in-memory; project overrides it).
customAudit.define('loan-store', new EventSourcedAuditProvider(db));

injector Application {
  provide { audit: 'loan-store' } to '@web-audit';   // every descendant resolves this provider
}

// 2. The HEADLINE composition — wire a lifecycle provider's events straight into the audit log.
lifecycleProvider.subscribe((ev) =>
  auditProvider.append({
    target: { type: 'loan', id: ev.entity },
    action: 'lifecycle.transition',
    actor: { role: ev.actor },
    at: ev.at,
    after: [{ path: '/state', op: 'replace', oldValue: ev.from, newValue: ev.to }],
  }),
);
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>One contract:</strong> <code>CustomAuditProvider</code> &mdash; <code>append()</code> +
      <code>queryByEntity()</code> &mdash; is satisfied by the default and every plugged store alike.</li>
    <li><strong>One registry:</strong> <code>CustomAuditRegistry</code> (<code>window.customAudit</code>)
      holds the named providers; the project selects/overrides via the injector chain.</li>
    <li><strong>Append-only is a guarantee, not a convention:</strong> the contract forbids mutation and
      deletion of a recorded event &mdash; the property regulated audit depends on.</li>
    <li><strong>Compose, don't duplicate:</strong> before/after reuse the Web States
      <code>ChangeRecord</code>; lifecycle transitions auto-feed the log; correlationId reaches Web
      Traces. Web Audit owns only the append-only, actor-attributed record and its query seam.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="protocol-reproduction-parity"') }}
  <h3 id="reproduction-parity">Reproduction-Parity Verdict/Delta Protocol</h3>
  <p>
    A second, cross-repo conformance surface Web Audit hosts: the thin contract the <strong>Plateau</strong>
    vision-judgment service emits and the Web Everything project ingests when an incumbent design system is
    reproduced as <strong>theme + intents over Frontier UI primitives</strong>. WE never renders Frontier UI
    nor runs the judge &mdash; per the <a href="/backlog/475/">no-leakage</a> posture it consumes
    <em>outputs only</em>: a per-target <strong>pass/fail</strong> verdict plus a structured
    <strong>gap delta</strong> (what theme + intents could not express). The gap list, not the copy, is the
    deliverable &mdash; it feeds the <a href="/backlog/315/">coverage gap-sweep</a>.
  </p>
  {% highlight "typescript" %}
// A verdict judges one component × state × scheme, backed by the layered oracle.
interface ReproductionVerdict {
  target: { system: string; component: string; state: string; scheme: string };
  pass: boolean;                                  // the single gate
  oracle: {                                       // observable readings only — never the judge's internals
    pixel: { pass: boolean; score?: number };     // fuzzy-pixel comparison
    structural: { pass: boolean; note?: string }; // structural DOM/ARIA diff
    vlm?: { pass: boolean; note?: string };       // advisory — annotates, never flips `pass` alone
  };
}

// A gap: what theme + intents could NOT express — a gap-sweep #315 intake line, not a fix.
interface GapDelta {
  target: { system: string; component: string; state: string; scheme: string };
  kind: 'token' | 'intent' | 'behavior' | 'primitive';   // which expressive layer fell short
  description: string;
  suggested?: string;                             // a suggested intent name / token path / primitive
}

// The whole payload that crosses the seam — pass/fail + gaps, nothing more.
interface ReproductionParityReport {
  system: string;
  generatedAt: string;                            // ISO; the producer stamps the time
  verdicts: ReproductionVerdict[];
  gaps: GapDelta[];
  summary: { passed: number; failed: number; gaps: number };
}
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>Thin, not fat:</strong> pass/fail per target + a gap list &mdash; never a rich diff schema.
      The advisory VLM leg annotates; the quantitative pixel + structural legs gate.</li>
    <li><strong>No-leakage client (#475):</strong> only the reduced readings cross the seam &mdash; no
      screenshots, renderer handles, or oracle internals. The judge is a Plateau service.</li>
    <li><strong>The gap list is the product:</strong> each <code>GapDelta</code> is a gap-sweep #315
      backlog-intake line, attributed to the expressive layer (token/intent/behavior/primitive) that fell
      short &mdash; the exercise-app active-bypass=FAIL analogue for reproduction.</li>
    <li><strong>Distribution:</strong> ships as <code>@webeverything/contracts/reproduction-parity</code>
      (type-only, zero runtime emit); Plateau depends on it &mdash; the one new cross-repo surface the
      reproduction-conformance charter mints.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="composition"') }}
  <h3 id="composition">Composition With Other Standards</h3>
  <ul style="font-size: 0.9rem;">
    <li><strong><a href="/intents/audit-timeline/">Audit Timeline intent</a></strong> &mdash; the UX half:
      the canonical chronological render + filtering of an entity's history. It reads the same provider; it
      is the audit trail's visual member.</li>
    <li><strong><a href="/projects/weblifecycle/">Web Lifecycle</a></strong> &mdash; every
      <code>LifecycleEvent</code> becomes one AuditEvent automatically (the headline composition).</li>
    <li><strong><a href="/projects/webstates/">Web States</a></strong> &mdash; the before/after of an
      AuditEvent reuse the <code>ChangeRecord</code> shape; change-tracking is the substrate, audit adds
      persistence + actor + query.</li>
    <li><strong><a href="/backlog/351-web-compliance-project/">Web Compliance</a></strong> &mdash; a
      <em>consumer</em>: its enforcement-evidence trail reuses the AuditEvent schema at the platform level
      (same shape, different subject). Domain audit is not folded into the compliance project.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="status"') }}
  <h3 id="status">Status</h3>
  <p>
    Web Audit is in <strong>concept</strong> phase; the Audit Trail protocol's seam (AuditEvent + provider
    + append-only + query) is specified here at <strong>draft</strong>. It was surfaced by the
    loan-origination exercise app (<a href="/backlog/317-exercise-app-loan-origination/">#317</a>), whose
    every consequential action is recorded with actor / timestamp / before-after. The native-first default
    provider, the lifecycle&rarr;audit composition wiring, and a reference timeline render are the first
    planned work, on top of this contract.
  </p>
  <h4 style="margin-top: 1rem;">Open Questions</h4>
  <ul style="font-size: 0.9rem; color: var(--color-text-muted);">
    <li>Does the provider assign the event id / sequence, or does the producer? (Ordering + idempotency.)</li>
    <li>Tamper-evidence (hash-chaining / signing) as an opt-in provider upgrade, or out of scope &mdash;
      deferred to the proof-of-compliance proof format (<a href="/backlog/093-business-rule-manager-proof-of-compliance/">#093</a>)?</li>
    <li>Retention / redaction of PII in <code>before/after</code> &mdash; a provider concern, or a
      protocol-level field policy?</li>
  </ul>
{{ pc.endStandardSection() }}
