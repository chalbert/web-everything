{{ pc.standardSection('id="protocol-policy-rule"') }}
  <h3 id="how-it-works">Policy Rule Meta-Schema (DMN-aligned)</h3>
  <p>
    A rule is a <strong>decision table</strong>, the DMN model: named inputs, a set of rules each mapping
    input conditions to outputs, and a hit policy for when several match. WE fixes the <em>shape</em> of
    that table &mdash; the meta-schema &mdash; and adopts FEEL as the entry expression language, evaluated by
    Web Expressions. The policy <em>language</em> behind a rule (DMN/FEEL vs Rego vs Cedar) is a downstream
    implementation choice; the meta-schema is what makes rulesets portable and a decision reproducible.
  </p>
  {% highlight "typescript" %}
// The meta-schema — the contract. Adopts DMN's decision-table model; FEEL-style entry expressions.
type HitPolicy = 'UNIQUE' | 'FIRST' | 'PRIORITY' | 'COLLECT';

interface PolicyInput {
  id: string;                 // e.g. 'order.total'
  label?: string;
  ref: string;                // data reference, resolved against Web Contexts
}

interface PolicyRule {
  id: string;
  when: string[];             // one FEEL entry per input — '> 50000', '"minor"', '-' (any)
  then: Record<string, string>;  // output name → FEEL value — { decision: '"refer"', reason: '"high-value"' }
}

interface PolicyRuleSet {
  id: string;
  version: string;            // reproducibility — a decision replays against THIS version
  scope?: { context?: string; tenant?: string };   // per-context/tenant binding
  hitPolicy: HitPolicy;
  inputs: PolicyInput[];
  rules: PolicyRule[];
}

// Authored ruleset — "orders over $50k refer for sign-off".
const approvals: PolicyRuleSet = {
  id: 'order-approval', version: '1.2.0', hitPolicy: 'FIRST',
  inputs: [{ id: 'total', ref: 'order.total' }, { id: 'tier', ref: 'customer.tier' }],
  rules: [
    { id: 'r1', when: ['> 50000', '-'],        then: { decision: '"refer"',  reason: '"high-value"' } },
    { id: 'r2', when: ['-', '"untrusted"'],    then: { decision: '"refer"',  reason: '"new-customer"' } },
    { id: 'r3', when: ['-', '-'],              then: { decision: '"allow"' } },
  ],
};
// The engine evaluates each `when` entry via Web Expressions, applies hitPolicy, emits a verdict —
// and (proof-of-compliance slice) logs the evaluation as a Web Traces span carrying ruleSet version.
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>DMN adopted, not coined:</strong> decision tables + FEEL are a mature OMG standard with
      existing tooling (Drools, Camunda). WE standardizes the meta-schema, not a new rule language.</li>
    <li><strong>Reproducible by version:</strong> a ruleSet carries its <code>version</code>, so a stored
      decision re-explains against the exact rules that produced it &mdash; the seam the proof-of-compliance
      log depends on.</li>
    <li><strong>Composes, doesn't absorb:</strong> entry expressions are Web Expressions; input data is Web
      Contexts; the proof point is a Web Traces span. Web Policy owns only the rule's shape.</li>
    <li><strong>Authoring is a Configurator domain:</strong> a ruleSet is built in the plateau-app Technical
      Configurator (the data-driven decision tool), not hand-written, for non-developer authors.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="composition"') }}
  <h3 id="composition">Composition With Other Standards</h3>
  <ul style="font-size: 0.9rem;">
    <li><strong><a href="/projects/webexpressions/">Web Expressions</a></strong> &mdash; evaluates each FEEL
      input/output entry; Web Policy supplies the table, Web Expressions runs the cell.</li>
    <li><strong><a href="/projects/webcontexts/">Web Contexts</a></strong> &mdash; resolves a rule's
      <code>inputs[]</code> data references in the scoped policy context.</li>
    <li><strong><a href="/projects/webtraces/">Web Traces</a> + proof-of-compliance
      (<a href="/backlog/093-business-rule-manager-proof-of-compliance/">#093</a> Fork 2)</strong> &mdash;
      each evaluation logs at a trace span; the hash-chained, signed, OSCAL-aligned decision log is the
      tamper-evident proof that a rule ran.</li>
    <li><strong>Enforcement (#093 Fork 3)</strong> &mdash; the OPA PDP/PEP split: a decision point evaluates
      the ruleset, enforcement points attach to actions/components, runtime is the baseline proof venue.</li>
    <li><strong>Technical Configurator (plateau-app)</strong> &mdash; rule authoring surfaces as a
      Configurator domain.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="status"') }}
  <h3 id="status">Status</h3>
  <p>
    Web Policy is in <strong>concept</strong> phase; the Policy Rule (DMN-aligned) meta-schema is specified
    here at <strong>draft</strong>. The project was ratified by
    <a href="/backlog/093-business-rule-manager-proof-of-compliance/">#093</a> (the business-rule manager +
    proof-of-compliance decision, grounded in a
    <a href="/research/business-rule-proof-of-compliance/">prior-art survey</a> of DMN, OPA, the
    tamper-evident-audit ladder, and OSCAL). This page establishes Fork 1 &mdash; the project and the
    meta-schema. The graduated builds layer on top: proof-of-compliance (Fork 2, hash-chained signed
    decision log + external anchoring) and enforcement (Fork 3, OPA PDP/PEP runtime).
  </p>
  <h4 style="margin-top: 1rem;">Open Questions</h4>
  <ul style="font-size: 0.9rem; color: var(--color-text-muted);">
    <li>Is the project name <code>webpolicy</code> the right scope (access/consent/governance umbrella), or
      should the narrower <code>webrules</code> own just decision tables?</li>
    <li>Do nested/chained decisions (one ruleSet's output feeds another's input &mdash; DMN's DRD) ship in
      v1, or flat tables only?</li>
    <li>Is the FEEL subset WE adopts the full grammar, or a constrained safe subset Web Expressions can
      guarantee to evaluate deterministically?</li>
  </ul>
{{ pc.endStandardSection() }}
