        <tr>
            <th>Category</th>
            <th style="background:#28a745;color:#fff;">Covered</th>
            <th style="background:#17a2b8;color:#fff;">Concept</th>
            <th style="background:#ffc107;color:#000;">Adapter</th>
            <th style="background:#dc3545;color:#fff;">Missing</th>
        </tr>
        <tr><td>Reactivity &amp; State</td><td>3</td><td>0</td><td>1</td><td>2</td></tr>
        <tr><td>Templating &amp; Rendering</td><td>4</td><td>2</td><td>2</td><td>3</td></tr>
        <tr><td>Component Model</td><td>5</td><td>0</td><td>1</td><td>0</td></tr>
        <tr><td>Routing</td><td>8</td><td>0</td><td>1</td><td>1</td></tr>
        <tr><td>Data Fetching &amp; Async</td><td>4</td><td>1</td><td>1</td><td>2</td></tr>
        <tr><td>Forms &amp; Validation</td><td>0</td><td>2</td><td>0</td><td>2</td></tr>
        <tr><td>Events &amp; Communication</td><td>3</td><td>1</td><td>1</td><td>0</td></tr>
        <tr><td>Dependency Injection</td><td>3</td><td>0</td><td>0</td><td>1</td></tr>
        <tr><td>Styling &amp; Responsiveness</td><td>1</td><td>2</td><td>0</td><td>1</td></tr>
        <tr><td>Animations &amp; Transitions</td><td>1</td><td>1</td><td>0</td><td>2</td></tr>
        <tr><td>Accessibility</td><td>3</td><td>1</td><td>0</td><td>0</td></tr>
        <tr><td>Performance</td><td>3</td><td>0</td><td>0</td><td>3</td></tr>
        <tr><td>Internationalization</td><td>0</td><td>0</td><td>0</td><td>2</td></tr>
        <tr><td>DevTools &amp; DX</td><td>2</td><td>0</td><td>0</td><td>1</td></tr>
        <tr style="font-weight: bold; background: #f1f3f5;">
            <td>TOTAL (74 features)</td>
            <td style="color:#28a745;">40 (54%)</td>
            <td style="color:#17a2b8;">10 (14%)</td>
