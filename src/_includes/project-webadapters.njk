            </div>
            <p style="font-size: 0.85rem; color: var(--color-text-muted); margin: 0 0 0.75rem 0;">{{ adapter.summary | safe }}</p>
            {{ projectStatus(adapter.status) }}
        </div>
            {% endfor %}
    </div>
        {% endif %}
    {% endfor %}
</section>

