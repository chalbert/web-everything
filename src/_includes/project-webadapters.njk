            <td>Two-way binding syntax adapter (like Vue v-model)</td>
            <td style="color: #dc3545; font-weight: 600;">High</td>
        </tr>
        <tr>
            <td>Function Components</td>
            <td>Factory generating CustomElement subclasses from functions</td>
            <td style="color: #dc3545; font-weight: 600;">High</td>
        </tr>
        <tr>
            <td>Event Modifiers</td>
            <td><code>.stop</code>, <code>.prevent</code>, <code>.once</code> suffixes on <code>on:*</code> attributes</td>
            <td style="color: #dc3545; font-weight: 600;">High</td>
        </tr>
        <tr>
            <td>Signals</td>
            <td>Fine-grained reactivity over individual SimpleStore keys</td>
            <td style="color: #e67e22; font-weight: 600;">Medium</td>
        </tr>
        <tr>
            <td>Nested Routes</td>
            <td>Composable <code>&lt;route-view&gt;</code> elements for nested routing</td>
            <td style="color: #e67e22; font-weight: 600;">Medium</td>
        </tr>
        <tr>
            <td>Suspense Boundaries</td>
            <td>Resource Loader virtual element as component-style boundary</td>
            <td style="color: #7f8c8d; font-weight: 600;">Low</td>
        </tr>
        <tr>
            <td>Text Interpolation</td>
            <td>CustomTextNode parser for <code>{{ "{{ expression }}" }}</code> syntax</td>
            <td style="color: #7f8c8d; font-weight: 600;">Low</td>
