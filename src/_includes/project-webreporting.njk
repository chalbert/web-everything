{{ pc.standardSection('id="protocol-report-model"') }}
  <h3 id="how-it-works">Report Model Protocol</h3>
  <p>
    A producer never bundles a rendering or an export format. It emits a <strong>Report</strong> &mdash; the
    normalized, source-attributed result of a run &mdash; and any renderer or adapter reads it. There is no
    provider to resolve on the model itself: the schema is the entire contract, which is what lets
    <code>check:standards</code>, a CI SARIF run, and an external conformance tool all feed the same
    findings table, coverage matrix, and trend chart.
  </p>
  {% highlight "typescript" %}
// The pivot — the ONLY lock. Schema-only, like the Decision Record: no provider on the model;
// ingest/export ADAPTERS are the swappable bridge (separate slices).

type Severity = 'error' | 'warn' | 'info' | 'pass';  // base set — producers extend with their own strings

interface ReportSource {
  id: string;                 // producer id, e.g. 'check:standards'
  name: string;
  kind?: string;              // 'conformance' | 'coverage' | 'lint' | 'test' | …
  at?: string;                // ISO — when this run produced its results
  meta?: Record<string, string>;
}

interface Finding {
  id: string;
  severity: Severity | string;          // open vocabulary over the base set
  title: string;
  detail?: string;
  location?: { path: string; line?: number; col?: number };
  ruleId?: string;                       // the check/rule that produced it
  source: string;                        // → ReportSource.id
}

interface Score  { id: string; label: string; value: number; max?: number; unit?: string; }
interface Series { id: string; label: string; points: { at: string; value: number }[]; unit?: string; }

interface ReportSection {
  id: string;
  title: string;
  findings?: Finding[];        // findings table
  scores?: Score[];           // score card
  series?: Series[];          // trend / burndown
}

interface Report {
  id: string;
  title: string;
  sources: ReportSource[];     // every run that contributed
  sections: ReportSection[];
  generatedAt?: string;        // ISO
}

// 1. Any producer emits the SAME model — the standards checker maps its results to it.
const report: Report = toReport(runCheckStandards());

// 2. Renderers & adapters interoperate off the schema — no provider, no coupling to the producer.
panel.append(renderFindingsTable(report));      // a v1 renderer (#432)
const sarif = exportSarif(report);              // an export adapter (#434)
const fromCi: Report = ingestSarif(ciSarif);    // an ingest adapter (#433)
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>Schema-only on the model, swappable at the edges:</strong> there is no
      <code>CustomReportProvider</code> &mdash; the interchange <em>is</em> the <code>Report</code>. The
      swap seam lives in the <a href="/projects/webadapters/">adapters</a> that ingest/emit foreign formats,
      which is exactly the multi-vendor interop a protocol exists to guarantee.</li>
    <li><strong>Source-attributed:</strong> every finding carries its <code>source</code>, so one report can
      fold several runs (a conformance check + a coverage run) and still trace each result to its producer.</li>
    <li><strong>Open severity vocabulary:</strong> a named base set (<code>error/warn/info/pass</code>) keeps
      renderers consistent, while producers extend it &mdash; the same pattern as the Decision Record
      outcome vocabulary.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="composition"') }}
  <h3 id="composition">Composition With Other Standards</h3>
  <ul style="font-size: 0.9rem;">
    <li><strong><a href="/projects/webadapters/">Web Adapters</a></strong> &mdash; the ingest/export bridge:
      SARIF · JUnit · coverage in, SARIF/JUnit out. The lossy-normalization hub that earns the protocol.</li>
    <li><strong><a href="/projects/webdecisions/">Web Decisions</a></strong> &mdash; a
      <code>DecisionRecord</code> feeds a report as one finding/source.</li>
    <li><strong>Web Compliance (<a href="/backlog/351-web-compliance-project/">#351</a>)</strong> &mdash; its
      audit/gate results are just another report source; the report model is the shared protocol both
      projects emit through (<a href="/backlog/439-build-the-audit-evidence-trail-emit-through-web-reporting/">#439</a> also consumes it).</li>
    <li><strong>Conformance tooling (<a href="/backlog/314-flagship-exercise-apps/">#314</a>)</strong> &mdash;
      the output layer <code>check:app-conformance</code> renders through.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="status"') }}
  <h3 id="status">Status</h3>
  <p>
    Web Reporting is in <strong>concept</strong> phase; the Report model protocol's schema is specified here
    at <strong>draft</strong>. It was carved from the reporting epic
    (<a href="/backlog/350-web-reporting-project/">#350</a>) as its root slice &mdash; the canonical pivot
    everything else consumes. The Project + Protocol shape was ratified: multi-vendor report-format interop
    earns a protocol; an intent is UX-only and wrong for a data-interchange contract. The v1 renderers
    (<a href="/backlog/432-build-the-v1-report-renderers-findings-table-coverage-matrix/">#432</a>), ingest adapters
    (<a href="/backlog/433-build-the-v1-ingest-adapters-sarif-junit-coverage/">#433</a>), export adapters
    (<a href="/backlog/434-build-the-export-adapters-report-model-to-sarif-junit/">#434</a>), and producer migration
    (<a href="/backlog/435-migrate-existing-check-reporters-onto-the-report-model-share/">#435</a>) build on this schema.
  </p>
  <h4 style="margin-top: 1rem;">Open Questions</h4>
  <ul style="font-size: 0.9rem; color: var(--color-text-muted);">
    <li>Does a finding carry a <em>raw</em> location and a <em>display</em> form, or one pre-formatted by the
      producer (mirrors the Decision Record's raw-vs-display question)?</li>
    <li>Is a coverage matrix a first-class section kind, or does it fall out of <code>scores[]</code> keyed
      by a dimension axis?</li>
    <li>Should the base severity set name a <code>pass</code>/positive tier, or stay failure-only and let a
      score express the positive roll-up?</li>
  </ul>
{{ pc.endStandardSection() }}
