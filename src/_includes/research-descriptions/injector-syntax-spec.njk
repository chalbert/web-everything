<h2>Appendix A: Full Desugaring Table</h2>
<table>
  <tr><th>DSL Syntax</th><th>Runtime API Equivalent</th></tr>
  <tr>
    <td><code>injector Name { ... }</code></td>
    <td><code>const Name = new Injector('Name');</code></td>
  </tr>
  <tr>
    <td><code>injector Name extends Parent { ... }</code></td>
    <td><code>const Name = new Injector('Name'); Name.parentInjector = Parent;</code></td>
  </tr>
  <tr>
    <td><code>injector Name isolate { ... }</code></td>
    <td><code>const Name = new Injector('Name'); /* no parent */</code></td>
  </tr>
  <tr>
    <td><code>provide X as 'key';</code></td>
    <td><code>injector.set('key', X);</code></td>
  </tr>
  <tr>
    <td><code>provide { 'a': A, 'b': B } as 'reg';</code></td>
    <td><code>const r = new Registry(); r.define('a', A); r.define('b', B); injector.set('reg', r);</code></td>
  </tr>
  <tr>
    <td><code>provide { 'a': A } in 'reg';</code></td>
    <td><code>const r = injector.get('reg') ?? new Registry(); r.define('a', A); injector.set('reg', r);</code></td>
  </tr>
  <tr>
    <td><code>provide * from parent;</code></td>
    <td><code>for (const [k, v] of parent.entries()) injector.set(k, v);</code></td>
  </tr>
  <tr>
    <td><code>provide { 'key1', 'key2' } from parent;</code></td>
    <td><code>['key1','key2'].forEach(k => { const v = parent.get(k); if (v) injector.set(k, v); });</code></td>
  </tr>
  <tr>
    <td><code>consume x from 'key';</code></td>
    <td><code>const x = injector.consume('key', this);</code></td>
  </tr>
  <tr>
    <td><code>consume { a, b } from 'ns';</code></td>
    <td><code>const a = injector.consume('ns:a', this); const b = injector.consume('ns:b', this);</code></td>
  </tr>
  <tr>
    <td><code>consume { 'path.expr' as x } from 'key';</code></td>
    <td><code>const x = injector.consume('key/path.expr', this);</code></td>
  </tr>
  <tr>
    <td><code>import.injector</code></td>
    <td><code>__resolveInjector(import.meta)</code> (compile-time) or factory parameter (runtime)</td>
  </tr>
</table>

