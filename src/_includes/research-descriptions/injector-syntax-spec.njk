<h3>2.1 DSL vs Runtime API</h3>
<p>
  The DSL is syntactic sugar over the Tier 1 runtime API.
  The right column shows what a developer would write without the DSL —
  readable, idiomatic code using <code>Injector</code>, <code>Consumable</code>,
  and <code>InjectableModule</code> directly.
</p>

<h4>Provide a Value</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>provide MyStore
  as 'customContexts:state';
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>injector.set(
  'customContexts:state',
  MyStore
);
</code></pre>
  </div>
</div>

<h4>Extend a Registry</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>provide { 'my-btn': Button }
  in 'customElements';
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>const elements =
  injector.get('customElements')
  ?? new CustomElementRegistry();

elements.define('my-btn', Button);
injector.set('customElements',
  elements);
</code></pre>
  </div>
</div>

<h4>Re-provide from Parent</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>// All providers
provide * from import.injector;

// Selected providers
provide { 'customElements' }
  from import.injector;
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>// All providers
for (const [key, value]
  of parent.entries()) {
  injector.set(key, value);
}

// Selected providers
const elements =
  parent.get('customElements');
if (elements) {
  injector.set('customElements',
    elements);
}
</code></pre>
  </div>
</div>

<h4>Consume a Provider</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>consume nav
  from 'customContexts:nav';

// nav is Consumable — not awaited
const { value } = await nav;
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>const nav = injector.consume(
  'customContexts:nav', this
);
// Returns Consumable&lt;T&gt;
const { value } = await nav;
</code></pre>
  </div>
</div>

<h4>Reactive Consumption</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>consume state
  from 'customContexts:state';

for await (const { value }
  of state) {
  this.render(value);
}
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>const state = injector.consume(
  'customContexts:state', this
);

for await (const { value }
  of state) {
  this.render(value);
}
</code></pre>
  </div>
</div>

<h4>Destructured Consume</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>consume { nav, redux }
  from 'customContexts';
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>const nav = injector.consume(
  'customContexts:nav', this
);
const redux = injector.consume(
  'customContexts:redux', this
);
</code></pre>
  </div>
</div>

<h4>Injector Block</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>injector AppScope {
  provide AppStore
    as 'customContexts:state';
  provide Router
    as 'customContexts:route';
}

injector TestScope
  extends AppScope {
  provide MockStore
    as 'customContexts:state';
}
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>const AppScope =
  new Injector('AppScope');
AppScope.set('customContexts:state',
  AppStore);
AppScope.set('customContexts:route',
  Router);

const TestScope =
  new Injector('TestScope');
TestScope.parentInjector = AppScope;
TestScope.set('customContexts:state',
  MockStore);
</code></pre>
  </div>
</div>

<h4>Module Integration</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">DSL</div>
<pre><code>provide Logger
  as 'customContexts:logger';
consume config
  from 'customContexts:config';
</code></pre>
  </div>
  <div>
    <div class="col-header">Runtime API</div>
<pre><code>const mod = new InjectableModule(
  'my-mod', import.meta, (m) =&gt; {
    m.provide(
      'customContexts:logger',
      new Logger()
    );
    const config = m.consume(
      'customContexts:config',
      import.meta
    );
  }
);
mod.bootstrap();
</code></pre>
  </div>
</div>

<h3>2.2 Plugged vs Unplugged DOM Access</h3>
<p>
  The compiled output above uses an abstract <code>injector</code> reference.
  In DOM contexts, how you <em>obtain</em> that injector depends on plugged vs unplugged mode.
  This is orthogonal to whether you write DSL or standard JS.
</p>

<h4>Obtaining an Injector</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">Plugged</div>
<pre><code>// Node.prototype patches
const inj =
  element.getClosestInjector();
</code></pre>
  </div>
  <div>
    <div class="col-header">Unplugged</div>
<pre><code>// InjectorRoot static methods
const inj = root
  .ensureInjector(element);
</code></pre>
  </div>
</div>

<h4>Traversing the Chain</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">Plugged</div>
<pre><code>element.getOwnInjector();
element.hasOwnInjector();
element.getClosestInjector();

for (const inj
  of element.injectors()) {
  console.log(inj.providers);
}
</code></pre>
  </div>
  <div>
    <div class="col-header">Unplugged</div>
<pre><code>InjectorRoot.getProviderOf(
  element, 'customContexts:nav');
InjectorRoot.getProvidersOf(element);

for (const inj of InjectorRoot
  .getInjectorChain(element)) {
  console.log(inj.providers);
}
</code></pre>
  </div>
</div>

<h4>Context Convenience Methods</h4>
<div class="syntax-compare">
  <div>
    <div class="col-header">Plugged</div>
<pre><code>element.getContext('nav');
element.getOwnContext('nav');
element.hasContext('nav');
element.ensureContext('nav');
element.createContext('nav');
element.queryContext(
  'nav', 'path.to.value');
element.createElement('my-button');
</code></pre>
  </div>
  <div>
    <div class="col-header">Unplugged</div>
<pre><code>InjectorRoot.getProviderOf(
  element, 'customContexts:nav');

// No convenience wrappers —
// use InjectorRoot statics
// or walk the chain manually.

InjectorRoot.getValueInProviderOf(
  element,
  'customElements',
  'my-button');
</code></pre>
  </div>
</div>

