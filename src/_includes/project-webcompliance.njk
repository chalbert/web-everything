{{ pc.standardSection('id="policy-model"') }}
  <h3 id="how-it-works">The Policy / Rule Model</h3>
  <p>
    A compliance policy is <strong>config, not a protocol</strong> &mdash; a versioned set of rules, each
    promoting a conformance <em>measure</em> to an enforced hard rule at a declared severity and scope. The
    platform ships a <strong>fully-defined default policy</strong> (the baseline gates); a project policy
    <code>extends</code> it and overrides only what differs, exactly as every other Web Everything config
    layer resolves a default.
  </p>
  {% highlight "typescript" %}
// The policy model — CONFIG (no protocol; results ride Web Reporting's report model).
// A project policy EXTENDS a fully-defined platform-default baseline (config-layer convention).

type Severity = 'block' | 'error' | 'warn' | 'off';   // 'block' fails the gate

interface PolicyRule {
  id: string;                  // the rule's stable id
  measure: string;             // the conformance signal it promotes, e.g. 'app-conformance:aria-sort'
  severity: Severity;
  scope?: string;              // where it applies — project | path glob | app id (default: whole project)
  threshold?: number | string; // the bar to clear, e.g. "L2" | 80  (conformanceLevel ≥ / coverage ≥)
  since?: string;              // the policy version this criterion was promoted in
}

interface CompliancePolicy {
  id: string;
  version: string;             // versioned — a gate result records the policy version it ran against
  extends?: string;            // the platform-default baseline policy id it builds on
  rules: PolicyRule[];         // overrides/adds on top of the inherited baseline
}

// 1. The platform ships the baseline fully-defined — every project inherits these gates.
const platformDefault: CompliancePolicy = definePlatformDefaultPolicy();

// 2. A project EXTENDS it — promote one more measure, relax another, leave the rest inherited.
const projectPolicy: CompliancePolicy = {
  id: 'my-app', version: '3', extends: platformDefault.id,
  rules: [
    { id: 'aria-sort', measure: 'app-conformance:aria-sort', severity: 'block', threshold: 'L2', since: '3' },
    { id: 'coverage',  measure: 'coverage:lines',            severity: 'warn',  threshold: 80 },
  ],
};

// 3. Resolution = baseline ⊕ project overrides (nearest wins), the same shape as every WE config layer.
const effective = resolvePolicy(projectPolicy);   // → the gates that actually run
  {% endhighlight %}
  <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
    <li><strong>Extends a platform default:</strong> the baseline is fully defined, so a project authors only
      its deltas &mdash; never a policy from scratch. The default <em>is</em> the recommended gate set.</li>
    <li><strong>Versioned:</strong> a policy carries its <code>version</code>, so an audit result records the
      exact rule set it was enforced against &mdash; the evidence replays.</li>
    <li><strong>Config, not a protocol:</strong> there is no cross-vendor policy-interchange contract in v1.
      The <em>results</em> are what interoperate, and they ride Web Reporting's report model.</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="composition"') }}
  <h3 id="composition">Composition With Other Standards</h3>
  <ul style="font-size: 0.9rem;">
    <li><strong><a href="/projects/webreporting/">Web Reporting</a></strong> &mdash; the audit/evidence
      trail emits as a <code>Report</code>; a gate result is just another report source. The shared report
      model is why Compliance needs no protocol of its own.</li>
    <li><strong>Conformance tooling (<a href="/backlog/314-flagship-exercise-apps/">#314</a>)</strong> &mdash;
      the first producer of conformance signals a compliance policy promotes (the <code>--strict</code>
      seed).</li>
    <li><strong><a href="/projects/webpolicy/">Web Policy</a></strong> &mdash; the sibling enforcement
      vocabulary for <em>domain</em> rules; same "policy-as-code, versioned, extends a default" shape,
      different subject (business actions vs. standards conformance).</li>
  </ul>
{{ pc.endStandardSection() }}

{{ pc.standardSection('id="status"') }}
  <h3 id="status">Status</h3>
  <p>
    Web Compliance is in <strong>PoC</strong> phase: the policy/rule model is specified here as the
    canonical first slice of the compliance epic (<a href="/backlog/351-web-compliance-project/">#351</a>),
    and <strong>all four spec layers are built</strong> in the PoC impl tree (<code>we:webcompliance/</code>
    &mdash; <code>gate.ts</code>, <code>waiver.ts</code>, <code>audit.ts</code>,
    <code>policies/platform-default.ts</code>, <code>conventions/vcs.ts</code>; 36 unit tests). The Project
    + policy-model shape was ratified: <strong>no compliance-specific protocol in v1</strong> &mdash;
    results ride <a href="/projects/webreporting/">Web Reporting</a>'s report model, and a policy-interchange
    protocol is added only if a concrete cross-vendor need appears. The built layers: gates
    (<a href="/backlog/437-build-the-compliance-gates-ci-runners-that-block-on-a-policy/">#437</a>), waivers
    (<a href="/backlog/438-add-waivers-exceptions-tracked-expiring-audited-overrides/">#438</a>), audit
    trail emit through Web Reporting
    (<a href="/backlog/439-build-the-audit-evidence-trail-emit-through-web-reporting/">#439</a>), the
    retrofit of <code>check:standards</code> + readiness gates as declared policies
    (<a href="/backlog/440-retrofit-check-standards-readiness-gates-as-declared-complia/">#440</a>), and the
    platform-default VCS-convention vocabulary
    (<a href="/backlog/579-platform-default-vcs-convention-vocabulary-in-the-compliance/">#579</a>) &mdash;
    all resolved. The deferred <em>hosted</em> compliance product is a separate, parked question
    (<a href="/backlog/966-where-does-hosted-we-compliance-validation-live-plateau-app-/">#966</a>).
  </p>
  <h4 style="margin-top: 1rem;">Open Questions</h4>
  <ul style="font-size: 0.9rem; color: var(--color-text-muted);">
    <li>Does <code>extends</code> resolve a single baseline, or a chain (platform → org → project) the way a
      config flavor stack would?</li>
    <li>Is <code>measure</code> a free string keyed to a producer's signal id, or does it reference a
      registered conformance-criterion catalog so a typo is caught at author time?</li>
    <li>Does a rule own its waiver policy inline, or is the waiver register a separate scope keyed by
      <code>rule.id</code> (the waivers slice, <a href="/backlog/438-add-waivers-exceptions-tracked-expiring-audited-overrides/">#438</a>)?</li>
  </ul>
{{ pc.endStandardSection() }}
