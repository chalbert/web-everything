{#
  HTML ↔ JSX source toggle for any element example.

  Reuses the global mode-selector.js handler (loaded in base.njk) — it keys off
  .mode-selector-container / .mode-tab[data-mode] / [data-mode-content][data-mode],
  so this emits that same structure with two modes: "html" and "jsx".

  HTML is canonical; the JSX pane is the reversible *mirror dialect* (class not
  className, on:click string behaviors, literal <template is="…"> directives) —
  see reports/2026-06-03-jsx-adapter-feature-mapping.md and /adapters/jsx-adapter/.

  Usage:
    {% from "source-toggle.njk" import sourceToggle, jsxSource, endSource %}
    {{ sourceToggle("user-card") }}
      {% highlight "html" %}<user-card name="Ada"></user-card>{% endhighlight %}
    {{ jsxSource("user-card") }}
      {% highlight "tsx" %}<user-card name="Ada" />{% endhighlight %}
    {{ endSource() }}

  Static authored pairs for now (Tier 1). A live htmlToJsx/jsxToHtml transform
  can auto-populate the JSX pane later (Tier 2).
#}

{% macro sourceToggle(id) %}
<div class="mode-selector-container" data-mode-selector="{{ id }}" style="border: 1px solid #e5e7eb; border-radius: 0.375rem; overflow: hidden; margin-bottom: 1rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0.75rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
        <span style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: #9ca3af;">Source</span>
        <div class="mode-tabs" style="display: flex; gap: 0; border: 1px solid #d1d5db; border-radius: 0.25rem; overflow: hidden;">
            <button class="mode-tab active" data-mode="html" style="padding: 0.25rem 0.75rem; font-size: 0.75rem; font-weight: 500; background: #059669; color: white; border: none; cursor: pointer;">
                HTML
            </button>
            <button class="mode-tab" data-mode="jsx" style="padding: 0.25rem 0.75rem; font-size: 0.75rem; font-weight: 500; background: white; color: #6b7280; border: none; border-left: 1px solid #d1d5db; cursor: pointer;">
                JSX
            </button>
        </div>
    </div>
    <div class="mode-content" data-mode-content="{{ id }}" data-mode="html" style="display: block;">
{% endmacro %}

{% macro jsxSource(id) %}
    </div>
    <div class="mode-content" data-mode-content="{{ id }}" data-mode="jsx" style="display: none;">
{% endmacro %}

{% macro endSource() %}
    </div>
</div>
{% endmacro %}
