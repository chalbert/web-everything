        <tr><th>Feature</th><th>Source (spec / lib)</th><th>What it does</th><th>Built-in</th><th>Adapter</th></tr>
      </thead>
      <tbody>
        <tr><td colspan="5" style="font-weight:600; background:rgba(5,150,105,0.06);">Core placement</td></tr>
        <tr><td><strong>Placement</strong> (12-way)</td><td>CSS <code>position-area</code> · FU <code>placement</code></td><td>Where the anchored element sits relative to the anchor</td><td>✅</td><td>✅</td></tr>
        <tr><td><strong>Offset</strong></td><td>FU <code>offset()</code> · CSS margin</td><td>Gap between anchor and anchored element</td><td>✅</td><td>✅</td></tr>
        <tr><td><strong>Anchor ↔ anchored binding</strong></td><td>CSS <code>anchor-name</code>/<code>position-anchor</code></td><td>Resolve which element tracks which</td><td>✅</td><td>✅</td></tr>
        <tr><td><strong>Strategy</strong> (absolute/fixed)</td><td>FU <code>strategy</code></td><td>CSS positioning context</td><td>✅</td><td>✅</td></tr>
        <tr><td colspan="5" style="font-weight:600; background:rgba(5,150,105,0.06);">Collision / fallback</td></tr>
        <tr><td><strong>Flip</strong></td><td>CSS <code>position-try</code> · FU <code>flip()</code></td><td>Flip to the opposite side on overflow</td><td>✅ basic</td><td>✅ robust</td></tr>
