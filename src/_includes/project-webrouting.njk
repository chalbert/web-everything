<section id="route-format" class="section-card">
    <h3 id="route-format-sot">Route-format source-of-truth</h3>
    <p>
        Routes are authored as <strong>declarative DOM</strong>, not a hand-written data table: today
        <code>parseRouteDefinitions()</code> runs <code>querySelectorAll('template[route]')</code> over
        <code>&lt;we-route-view&gt;</code>'s children, reading <code>route</code> / <code>route:guard</code> /
        <code>route:loader</code> / <code>route:outlet</code> / <code>route:error</code> attributes. That
        <code>&lt;template route&gt;</code> tree is the <strong>canonical authoring source-of-truth</strong>
        (HTML-first, single SoT, no drift), and <a href="https://developer.mozilla.org/docs/Web/API/URLPattern">URLPattern</a>
        (Baseline 2025) is the pattern grammar &mdash; webrouting invents no syntax. The catch: a
        <code>RouteDefinition</code> carries a compiled <code>URLPattern</code> + a live
        <code>HTMLTemplateElement</code>, <strong>both non-serializable</strong>, so no consumer (sitemap,
        prerender, config tooling) can read the route table without a DOM. webrouting therefore <em>derives</em>
        a serializable <strong>route-map projection</strong> &mdash; built by the first consuming slice, never
        speculatively &mdash; that drops the non-serializable fields and exposes the rest as a fixed shared
        contract.
    </p>
    {% highlight "typescript" %}
// AUTHORING source-of-truth — declarative DOM. The route table is the <template route> children of
// <we-route-view>; URLPattern is the grammar. This is what an author edits — HTML-first, single SoT.
//
//   <we-route-view>
//     <template route="/users/:id" route:loader="user" route:guard="auth">…</template>
//     <template route="/users/:id/settings" route:outlet="detail">…</template>
//   </we-route-view>

// DERIVED projection — a serializable route-map for non-DOM consumers (sitemap / prerender / config
// tooling). GENERATED from the DOM, never hand-authored, so there is no second authoring home and no
// drift. A 1:1 drop of the non-serializable pattern + template; keeps exactly the #1685 fields. The
// table is a flat ordered list (first match wins), mirroring parseRouteDefinitions — outlets are named,
// not nested. (Schema + validator + vectors authored in slice B, #1721: blocks/router/route-map.ts.)
interface RouteMapEntry {
  path: string;                 // the URLPattern pathname template, e.g. "/users/:id" (not a concrete URL)
  guard?: string;               // canActivate guard name (resolved from the @routeGuard context)
  guardLeave?: string;          // canDeactivate guard name
  loader?: string;              // data-loader name
  outlet?: string;              // named outlet identifier (omitted = primary, in-place)
  isErrorBoundary?: boolean;    // this entry is the route:error boundary
}
interface RouteMap {
  base?: string;                // optional base path the table was parsed under (paths are pre-resolved)
  routes: RouteMapEntry[];      // ordered, first-match-wins — mirrors the <template route> order
}
    {% endhighlight %}
    <ul style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 1rem;">
        <li><strong>One canonical authoring form:</strong> the <code>&lt;template route&gt;</code> DOM is the SoT;
            the serializable map is <em>derived</em>, never a second authored home &mdash; so there is no drift
            and HTML-first authoring is preserved
            (<a href="/backlog/1685-webrouting-route-format-source-of-truth-declarative-dom-temp/">#1685</a>).</li>
        <li><strong>URLPattern is the grammar:</strong> native-first &mdash; webrouting reuses the platform's
            URLPattern (Baseline 2025) rather than inventing a route syntax.</li>
        <li><strong>Internal schema, not yet a protocol:</strong> one conforming router exists today
            (<code>fui:blocks/router</code>), so the derived map is an internal WE schema + conformance vectors;
            a <code>CustomRouteMap</code> protocol is minted only on a <em>second</em> independent impl (the
            protocol temporal rule).</li>
        <li><strong>Build-only-when-a-consumer-exists:</strong> the projection <em>builder</em> is not slice B
            &mdash; it folds into the first consuming slice (sitemap,
            <a href="/backlog/1688-webrouting-sitemap-derivation-scope-which-artifact-set-ships/">#1688</a>);
            slice B ships the schema + vectors only.</li>
    </ul>
</section>
