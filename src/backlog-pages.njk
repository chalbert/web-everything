---
pagination:
    data: backlog
    size: 1
    addAllPagesToCollections: true
    alias: item
permalink: "backlog/{{ item.id }}/"
layout: base.njk
eleventyComputed:
    title: "Backlog - {{ item.title }}"
---

{% import "backlog-badges.njk" as bk with context %}
{% from "we-component.njk" import weCard %}
{# The 4 section-card panels below are authored via the generic SSR `weCard` primitive (#2098) — the same
   render-from-data macro semantics.njk uses. Each emits an inert `<we-card data-we-spec>` placeholder the
   `weComponentSSR` build transform batches through the pinned FUI CLI (one subprocess/page) and splices to
   the finished `<article class="fui-card">`, byte-identical to the client `<we-card>` CE upgrade, JS-off
   correct. This is the panel half of the tile-subset-of-detail parity (#2018 converted the tile grid). #}
{# Badge macros + vocabulary are shared with the /backlog/ tile via src/_includes/backlog-badges.njk
   + src/_data/backlogMeta.js — ONE source so the two surfaces cannot drift. Detail uses scale "md".
   check:standards forbids re-defining these locally. #}

<div class="plug-detail-header">
    <div class="plug-detail-header-inner">
        <nav class="plug-breadcrumb">
            <a href="/backlog/" class="plug-crumb">Backlog</a>
            <svg class="plug-crumb-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            <span class="plug-crumb plug-crumb-current">{{ item.title }}</span>
        </nav>
        <div class="plug-title-row">
            <h1 class="plug-title">{% if item.num %}<span style="color: var(--color-text-muted, #94a3b8); font-weight: 600; font-variant-numeric: tabular-nums;">#{{ item.num }}</span> {% endif %}{{ item.title }}</h1>
        </div>
        <div class="plug-status" style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; width: 100%; margin-top: 0.5rem;">
            {{ bk.kindBadge(item.kind, 'md') }}
            {{ bk.statusBadge(item.status, 'md') }}
            {{ bk.reasonPill(item, 'md') }}
            {% if item.size %}{{ bk.metaBadge('Size', item.size) }}{% endif %}
            {% if item.tier %}{{ bk.metaBadge('Tier', item.tier) }}{% endif %}
            {% if item.batchable %}{{ bk.metaBadge('Batchable', 'yes') }}{% endif %}
            {% if item.batchCost %}{{ bk.metaBadge('Cost', item.batchCost) }}{% endif %}
            {% if item.leverageScore %}{{ bk.metaBadge('Leverage', item.leverageScore) }}{% endif %}
            {% if item.directUnblocks %}{{ bk.metaBadge('Unblocks', item.directUnblocks) }}{% endif %}
            {% if item.transitiveUnblocks %}{{ bk.metaBadge('Unblocks (transitive)', item.transitiveUnblocks) }}{% endif %}
            {% if item.unblocksToReady %}{{ bk.metaBadge('Unblocks→ready', item.unblocksToReady) }}{% endif %}
            {% if item.parent %}{% set parentItem = null %}{% for p in backlog %}{% if p.num == item.parent %}{% set parentItem = p %}{% endif %}{% endfor %}{% if parentItem %}<a href="/backlog/{{ parentItem.id }}/" style="text-decoration: none;" title="{{ parentItem.title }}">{{ bk.metaBadge('Parent', '#' + item.parent) }}</a>{% else %}{{ bk.metaBadge('Parent', '#' + item.parent) }}{% endif %}{% endif %}
            {% if item.dateStarted %}{{ bk.metaBadge('Started', item.dateStarted) }}{% endif %}
            {% if item.dateResolved %}{{ bk.metaBadge('Resolved', item.dateResolved) }}{% endif %}
            {{ bk.epicStatusBadge(item, 'md') }}
        </div>
        {% if item.children and item.children.length %}
        {# Same "Contains" circles as the tile, at the very top — a mini constellation of this epic's slices. #}
        <div class="plug-epic-children" style="display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem; width: 100%; margin-top: 0.6rem;">
            <span style="font-size: 0.72em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600;">Contains</span>
            {% for child in item.children %}{{ bk.childCircle(child) }}{% endfor %}
        </div>
        {% endif %}
        {% if item.blockers and item.blockers.length %}
        {# Same "Blocked by" chips as the tile, at the top — open prerequisites red (⛔), cleared ones green (✓). #}
        <div class="plug-blockers" style="display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem; width: 100%; margin-top: 0.6rem;">
            <span style="font-size: 0.72em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600;">Blocked by</span>
            {% for b in item.blockers %}{{ bk.blockerChip(b) }}{% endfor %}
        </div>
        {% endif %}
    </div>
</div>

<div class="container block-detail-page">
    <div class="block-body content">
        {%- set _bodyPanel %}
            {% if item.details %}
            <div class="content" style="line-height: 1.7;">{{ item.details | safe }}</div>
            {% else %}
            <p class="mb-4 text-slate-600" style="font-size: 1.1em; line-height: 1.6;">{{ item.summary }}</p>
            {% endif %}

            {{ bk.tagsRow(item.tags, 'md') }}

            <p style="font-size: 0.85em; color: var(--color-text-muted, #94a3b8);">Opened: {{ item.dateOpened }}</p>
        {% endset -%}
        {{ weCard("", _bodyPanel, "", "section-card") }}

        {% if item.children and item.children.length %}
        {%- set _containsPanel %}
            <h2>Contains</h2>
            <p style="color: var(--color-text-muted); margin-top: -0.25rem;">Child slices of this epic{% if item.openChildCount %} — <strong>{{ item.openChildCount }}</strong> still open{% else %} — all resolved{% endif %}. Each is coloured by agent-readiness.</p>
            <ul style="list-style: none; padding: 0; margin: 0.75rem 0 0; display: flex; flex-direction: column; gap: 0.6rem;">
                {% for child in item.children %}
                <li style="display: flex; gap: 0.5rem; align-items: center;">
                    {{ bk.childCircle(child) }}
                    <a href="/backlog/{{ child.id }}/" style="color: var(--color-primary); font-weight: 600; text-decoration: none;">{{ child.title }}</a>
                    {% if child.size %}{{ bk.metaBadge('Size', child.size) }}{% elif child.kind %}{{ bk.metaBadge('Kind', child.kind) }}{% endif %}
                    {{ bk.statusBadge(child.status, 'md') }}
                </li>
                {% endfor %}
            </ul>
        {% endset -%}
        {{ weCard("", _containsPanel, "", "section-card mt-8") }}
        {% endif %}

        {% if item.blockers and item.blockers.length %}
        {%- set _blockedByPanel %}
            <h2>Blocked by</h2>
            <p style="color: var(--color-text-muted); margin-top: -0.25rem;">This item can't start until each prerequisite is resolved.</p>
            <ul style="list-style: none; padding: 0; margin: 0.75rem 0 0; display: flex; flex-direction: column; gap: 0.6rem;">
                {% for blocker in item.blockers %}
                <li style="display: flex; gap: 0.5rem; align-items: center;">
                    <a href="/backlog/{{ blocker.id }}/" style="color: var(--color-primary); font-weight: 600; text-decoration: none;"><span style="color: var(--color-text-muted, #94a3b8); font-variant-numeric: tabular-nums;">#{{ blocker.num }}</span> {{ blocker.title }}</a>
                    {{ bk.statusBadge(blocker.status, 'md') }}
                </li>
                {% endfor %}
            </ul>
        {% endset -%}
        {{ weCard("", _blockedByPanel, "", "section-card mt-8") }}
        {% endif %}

        {% if item.crossRef or item.relatedProject or item.relatedReport or item.graduatedTo %}
        {%- set _referencesPanel %}
            <h2>References</h2>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
                {% if item.crossRef %}
                <li><a href="{{ item.crossRef.url }}" style="color: var(--color-primary); font-weight: 600; text-decoration: none;">&rarr; {{ item.crossRef.label }}</a></li>
                {% endif %}
                {% if item.relatedProject %}
                {% for project in projects %}{% if project.id == item.relatedProject %}
                <li><a href="/projects/{{ project.id }}/" style="color: var(--color-primary); font-weight: 600; text-decoration: none;">&rarr; Project: {{ project.name }}</a></li>
                {% endif %}{% endfor %}
                {% endif %}
                {% if item.relatedReport %}
                <li style="color: var(--color-text-muted);">Deep dive{% if item.reportDate %} <span style="color: var(--color-text); font-weight: 600;">({{ item.reportDate }})</span>{% endif %} — in repo, not on site: <span style="font-family: var(--font-mono, monospace);">{{ item.relatedReport }}</span></li>
                {% endif %}
                {% if item.graduatedTo %}
                <li style="color: #166534; font-weight: 600;">Graduated into: {{ item.graduatedTo }}</li>
                {% endif %}
            </ul>
        {% endset -%}
        {{ weCard("", _referencesPanel, "", "section-card mt-8") }}
        {% endif %}
    </div>
</div>

{#
  PARITY RULE — the detail page is a SUPERSET of the tile.
  Every field/badge/section `src/backlog.njk` shows on a tile MUST also appear here
  (the detail page may show MORE — leverage, unblocks, dates, full body — but never less).
  When you add anything to the tile, add it here in the same turn. Tile → detail mapping:
    type / status / workItem / size / tier  → header badges
    epic unsliced·why / all-slices-done / ⚠ open-slice → header epic-status badge
    "Contains" child circles                 → Contains section
    "Blocked by" chips                        → Blocked by section
    tags                                      → tags row
    crossRef / relatedProject / relatedReport / graduatedTo → References section
  Codified in docs/agent/backlog-workflow.md ("Tile ⊆ detail" rule).
#}
