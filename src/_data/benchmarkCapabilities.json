{
  "id": "benchmark-capabilities",
  "version": 1,
  "lastSwept": "2026-06-12",
  "corpus": "benchmark-corpus",
  "description": "Phase 2 of the gap-analysis program (backlog #346): the normalized capability matrix extracted from the benchmark corpus (#316). Each row is one capability the corpus exposes, deduped across sources into a stable id (e.g. Material 'Menu', Fluent 'Menu', Radix 'Dropdown Menu' -> one `menu` capability). Phase 3 (#347) joins each row to a Web Everything entity and labels coverage. This is a FIRST PASS keyed for diffability, not an exhaustive per-source enumeration (see method.scope).",
  "method": {
    "howRead": "Each source's component catalogue + documented patterns + accessibility/standards guidance were read and collapsed bottom-up into shared capability ids. A 'component' is a documented, named UI building block; a 'pattern' is a cross-cutting behavior a component composes (focus return, type-ahead, async pagination); a 'token' is a themeable design value; a 'standard' is an accessibility/i18n conformance expectation.",
    "dedup": "Capabilities are capability-keyed, not source-keyed: one id carries the union of sources that provide it. Synonyms are merged (snackbar = toast; sheet = drawer; combobox = autocomplete-select).",
    "ubiquityScale": {
      "universal": "present in essentially every implementing source (the component kits, mature DS, and most headless sets)",
      "common": "present in a clear majority",
      "partial": "present in a minority / only some axes",
      "emerging": "appearing recently or only in standards/native frontier"
    },
    "scope": "FIRST PASS. `ubiquity` is a coarse cross-corpus signal and `notableIn` flags standout/canonical implementations; exact per-source presence + deep doc URLs per (capability x source) are deferred to the per-source fan-out (a #346 split under #315). `nativeAnchorHint` is recorded now so phase 3's native-first weighing has input.",
    "reproducibility": "Keyed by stable capability `id` so a re-run yields a clean diff (capabilities added / removed / re-classified) rather than a rewrite. Bump `version` + `lastSwept` per run."
  },
  "kinds": [
    { "id": "component", "label": "Component", "test": "A documented, named UI building block." },
    { "id": "pattern", "label": "Pattern", "test": "A cross-cutting behavior a component composes." },
    { "id": "token", "label": "Token", "test": "A themeable design value / scale." },
    { "id": "standard", "label": "Standard", "test": "An accessibility / i18n conformance expectation." }
  ],
  "capabilities": [
    { "id": "button", "label": "Button", "kind": "component", "family": "actions", "ubiquity": "universal", "notableIn": ["material-3", "carbon"], "nativeAnchorHint": "button element", "summary": "Primary/secondary/tertiary action triggers with variants and states." },
    { "id": "icon-button", "label": "Icon button", "kind": "component", "family": "actions", "ubiquity": "universal", "notableIn": ["fluent-2"], "nativeAnchorHint": "button + aria-label", "summary": "Compact icon-only action with required accessible name." },
    { "id": "button-group", "label": "Button / toggle group", "kind": "component", "family": "actions", "ubiquity": "common", "notableIn": ["radix-primitives", "material-3"], "nativeAnchorHint": "role=group / radiogroup", "summary": "Segmented set of related actions or single/multi toggles." },
