---
layout: base.njk
title: Backlog
---

{# PARITY RULE: this is the tile index. Anything you expose on a tile here MUST also be exposed on the
   /backlog/{id}/ detail page (src/backlog-pages.njk) — the detail page is a superset of the tile.
   Add tile fields to both in the same change. See docs/agent/backlog-workflow.md ("Tile ⊆ detail"). #}

{% from "display-toolbar.njk" import displayToolbar %}

<style>
.backlog-tabs { display: flex; gap: 0.25rem; border-bottom: 1px solid var(--color-border); margin: 0 0 1.5rem; }
.backlog-tab { appearance: none; background: none; border: none; border-bottom: 2px solid transparent; padding: 0.6rem 1rem; font: inherit; font-weight: 600; color: var(--color-text-muted, #64748b); cursor: pointer; margin-bottom: -1px; }
.backlog-tab:hover { color: var(--color-text); }
.backlog-tab.is-active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
.bd-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
.bd-card { border: 1px solid var(--color-border); border-radius: 0.6rem; padding: 0.85rem 1rem; background: var(--color-surface-alt, #f8fafc); }
.bd-card .n { font-size: 1.6em; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1.1; }
.bd-card .l { font-size: 0.78em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; }
.bd-callout { border-left: 4px solid; padding: 0.75rem 1rem; border-radius: 0 0.5rem 0.5rem 0; margin-bottom: 1.5rem; font-size: 0.92em; }
.bd-callout.diverging { border-color: #dc2626; background: #fef2f2; color: #991b1b; }
.bd-callout.converging { border-color: #16a34a; background: #f0fdf4; color: #166534; }
.bd-ratetable { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.88em; background: #fff; }
.bd-ratetable th, .bd-ratetable td { text-align: right; padding: 0.4rem 0.75rem; border-bottom: 1px solid var(--color-border); font-variant-numeric: tabular-nums; }
.bd-ratetable th:first-child, .bd-ratetable td:first-child { text-align: left; }
.bd-ratetable thead th { color: var(--color-text-muted); font-weight: 600; }
.bd-gran, .bg-filter { display: inline-flex; gap: 0.25rem; margin-bottom: 0.75rem; }
.bd-gran button, .bg-filter button { appearance: none; border: 1px solid var(--color-border); background: var(--color-surface, #fff); padding: 0.3rem 0.75rem; font: inherit; font-size: 0.85em; cursor: pointer; }
.bd-gran button:first-child, .bg-filter button:first-child { border-radius: 0.4rem 0 0 0.4rem; }
.bd-gran button:last-child, .bg-filter button:last-child { border-radius: 0 0.4rem 0.4rem 0; }
.bd-gran button.is-active, .bg-filter button.is-active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
.bd-chart-wrap { border: 1px solid var(--color-border); border-radius: 0.6rem; padding: 1rem; }
.bd-legend { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; font-size: 0.82em; color: var(--color-text-muted); }
.bd-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
.bd-legend i { width: 18px; height: 0; border-top-width: 3px; border-top-style: solid; display: inline-block; }
/* Collapsible top blurb + legends — open by default, state persisted to localStorage (data-persist key). */
.bk-collapse { margin-bottom: 1.5rem; }
.bk-collapse > summary { cursor: pointer; font-weight: 600; color: var(--color-text-muted, #64748b); font-size: 0.82em; text-transform: uppercase; letter-spacing: 0.03em; list-style: none; display: inline-flex; align-items: center; gap: 0.4rem; user-select: none; padding: 0.15rem 0; width: fit-content; }
.bk-collapse > summary::-webkit-details-marker { display: none; }
.bk-collapse > summary::before { content: "\25B8"; font-size: 0.9em; transition: transform 0.15s ease; }
.bk-collapse[open] > summary::before { transform: rotate(90deg); }
.bk-collapse > summary:hover { color: var(--color-text); }
.bk-collapse[data-persist="intro"] { margin-bottom: 0; }
.bk-collapse[data-persist="intro"] > summary { margin-top: 0.25rem; }
</style>

{% macro typeBadge(type) %}
<span style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; white-space: nowrap;
  background: {% if type == 'idea' %}#ede9fe{% elif type == 'issue' %}#fee2e2{% elif type == 'decision' %}#e0e7ff{% else %}#f1f5f9{% endif %};
  color: {% if type == 'idea' %}#5b21b6{% elif type == 'issue' %}#991b1b{% elif type == 'decision' %}#3730a3{% else %}#64748b{% endif %};">{{ type }}</span>
{% endmacro %}

{% macro statusBadge(status) %}
<span style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.75em; font-weight: 600; white-space: nowrap;
  background: {% if status == 'open' %}#fef3c7{% elif status == 'active' %}#dbeafe{% elif status == 'preparing' %}#ede9fe{% elif status == 'resolved' %}#dcfce7{% else %}#f1f5f9{% endif %};
  color: {% if status == 'open' %}#92400e{% elif status == 'active' %}#1e40af{% elif status == 'preparing' %}#6d28d9{% elif status == 'resolved' %}#166534{% else %}#64748b{% endif %};">{% if status == 'preparing' %}Prepping{% else %}{{ status | title }}{% endif %}</span>
{% endmacro %}

{% macro sizeBadge(size) %}
<span title="Estimate: {{ size }} agile point{% if size != 1 %}s{% endif %}" style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; white-space: nowrap; font-variant-numeric: tabular-nums; background: var(--color-surface-alt, #f1f5f9); color: var(--color-text-muted, #64748b);">{{ size }} pt{% if size != 1 %}s{% endif %}</span>
{% endmacro %}

{# Stand-in for the size badge on an UNSIZED item (an epic rolls its children's points; a task's roll up
   to its parent) so every tile shows something in the size slot — mirrors the Prioritisation cell. #}
{% macro workItemBadge(workItem) %}
<span title="{{ workItem }} — unsized ({% if workItem == 'epic' %}rolls up its child stories{% else %}points roll up to its parent{% endif %})" style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; white-space: nowrap; background: var(--color-surface-alt, #f1f5f9); color: var(--color-text-muted, #64748b);">{{ workItem }}</span>
{% endmacro %}

{# A child of an epic, drawn as a numbered circle coloured by the SAME agent-readiness palette as the
   dependency graph nodes (resolved=grey · active=blue · ready=green · decision=amber · not-ready=slate),
   so the epic tile reads at a glance like a mini constellation of its slices. Sits above the card's
   overlay link (z-index 2) so each circle is independently clickable. #}
{% macro childCircle(child) %}
{% set bg = "#f1f5f9" %}{% set bd = "#94a3b8" %}{% set fg = "#475569" %}
{% if child.status == 'resolved' %}{% set bg = "#f8fafc" %}{% set bd = "#cbd5e1" %}{% set fg = "#94a3b8" %}
{% elif child.status == 'active' %}{% set bg = "#dbeafe" %}{% set bd = "#2563eb" %}{% set fg = "#1e40af" %}
{% elif child.status == 'preparing' %}{% set bg = "#ede9fe" %}{% set bd = "#7c3aed" %}{% set fg = "#6d28d9" %}
{% elif child.tier == 'A' %}{% set bg = "#dcfce7" %}{% set bd = "#16a34a" %}{% set fg = "#166534" %}
{% elif child.tier == 'B' %}{% set bg = "#fef3c7" %}{% set bd = "#d97706" %}{% set fg = "#92400e" %}{% endif %}
<a href="/backlog/{{ child.id }}/" title="#{{ child.num }} {{ child.title }} · {% if child.size %}{{ child.size }} pt{% if child.size != 1 %}s{% endif %}{% else %}{{ child.workItem }}{% endif %} · {{ child.status }}" style="position: relative; z-index: 2; display: inline-flex; align-items: center; justify-content: center; min-width: 1.7rem; height: 1.7rem; padding: 0 0.35rem; border-radius: 9999px; background: {{ bg }}; border: 1.5px solid {{ bd }}; color: {{ fg }}; font-size: 0.72em; font-weight: 700; font-variant-numeric: tabular-nums; text-decoration: none;">{{ child.num }}</a>
{% endmacro %}

{# A prerequisite (`blockedBy`) drawn as a pill: a still-open blocker is red with ⛔ (it's what's holding
   this item back), a resolved one is green with ✓ (cleared — kept so the dependency reads in full). Sits
   above the card overlay (z-index 2) so it stays clickable. #}
{% macro blockerChip(b) %}
{% if b.status == 'resolved' %}
<a href="/backlog/{{ b.id }}/" title="#{{ b.num }} {{ b.title }} · resolved — cleared" style="position: relative; z-index: 2; display: inline-flex; align-items: center; gap: 0.15rem; padding: 0.05rem 0.45rem; border-radius: 9999px; font-size: 0.72em; font-weight: 700; font-variant-numeric: tabular-nums; text-decoration: none; background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0;">&#10003; #{{ b.num }}</a>
{% else %}
<a href="/backlog/{{ b.id }}/" title="#{{ b.num }} {{ b.title }} · {{ b.status }} — still blocking" style="position: relative; z-index: 2; display: inline-flex; align-items: center; gap: 0.15rem; padding: 0.05rem 0.45rem; border-radius: 9999px; font-size: 0.72em; font-weight: 700; font-variant-numeric: tabular-nums; text-decoration: none; background: #fef2f2; color: #991b1b; border: 1px solid #fecaca;">&#9940; #{{ b.num }}</a>
{% endif %}
{% endmacro %}

{# The "unsliced" badge for a childless epic — when the author has recorded a `childlessReason` it reads
   "unsliced · <why>" with a colour + tooltip from childlessReasonMeta; otherwise a bare "unsliced". #}
{% macro unslicedBadge(reason) %}
{% set m = childlessReasonMeta[reason] %}
{% if m %}<span title="{{ m.tip }}" style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; white-space: nowrap; background: {{ m.bg }}; color: {{ m.fg }};">unsliced &middot; {{ m.label }}</span>{% else %}<span title="Unsliced epic — no child stories cut yet, and no reason recorded (add a childlessReason)." style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; white-space: nowrap; background: #f1f5f9; color: #64748b;">unsliced</span>{% endif %}
{% endmacro %}

{# Why a childless epic has no child stories yet — author-supplied (`childlessReason`), since the reason
   lives in the body, not in derivable fields. Rendered as an at-a-glance badge on the tile. `blocked` is
   the one case also shown structurally (the red Blocked-by row), so its badge stays muted. #}
{% set childlessReasonMeta = {
  "blocked":   { label: "blocked",         bg: "#fef2f2", fg: "#991b1b", tip: "No child stories yet — it's waiting on the prerequisites in the Blocked-by row. The slices can't be cut until those clear." },
  "undecided": { label: "needs decisions", bg: "#fef3c7", fg: "#92400e", tip: "No child stories yet — open design decisions determine where the slices fall. Resolve them and it splits into stories." },
  "untriaged": { label: "needs triage",    bg: "#ede9fe", fg: "#5b21b6", tip: "No child stories yet — a holding-pen of candidates; each must be triaged (promote / fold / drop) before any become stories." },
  "program":   { label: "ongoing program", bg: "#e0f2fe", fg: "#075985", tip: "No child stories by design — a continuous program measured by progress, not a fixed set of child stories." }
} %}

{# Tier labels & one-line meaning — kept in one place so the chip, the card badge, and its tooltip stay in sync. #}
{% set tierLabel = { "A": "Agent-ready", "B": "Decision-ready", "C": "Not ready" } %}
{% set tierMeaning = { "A": "issue/idea with all prerequisites resolved — nothing structural blocks an agent starting", "B": "a decision awaiting a nod — ratify it, then it's a quick build", "C": "needs design or is blocked — an issue/idea with an unresolved prerequisite" } %}

{# Agent-readiness chip. Heuristic HINT, not authoritative: derived in the loader from structured fields only (type + resolved blockers), so it's deterministic across rebuilds but cannot see the two prose signals the LLM selection pass weighs. #}
{% macro tierBadge(tier) %}
{% if tier %}<span title="Agent-readiness hint — {{ tierMeaning[tier] }}. Heuristic from structured fields only (type + resolved prerequisites); not authoritative — the selection pass still refines it." style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; white-space: nowrap;
  background: {% if tier == 'A' %}#dcfce7{% elif tier == 'B' %}#fef3c7{% else %}#f1f5f9{% endif %};
  color: {% if tier == 'A' %}#166534{% elif tier == 'B' %}#92400e{% else %}#64748b{% endif %};">{{ tierLabel[tier] }}</span>{% endif %}
{% endmacro %}

<section class="intro">
    <h1>Backlog</h1>
    <details class="bk-collapse" data-persist="intro" open>
        <summary>About the backlog</summary>
        <p>The single source of truth for ideas, issues, and decisions across Web Everything. Each item is one markdown file in <code>backlog/</code>, completely dynamic — its title, summary, and detail come from markdown (the item's own body, or a related report it mirrors), never hand-typed. Open questions raised on the standards' own pages are collected live below. Deep thinking stays in <code>reports/</code> — a backlog item links out to it or mirrors it.</p>
    </details>
</section>

<div class="backlog-tabs" role="tablist" aria-label="Backlog views">
    <button type="button" class="backlog-tab is-active" role="tab" aria-selected="true" aria-controls="panel-tracked" id="tab-tracked" data-bd-tab="tracked">Tracked work</button>
    <button type="button" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-priority" id="tab-priority" data-bd-tab="priority">Prioritisation</button>
    <button type="button" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-graph" id="tab-graph" data-bd-tab="graph">Graph</button>
    <button type="button" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-burndown" id="tab-burndown" data-bd-tab="burndown">Burndown</button>
</div>

<div id="panel-tracked" role="tabpanel" aria-labelledby="tab-tracked">
{% set statusOrder = ["open", "active", "preparing", "parked", "resolved"] %}
{# Item types present in the backlog, in preferred order. #}
{% set typeOrder = ["idea", "issue", "decision"] %}
{% set typeChips = [] %}
{% for t in typeOrder %}{% if (backlog | where("type", t) | length) %}{% set typeChips = (typeChips.push(t), typeChips) %}{% endif %}{% endfor %}
{# Agile-point estimates, in Fibonacci order; only sizes actually present become chips. #}
{% set sizeOrder = [1, 2, 3, 5, 8, 13] %}
{% set sizeChips = [] %}
{% for s in sizeOrder %}{% if (backlog | where("size", s) | length) %}{% set sizeChips = (sizeChips.push(s), sizeChips) %}{% endif %}{% endfor %}
{# Agent-readiness tiers actually present (only open items carry one); chip lets you filter to Tier A. #}
{% set tierOrder = ["A", "B", "C"] %}
{% set tierChips = [] %}
{% for t in tierOrder %}{% if (backlog | where("tier", t) | length) %}{% set tierChips = (tierChips.push(t), tierChips) %}{% endif %}{% endfor %}
{# Work-item kinds present (epic / story / task); chip lets you filter to e.g. just epics. #}
{% set workItemOrder = ["epic", "story", "task"] %}
{% set workItemChips = [] %}
{% for w in workItemOrder %}{% if (backlog | where("workItem", w) | length) %}{% set workItemChips = (workItemChips.push(w), workItemChips) %}{% endif %}{% endfor %}
<section class="mb-12">
    <h2 class="section-title">Tracked work <span class="count-badge" data-count-target>{{ backlog | length }}</span></h2>
    <p class="section-desc">Ideas, issues, and decisions — ordered by status. Filter by status, type, or keyword, or switch to a compact list. Resolved items are hidden by default.</p>
    <div class="backlog-filter-row">
        <div class="filter-groups">
            <div class="status-filter" role="group" aria-label="Filter by status">
                {% for s in statusOrder %}
                <button type="button" class="status-filter-chip" data-status-chip="{{ s }}" aria-pressed="true">{{ s | title }}</button>
                {% endfor %}
            </div>
            <div class="status-filter" role="group" aria-label="Filter by type">
                {% for t in typeChips %}
                <button type="button" class="status-filter-chip" data-type-chip="{{ t }}" aria-pressed="true">{{ t | title }}</button>
                {% endfor %}
            </div>
            {% if sizeChips | length %}
            <div class="status-filter" role="group" aria-label="Filter by size">
                {% for s in sizeChips %}
                <button type="button" class="status-filter-chip" data-size-chip="{{ s }}" aria-pressed="true">{{ s }} pt{% if s != 1 %}s{% endif %}</button>
                {% endfor %}
            </div>
            {% endif %}
            {% if tierChips | length %}
            <div class="status-filter" role="group" aria-label="Filter by agent-readiness">
                {% for t in tierChips %}
                <button type="button" class="status-filter-chip" data-tier-chip="{{ t }}" aria-pressed="true" title="{{ tierMeaning[t] }}">{{ tierLabel[t] }}</button>
                {% endfor %}
            </div>
            {% endif %}
            {% if workItemChips | length %}
            <div class="status-filter" role="group" aria-label="Filter by work item">
                {% for w in workItemChips %}
                <button type="button" class="status-filter-chip" data-workitem-chip="{{ w }}" aria-pressed="true" title="{% if w == 'epic' %}umbrella — rolls up child stories{% elif w == 'story' %}an independently valuable, sized deliverable{% else %}bounded sub-work under a parent{% endif %}">{{ w | title }}</button>
                {% endfor %}
            </div>
            {% endif %}
        </div>
        {{ displayToolbar("backlog") }}
    </div>
    {# Legend for the "Contains" circles on epic tiles — each child is a numbered circle coloured by the
       SAME agent-readiness palette as the dependency-graph nodes. Only shown if some epic has children. #}
    {% set hasEpicChildren = false %}
    {% for item in backlog %}{% if item.children | length %}{% set hasEpicChildren = true %}{% endif %}{% endfor %}
    {% if hasEpicChildren %}
    <details class="bk-collapse" data-persist="legend-epic-children" open>
    <summary>Readiness legend</summary>
    <div class="epic-children-legend" style="display:flex; flex-wrap:wrap; align-items:center; gap:0.4rem 1rem; margin:0.5rem 0 1rem; font-size:0.8em; color:var(--color-text-muted);">
        <span style="flex-basis:100%; font-weight:600;">Epic tiles list the items they <strong style="text-transform:uppercase; letter-spacing:0.03em; font-weight:700;">contain</strong> as numbered circles, coloured by readiness:</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#dcfce7; border:1.5px solid #16a34a;"></span><strong style="color:#166534;">Agent-ready</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#fef3c7; border:1.5px solid #d97706;"></span><strong style="color:#92400e;">Decision-ready</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#f1f5f9; border:1.5px solid #94a3b8;"></span><strong style="color:#475569;">Not ready</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#dbeafe; border:1.5px solid #2563eb;"></span><strong style="color:#1e40af;">In progress</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#f8fafc; border:1.5px solid #cbd5e1;"></span>Resolved</span>
    </div>
    </details>
    {% endif %}
    {# Legend for the `unsliced · <why>` badge — why a childless epic has no child stories yet. Only shown
       if some childless epic carries a recorded reason. Colours match childlessReasonMeta / the badges. #}
    {% set hasUnslicedReason = false %}
    {% for item in backlog %}{% if item.workItem == 'epic' and not (item.children | length) and item.childlessReason %}{% set hasUnslicedReason = true %}{% endif %}{% endfor %}
    {% if hasUnslicedReason %}
    <details class="bk-collapse" data-persist="legend-unsliced" open>
    <summary>Epic status legend</summary>
    <div class="unsliced-legend" style="display:flex; flex-wrap:wrap; align-items:center; gap:0.4rem 1rem; margin:0.5rem 0 1rem; font-size:0.8em; color:var(--color-text-muted);">
        <span style="flex-basis:100%; font-weight:600;">An <strong style="text-transform:uppercase; letter-spacing:0.03em; font-weight:700;">unsliced</strong> epic has no child stories cut yet; the tag says <em>why</em>:</span>
        {% for key, m in childlessReasonMeta %}
        <span style="display:inline-flex; align-items:center; gap:0.4rem;" title="{{ m.tip }}"><span style="padding:0.05rem 0.45rem; border-radius:9999px; font-size:0.92em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:{{ m.bg }}; color:{{ m.fg }};">{{ m.label }}</span><span>{% if key == 'blocked' %}waiting on prerequisites (see Blocked-by){% elif key == 'undecided' %}open decisions set where the slices fall{% elif key == 'untriaged' %}candidates to promote / fold / drop first{% else %}continuous program — no fixed child stories{% endif %}</span></span>
        {% endfor %}
        <span style="flex-basis:100%; font-weight:600; margin-top:0.2rem;">A <em>storied</em> epic (one with child slices) may also flag its completion state:</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;" title="Every child slice is resolved but the epic is still open — its scope looks delivered. Review the epic: resolve it, or add the remaining child work."><span style="padding:0.05rem 0.45rem; border-radius:9999px; font-size:0.92em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#dcfce7; color:#166534;">all slices done</span><span>every child resolved — review &amp; resolve the epic (or add stories)</span></span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;" title="The epic is resolved but some child slice is still open — a contradiction. Reopen the epic, re-parent, or resolve the children."><span style="padding:0.05rem 0.45rem; border-radius:9999px; font-size:0.92em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#fef2f2; color:#991b1b;">&#9888; open slice</span><span>epic resolved but a child is still open — contradiction to fix</span></span>
    </div>
    </details>
    {% endif %}
    <div class="project-grid">
        {% for group in statusOrder %}{% for item in backlog %}{% if item.status == group %}
        <div class="project-card" data-status="{{ item.status }}" data-type="{{ item.type }}" data-size="{{ item.size }}" data-tier="{{ item.tier }}" data-workitem="{{ item.workItem }}">
            <a href="/backlog/{{ item.id }}/" class="project-card-link" aria-label="View {{ item.title }}"></a>
            <div class="project-header" style="margin-bottom: 0.4rem;">
                <h3 class="project-title" style="margin: 0; font-size: 1.05em;">{% if item.num %}<span style="color: var(--color-text-muted, #94a3b8); font-weight: 600; font-variant-numeric: tabular-nums;">#{{ item.num }}</span> {% endif %}{{ item.title }}</h3>
            </div>
            <div class="backlog-badges" style="margin-bottom: 0.6rem; display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;">{{ typeBadge(item.type) }}{{ statusBadge(item.status) }}{% if item.workItem == 'epic' %}{{ workItemBadge('epic') }}{% if item.size %}{{ sizeBadge(item.size) }}{% endif %}{% elif item.size %}{{ sizeBadge(item.size) }}{% elif item.workItem %}{{ workItemBadge(item.workItem) }}{% endif %}{{ tierBadge(item.tier) }}{% if item.workItem == 'epic' %}{% if not (item.children | length) %}{{ unslicedBadge(item.childlessReason) }}{% elif item.openChildCount == 0 and (item.status == 'open' or item.status == 'active') %}<span title="Every child slice is resolved but the epic is still open — its scope looks delivered. Resolve it, or add the remaining child work." style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; white-space: nowrap; background: #dcfce7; color: #166534;">all slices done</span>{% elif item.openChildCount and item.status == 'resolved' %}<span title="The epic is resolved but {{ item.openChildCount }} child slice(s) are still open — a contradiction. Reopen the epic, re-parent, or resolve the children." style="padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; white-space: nowrap; background: #fef2f2; color: #991b1b;">&#9888; {{ item.openChildCount }} open slice{% if item.openChildCount != 1 %}s{% endif %}</span>{% endif %}{% endif %}</div>
            {% if item.blockers | length %}
            {# Prerequisites (`blockedBy`) on every tile — open ones (red ⛔) are why an item is Not-ready;
               for an unsliced epic they double as "why it's empty". Resolved ones (green ✓) show the edge
               was satisfied. #}
            <div class="backlog-blockers" style="position: relative; z-index: 2; display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem; margin: 0 0 0.6rem;">
                <span style="font-size: 0.72em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600;">Blocked by</span>
                {% for b in item.blockers %}{{ blockerChip(b) }}{% endfor %}
            </div>
            {% endif %}
            <p class="backlog-summary" style="margin: 0 0 0.75rem 0; color: var(--color-text-muted); font-size: 0.9em;">{{ item.summary }}</p>
            {% if item.children | length %}
            <div class="epic-children" style="position: relative; z-index: 2; display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem; margin: 0 0 0.75rem;">
                <span style="font-size: 0.72em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600;">Contains</span>
                {% for child in item.children %}{{ childCircle(child) }}{% endfor %}
            </div>
            {% endif %}
            <div class="backlog-meta">
                {% if item.tags %}
                <div style="display: flex; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
                    {% for tag in item.tags %}
                    <span style="display: inline-block; padding: 0.1rem 0.5rem; border-radius: 9999px; background: var(--color-surface-alt, #f1f5f9); color: var(--color-text-muted, #64748b); font-size: 0.75em;">{{ tag }}</span>
                    {% endfor %}
                </div>
                {% endif %}
                <div style="display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.8em;">
                    {% if item.crossRef %}
                    <a href="{{ item.crossRef.url }}" style="color: var(--color-primary); text-decoration: none;">&rarr; {{ item.crossRef.label }}</a>
                    {% endif %}
                    {% if item.relatedProject %}
                    <a href="/projects/{{ item.relatedProject }}/" style="color: var(--color-primary); text-decoration: none;">&rarr; project: {{ item.relatedProject }}</a>
                    {% endif %}
                    {% if item.relatedReport %}
                    <span style="color: var(--color-text-muted); font-family: var(--font-mono, monospace);">report{% if item.reportDate %} · {{ item.reportDate }}{% endif %}: {{ item.relatedReport }}</span>
                    {% endif %}
                    {% if item.graduatedTo %}
                    <span style="color: #166534; font-weight: 600;">graduated &rarr; {{ item.graduatedTo }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endif %}{% endfor %}{% endfor %}
    </div>
</section>

{% set pqCount = 0 %}
{% for project in projects %}{% if project.openQuestions %}{% set pqCount = pqCount + 1 %}{% endif %}{% endfor %}
{% if pqCount %}
<section style="margin-top: 3rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
    <h2 class="section-title" style="margin-bottom: 0.5rem;">Live from the standards</h2>
    <p style="margin-bottom: 1.5rem; color: var(--color-text-muted); font-size: 0.9em;">Open questions declared on the standards' own pages, collected here automatically. Edit them on the project, not in the backlog.</p>
    <div class="project-grid">
        {% for project in projects %}{% if project.openQuestions %}
        <div class="project-card">
            <div class="project-header" style="margin-bottom: 0.75rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem;">
                <h3 class="project-title" style="margin: 0;"><a href="/projects/{{ project.id }}/" style="text-decoration: none; color: inherit;">{{ project.name }}</a></h3>
            </div>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
                {% for q in project.openQuestions %}
                <li style="font-size: 0.9em;">
                    <a href="/projects/{{ project.id }}/{% if q.anchor %}#{{ q.anchor }}{% endif %}" style="color: var(--color-text); text-decoration: none;">{{ q.question }}</a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}{% endfor %}
    </div>
</section>
{% endif %}

</div>{# /#panel-tracked #}

<div id="panel-priority" role="tabpanel" aria-labelledby="tab-priority" hidden>
{# Open items ranked by how much work resolving them would free — derived deterministically in the
   loader (#254) by inverting `blockedBy`. `transitiveUnblocks` = every open item this one ultimately
   gates; `unblocksToReady` = open issue/idea dependents this is the LAST open blocker for (resolving it
   flips them to agent-ready). Sorted by `leverageScore` (transitive-dominant); only items that gate
   something appear. #}
{% set leverageItems = backlog | where("status", "open") | sort(attribute="leverageScore", reverse=true) %}
{% set leverageCount = leverageItems | length %}
{# In-flight decisions — a `decision` claimed (status:active) for a live /decision turn. It's no longer
   `open`, so the loader gives it no tier and it would normally drop out of this open-only table. We pin it
   back in (concatenated AHEAD of the open rows) flagged "deciding now", so the call you're currently making
   stays visible in the decision-ready view. Scoped to THIS table only — the loader tier rule and every
   other tab / rollup are untouched. #}
{% set activeDecisions = backlog | where("status", "active") | where("type", "decision") | sort(attribute="leverageScore", reverse=true) %}
{% set countActiveDecisions = activeDecisions | length %}
{% set tableRows = activeDecisions.concat(leverageItems) %}
{% set countBatch = backlog | where("batchable", true) | length %}
{% set countA = backlog.countAgentReady %}
{% set countSlice = backlog.countSliceable %}
{% set countEpicAction = backlog.countEpicActionable %}
{% set countEpicParked = backlog.countEpicParked %}
{% set countEpicUnsliced = backlog.countEpicUnsliced %}
{% set countEpicDone = backlog.countEpicDone %}
{% set countB = backlog | where("tier", "B") | length %}
{% set countPrepared = backlog.countPreparedB %}
{% set countC = backlog | where("tier", "C") | length %}
{% set pointsBatch = backlog.pointsBatch %}
{% set pointsA = backlog.pointsTierA %}
{% set pointsSlice = backlog.pointsSlice %}
{% set pointsB = backlog.pointsTierB %}
{% set pointsC = backlog.pointsTierC %}
<section class="mb-12">
    <h2 class="section-title">Prioritisation <span class="count-badge">{{ leverageCount }}</span></h2>
    <p class="section-desc">Every <strong>open</strong> item (plus any <strong>decision being actively made</strong>, pinned on top), sortable — ranked by default by <strong>how much work resolving it would unblock</strong> (the inverse of the <code>blockedBy</code> edges, computed deterministically from structured fields only, no LLM). <strong>Frees now</strong> counts the items this is the <em>last</em> open prerequisite for — resolving it flips them to agent-ready. <strong>Gates (chain)</strong> counts every open item it ultimately blocks, directly or transitively. The <strong>Readiness</strong> column is the agent-readiness tier; sort by it to surface the batchable work.</p>
    <div style="display:flex; gap:0.6rem; flex-wrap:wrap; align-items:center; margin:0 0 1rem; font-size:0.85em;">
        <button type="button" data-pfilter="batchable" aria-pressed="false" title="Click to filter the table to the batch pool. Batchable (deterministic) — the candidate set a points-budgeted batch may pack: a Tier-A task or a story of size ≤ 8. The budget packs smallest-first, reaching a single size·8 when the remaining points fit. Story ≥13 and any epic are never packed." style="cursor:pointer; appearance:none; border:2px solid transparent; display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.6rem; border-radius:9999px; background:#166534; color:#fff; font:inherit; font-size:1em; font-weight:700;">{{ countBatch }} batchable <span style="font-weight:600; opacity:0.85;">(≤8 pool · {{ pointsBatch }} pts)</span></button>
        <button type="button" data-pfilter="batchable,agentready" aria-pressed="false" title="Click to filter the table to buildable agent-ready work — an issue/idea (task or story) with every prerequisite resolved; startable now. Includes ready-but-large stories (story ≥13) beyond the batch pool. Excludes container epics (see ‘ready to slice’) — their work lives in their child slices, not in the epic itself." style="cursor:pointer; appearance:none; border:2px solid transparent; display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.6rem; border-radius:9999px; background:#dcfce7; color:#166534; font:inherit; font-size:1em; font-weight:700;">{{ countA }} agent-ready <span style="font-weight:600; opacity:0.8;">(Tier A · {{ pointsA }} pts)</span></button>
        {% if countSlice %}<button type="button" data-pfilter="sliceable" aria-pressed="false" title="Click to filter to the unblocked (Tier A) epics. An epic isn't directly buildable — its work lives in child slices. Most here are just tracking open children (no action); only the ones tagged ‘slice’ (unsliced) or ‘resolve’ (all children done) need attention." style="cursor:pointer; appearance:none; border:2px solid transparent; display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.6rem; border-radius:9999px; background:#ecfeff; color:#155e75; font:inherit; font-size:1em; font-weight:700;">{% if countEpicAction %}{{ countEpicAction }} epic{{ "s" if countEpicAction != 1 }} need attention <span style="font-weight:600; opacity:0.8;">(of {{ countSlice }}{% if countEpicUnsliced %} · {{ countEpicUnsliced }} to slice{% endif %}{% if countEpicDone %} · {{ countEpicDone }} to resolve{% endif %})</span>{% else %}{{ countSlice }} epics <span style="font-weight:600; opacity:0.8;">(none need action{% if countEpicParked %} · {{ countEpicParked }} parked{% endif %})</span>{% endif %}</button>{% endif %}
        <button type="button" data-pfilter="decision" aria-pressed="false" title="Click to filter to decision-ready (Tier B) — a decision awaiting a nod; ratify it, then the build it gates becomes agent-ready. A ✓ prepared one has its forks researched + options stated (preparedDate) — ready to ratify, not research." style="cursor:pointer; appearance:none; border:2px solid transparent; display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.6rem; border-radius:9999px; background:#fef3c7; color:#92400e; font:inherit; font-size:1em; font-weight:700;">{{ countB }} decision-ready <span style="font-weight:600; opacity:0.8;">(Tier B · {{ pointsB }} pts{% if countPrepared %} · <span style="color:#15803d;">{{ countPrepared }} ✓ prepared</span>{% endif %}{% if countActiveDecisions %} · <span style="color:#1e40af;">{{ countActiveDecisions }} in flight</span>{% endif %})</span></button>
        <button type="button" data-pfilter="notready" aria-pressed="false" title="Click to filter to not ready (Tier C) — an issue/idea that still has an open prerequisite; clear its blocker first." style="cursor:pointer; appearance:none; border:2px solid transparent; display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.6rem; border-radius:9999px; background:#f1f5f9; color:#475569; font:inherit; font-size:1em; font-weight:700;">{{ countC }} not ready <span style="font-weight:600; opacity:0.8;">(Tier C · {{ pointsC }} pts)</span></button>
    </div>
    {# Active batches (dev-only, advisory) — live soft-reservations from a running /batch, grouped by
       session (see backlog.js → items.activeBatches). Shows a concurrent batcher what's already in flight
       so a second batch packs around it. Ephemeral session state: live on the dev server, frozen at
       build-time on a static build. Hidden entirely when nothing is held. #}
    {% set activeBatches = backlog.activeBatches %}
    {% if activeBatches | length %}
    <div style="display:flex; gap:0.6rem; flex-wrap:wrap; align-items:center; margin:0 0 1rem; font-size:0.85em;">
        <span style="font-weight:700; color:#3730a3;" title="Live soft-reservations from a running /batch session (reservations.json). Advisory and dev-only — these clear when the batch finishes or its 120-min lease expires.">⊘ {{ activeBatches | length }} active batch{{ "es" if activeBatches | length != 1 }}</span>
        {% for b in activeBatches %}
        <span title="Batch {{ b.session }} — holding {{ b.nums | length }} item{{ 's' if b.nums | length != 1 }} ({{ b.points }} pts) since {{ b.date }}. Soft hold: a second concurrent batch deprioritizes these, the real lock is each item's status:open→active flip at claim." style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.2rem 0.6rem; border-radius:9999px; background:#eef2ff; color:#3730a3; border:1px solid #c7d2fe; font-weight:600;">{{ b.date }} · {% for n in b.nums %}#{{ n }}{% if not loop.last %} {% endif %}{% endfor %} <span style="font-weight:500; opacity:0.8;">({{ b.points }} pts)</span></span>
        {% endfor %}
    </div>
    {% endif %}
    <p class="section-desc" style="margin:-0.5rem 0 1rem; font-size:0.82em;"><strong style="color:#166534;">Batchable</strong> = the batch pool — <strong>Tier A</strong> (issue/idea with every prerequisite resolved) <em>and</em> small enough to chain: a <strong>task</strong> or a <strong>story&nbsp;≤&nbsp;8&nbsp;pts</strong>. A points-budgeted batch packs from this set smallest-first, reaching a single <code>size·8</code> when the remaining points fit. A <strong>story&nbsp;≥&nbsp;13</strong> is agent-ready but <em>never</em> batched (real work, too big for one chain). An <strong>epic</strong> is unblocked but not directly buildable — its work lives in child slices, so it's counted separately and never as buildable work. Most epics here just <strong>track</strong> open children (no action — the work is those children); only an <strong style="color:#155e75;">unsliced</strong> epic (tag <code>slice</code>) or one whose children are all done (tag <code>resolve</code>) needs attention. All computed deterministically from the <code>type</code>/<code>blockedBy</code>/<code>size</code> fields — no LLM.</p>
    {# Epic-badge legend — defines every tag an epic row can carry, including the parked reasons. Kept on
       this tab (not just the Tracked-work one) because the readiness column shows these tags here. #}
    <details class="bk-collapse" data-persist="legend-epic-tags" style="margin:-0.5rem 0 1rem;">
        <summary>What the epic tags mean</summary>
        <ul style="margin:0.5rem 0 0; padding-left:1.1rem; font-size:0.82em; color:var(--color-text-muted); line-height:1.6;">
            <li><strong style="color:#155e75;">slice</strong> — unsliced and <em>no reason recorded</em>: cut it into child stories/tasks via <code>/slice</code> (or record why not).</li>
            <li><strong style="color:#166534;">resolve</strong> — every child slice is resolved but the epic is still open: just close it (a status update).</li>
            <li><strong style="color:#475569;">tracking</strong> — open child slices remain: no epic-level action, its work is those children (already in the pool above).</li>
            <li><strong style="color:#5b21b6;">needs triage</strong> — a holding-pen of candidates. <strong>Triage</strong> = go through each candidate and decide its fate — <em>promote</em> it to its own backlog item, <em>fold</em> it into an existing item, or <em>drop</em> it. Only the promoted survivors become child slices; until that pass happens the epic can't be sliced.</li>
            <li><strong style="color:#92400e;">needs decisions</strong> — open design decisions determine where the slices fall; ratify them first.</li>
            <li><strong style="color:#991b1b;">blocked</strong> — waiting on the prerequisites in its Blocked-by row; clear those first.</li>
            <li><strong style="color:#075985;">ongoing program</strong> — no fixed child stories by design; measured by progress, not decomposed.</li>
        </ul>
    </details>
    {% if leverageCount or countActiveDecisions %}
    {# Higher rank = more ready, so first-click (descending, like the other numeric columns) puts
       Agent-ready on top. Value is a hidden sort key only — never shown. #}
    {% set tierRank = { "A": 3, "B": 2, "C": 1 } %}
    <p class="section-desc" style="margin-top:-0.5rem; font-size:0.82em;">Click a column header to sort; click again to reverse. Default order is by leverage (Gates, then Direct).</p>
    {# Client-side filtering for the Prioritisation table (backlog-table-sort.js). Chips toggle; deselecting
       every chip in a group means "no filter" (show all). The count badge reflects the visible rows. #}
    <div class="ptable-filter" style="display:flex; gap:0.6rem 1rem; flex-wrap:wrap; align-items:center; margin-bottom:0.75rem;">
        <input type="search" data-ptable-search placeholder="Filter by # or title…" aria-label="Filter the table by id or title" style="appearance:none; border:1px solid var(--color-border); border-radius:0.4rem; padding:0.3rem 0.6rem; font:inherit; font-size:0.85em; min-width:200px;">
        <div class="status-filter" role="group" aria-label="Filter by readiness">
            <button type="button" class="status-filter-chip" data-pready="batchable" aria-pressed="true" title="The batch pool — Tier-A task or story ≤8; a points-budgeted batch packs from here">Batchable</button>
            <button type="button" class="status-filter-chip" data-pready="agentready" aria-pressed="true" title="Buildable agent-ready beyond the batch pool — a story ≥13 (too big to chain). Excludes epics.">Agent-ready</button>
            <button type="button" class="status-filter-chip" data-pready="sliceable" aria-pressed="true" title="Epics — unblocked, not directly buildable. Tagged slice (unsliced), resolve (children all done), or tracking (open children, no action).">Epics</button>
            <button type="button" class="status-filter-chip" data-pready="decision" aria-pressed="true" title="Tier B — a decision to ratify">Decision-ready</button>
            <button type="button" class="status-filter-chip" data-pready="notready" aria-pressed="true" title="Tier C — has an open prerequisite">Not ready</button>
        </div>
        <div class="status-filter" role="group" aria-label="Filter by type">
            {% for t in ["idea", "issue", "decision"] %}{% if backlog | where("status","open") | where("type", t) | length %}
            <button type="button" class="status-filter-chip" data-ptype="{{ t }}" aria-pressed="true">{{ t | title }}</button>
            {% endif %}{% endfor %}
        </div>
        <span style="font-size:0.82em; color:var(--color-text-muted);"><strong data-ptable-count>{{ leverageCount + countActiveDecisions }}</strong> shown</span>
    </div>
    <div style="overflow-x: auto;">
    <table class="bd-ratetable sortable" style="min-width: 860px;">
        <thead><tr>
            <th data-sort-key="item" data-sort-type="num" style="text-align:left;">Item <span class="sort-ind"></span></th>
            <th data-sort-key="type" data-sort-type="text" title="idea / issue / decision">Type <span class="sort-ind"></span></th>
            <th data-sort-key="size" data-sort-type="num" title="Agile points — a story carries Fibonacci size (1/2/3/5/8/13); a task is unsized; an epic rolls up its children. Batchable = task or story ≤8.">Size <span class="sort-ind"></span></th>
            <th data-sort-key="readiness" data-sort-type="num" title="Agent-readiness tier — sorts Batchable (task or story ≤8) first, then Agent-ready (A), Decision-ready (B), Not-ready (C)">Readiness <span class="sort-ind"></span></th>
            <th data-sort-key="frees" data-sort-type="num" title="Open items this is the last open prerequisite for — resolving it flips them to agent-ready">Frees now <span class="sort-ind"></span></th>
            <th data-sort-key="gates" data-sort-type="num" title="Every open item this one ultimately blocks, directly or transitively">Gates (chain) <span class="sort-ind"></span></th>
            <th data-sort-key="direct" data-sort-type="num" title="Open items directly blocked by this one">Direct <span class="sort-ind"></span></th>
            <th style="text-align:left;">Would free</th>
        </tr></thead>
        <tbody>
        {% for item in tableRows %}
            {% set isActiveDecision = item.status == 'active' and item.type == 'decision' %}
            <tr data-type="{{ item.type }}" data-readiness="{% if isActiveDecision %}decision{% elif item.batchable %}batchable{% elif item.sliceable %}sliceable{% elif item.tier == 'A' %}agentready{% elif item.tier == 'B' %}decision{% else %}notready{% endif %}"{% if isActiveDecision %} data-pinned="true"{% endif %} data-search="{{ item.num }} {{ item.title | lower }}">
                <td style="text-align:left;" data-sort-val="{{ item.num }}">
                    <a href="/backlog/{{ item.id }}/" style="color: var(--color-primary); text-decoration: none; font-weight: 600;"><span style="color: var(--color-text-muted, #94a3b8); font-variant-numeric: tabular-nums;">#{{ item.num }}</span> {{ item.title }}</a>{% if item.reservedBy %} <span title="Held by a running batch ({{ item.reservedBy }}). Soft reservation — a concurrent batch deprioritizes it; the real lock is the status:open→active flip at claim." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#eef2ff; color:#3730a3; border:1px solid #c7d2fe; white-space:nowrap;">⊘ in batch</span>{% endif %}
                </td>
                <td data-sort-val="{{ item.type }}">{{ typeBadge(item.type) }}</td>
                <td data-sort-val="{{ item.size if item.size else 0 }}">{% if item.size %}{{ sizeBadge(item.size) }}{% else %}<span title="{{ item.workItem }} — unsized ({% if item.workItem == 'epic' %}rolls up its child stories{% else %}points roll up to a parent{% endif %})" style="font-size:0.78em; color:var(--color-text-muted, #94a3b8);">{{ item.workItem }}</span>{% endif %}</td>
                <td data-sort-val="{{ 2.9 if isActiveDecision else (4 if item.batchable else (2.8 if (item.sliceable and (item.epicState == 'unsliced' or item.epicState == 'done')) else (2.6 if item.sliceable else (2.5 if (item.tier == 'B' and item.preparedDate) else (tierRank[item.tier] if item.tier else 0))))) }}">{% if isActiveDecision %}{{ tierBadge('B') }} <span title="In flight — this decision is claimed (status:active) and being made in a live /decision turn. Pinned to the top of the decision-ready view so the call in progress stays visible." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#1e40af; color:#fff; white-space:nowrap;">deciding now</span>{% else %}{{ tierBadge(item.tier) }}{% if item.batchable %} <span title="Batchable — a Tier-A task or story ≤8; a points-budgeted batch packs from this pool when the remaining budget fits." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#166534; color:#fff; white-space:nowrap;">batch</span>{% elif item.sliceable %}{% if item.epicState == 'unsliced' %} <span title="Unsliced epic — no child slices cut yet, and no reason recorded. /slice it into child stories/tasks, or record a childlessReason saying why not." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#155e75; color:#fff; white-space:nowrap;">slice</span>{% elif item.epicState == 'done' %} <span title="Every child slice is resolved but the epic is still open — its scope looks delivered. Resolve it (a status update), or add the remaining child work." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#15803d; color:#fff; white-space:nowrap;">resolve</span>{% elif item.epicState == 'parked' %}{% set rm = childlessReasonMeta[item.childlessReason] %} <span title="Parked — decomposition is gated, so this is NOT a slice to-do. {{ rm.tip if rm else 'A childlessReason is recorded; clear it before slicing.' }}" style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:{{ rm.bg if rm else '#ede9fe' }}; color:{{ rm.fg if rm else '#5b21b6' }}; white-space:nowrap;">{{ rm.label if rm else 'parked' }}</span>{% else %} <span title="Tracking — open child slices remain. No epic-level action: its work is those children, which are already in the agent-ready/batch pool. The epic resolves once they finish." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#e2e8f0; color:#475569; white-space:nowrap;">tracking</span>{% endif %}{% endif %}{% if item.tier == 'B' and item.preparedDate %} <span title="Prepared — its forks are researched (research published as a /research/ topic), each with options + a bold default, and preparedDate is set. Ready to ratify, not research; sorts above un-prepared decisions." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#15803d; color:#fff; white-space:nowrap;">✓ ready</span>{% endif %}{% endif %}</td>
                <td style="font-weight: 700;{% if item.unblocksToReady %} color: #166534;{% endif %}" data-sort-val="{{ item.unblocksToReady }}">{{ item.unblocksToReady }}</td>
                <td data-sort-val="{{ item.transitiveUnblocks }}">{{ item.transitiveUnblocks }}</td>
                <td data-sort-val="{{ item.directUnblocks }}">{{ item.directUnblocks }}</td>
                <td style="text-align:left; font-size: 0.92em;">
                    {% for dep in item.dependents | where("status", "open") %}<a href="/backlog/{{ dep.id }}/" title="{{ dep.title }}" style="color: var(--color-text-muted); text-decoration: none; font-variant-numeric: tabular-nums;">#{{ dep.num }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
    <p class="section-desc" style="margin-top: 1rem;">All open items are listed; those that gate no open work simply show <strong>0</strong> in the leverage columns (sort by <strong>Gates</strong> to push them down, or by <strong>Readiness</strong> to surface the batchable ones). An <span style="color:#166534; font-weight:600;">Agent-ready</span> item with high leverage is the highest-value thing to start now; a <span style="color:#92400e; font-weight:600;">Decision-ready</span> or <span style="color:#64748b; font-weight:600;">Not ready</span> one with high leverage is the highest-leverage <em>blocker</em> to clear first.</p>
    {% else %}
    <p>No open items.</p>
    {% endif %}
</section>
</div>{# /#panel-priority #}

<div id="panel-graph" role="tabpanel" aria-labelledby="tab-graph" hidden>
{# Dependency relationship graph — the `blockedBy` network as a diagram (#255). Nodes/edges/layers are
   computed deterministically in src/_data/backlogGraph.js (reusing the #254 leverage fields); the SVG is
   laid out + drawn by src/assets/js/backlog-graph.js. Only items that participate in an edge appear. #}
<section class="mb-12">
    <h2 class="section-title">Dependency graph <span class="count-badge" id="bg-count">{{ backlogGraph.nodes | length }} items</span></h2>
    <p class="section-desc">The <code>blockedBy</code> network as a diagram — an arrow points <strong>prerequisite&nbsp;&rarr;&nbsp;dependent</strong>, so work flows left to right and the leftmost nodes are the roots that gate everything downstream. Nodes are coloured by agent-readiness (<span style="color:#166534;font-weight:600;">ready</span> / <span style="color:#92400e;font-weight:600;">decision</span> / <span style="color:#475569;font-weight:600;">blocked</span>; <span style="color:#94a3b8;font-weight:600;">muted</span> = already resolved/claimed) and sized by how much they unblock. Click any node to open its item. <strong>Open &amp; blockers</strong> shows <em>every</em> open item — those with prerequisites laid out in chains, the rest (no live dependency) as a standalone grid below the divider; <strong>All</strong> shows the full dependency network, resolved history included (so it can show fewer nodes than Open&nbsp;&amp;&nbsp;blockers, which also counts the standalone open items).</p>
    {% if backlogGraph.empty %}
    <p>No <code>blockedBy</code> edges yet — nothing to graph. As items declare prerequisites, the dependency network appears here.</p>
    {% else %}
    <div class="bg-legend" style="display:flex; gap:1.2rem; flex-wrap:wrap; align-items:center; margin-bottom:0.5rem; font-size:0.85em; color:var(--color-text-muted);">
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Tier A — an issue/idea whose every prerequisite is already resolved. An agent can start it now (but a large one — story ≥13 / epic — is beyond the batch pool)."><span style="width:14px;height:14px;border-radius:50%;background:#dcfce7;border:2px solid #16a34a;"></span><strong style="color:#166534;">Agent-ready</strong> — startable now</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Batchable — a Tier-A task or story ≤8; a points-budgeted batch packs from this pool. Shown with a detached green ring. A subset of agent-ready."><span style="position:relative; width:16px; height:16px; display:inline-flex; align-items:center; justify-content:center;"><span style="position:absolute; width:16px;height:16px;border-radius:50%;border:1.5px solid #16a34a;"></span><span style="width:9px;height:9px;border-radius:50%;background:#dcfce7;border:2px solid #16a34a;"></span></span><strong style="color:#166534;">Batchable</strong> — ready &amp; small (ring)</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Tier B — a decision. Ratify the call first, then the build it gates becomes agent-ready."><span style="width:14px;height:14px;border-radius:50%;background:#fef3c7;border:2px solid #d97706;"></span><strong style="color:#92400e;">Decision-ready</strong> — ratify, then build</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Tier C — an issue/idea that still has an open prerequisite. Clear its blocker(s) first."><span style="width:14px;height:14px;border-radius:50%;background:#f1f5f9;border:2px solid #94a3b8;"></span><strong style="color:#475569;">Not ready</strong> — has an open blocker</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Claimed — an agent is actively working it (status: active)."><span style="width:14px;height:14px;border-radius:50%;background:#dbeafe;border:2px solid #2563eb;"></span><strong style="color:#1e40af;">In progress</strong> — claimed</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Done — kept in the graph (in All view) for dependency history."><span style="width:14px;height:14px;border-radius:50%;background:#f8fafc;border:2px solid #cbd5e1;"></span>Resolved</span>
        <span title="Node radius grows with the number of open items this one ultimately unblocks.">larger node = unblocks more</span>
    </div>
    <p class="section-desc" style="margin-top:0; margin-bottom:1rem; font-size:0.82em;">Colour = <strong>agent-readiness</strong>, the same deterministic tier as the Prioritisation tab: whether an agent could pick the item up right now. <em>Agent-ready</em> nodes with no incoming edge are the live frontier; a <em>Not-ready</em> node points back (left) to the open blocker it's waiting on.</p>
    {# Filter toggle (#257): "Open & blockers" trims fully-resolved chains to the live frontier — open/active
       nodes plus the still-open prerequisites gating them. Filter + re-layout happen client-side in
       src/assets/js/backlog-graph.js (no second graph model); the choice persists in localStorage. #}
    <div class="bg-filter" role="group" aria-label="Graph filter">
        <button type="button" data-bg-filter="live" class="is-active">Open &amp; blockers</button>
        <button type="button" data-bg-filter="all">All</button>
    </div>
    <div style="overflow-x:auto; border:1px solid var(--color-border); border-radius:8px; background:var(--color-surface, #fff);">
        <svg id="backlog-graph" role="img" aria-label="Dependency graph of backlog items linked by blockedBy edges, prerequisite to dependent" style="display:block;"></svg>
    </div>
    <script type="application/json" id="backlog-graph-data">{{ backlogGraph | dump | safe }}</script>
    {% endif %}
</section>
</div>{# /#panel-graph #}

<div id="panel-burndown" role="tabpanel" aria-labelledby="tab-burndown" hidden>
    <section class="mb-12">
        <h2 class="section-title">Burndown <span class="count-badge">{{ burndown.points.remaining }} pts left</span></h2>
        <p class="section-desc">Continuous-flow burndown in <strong>agile points</strong>, not item counts — scope grows as items are opened and falls as they're resolved. Points are summed once per item: a <code>story</code> carries its <code>size</code>, a <code>task</code> never does, a storied <code>epic</code> defers to its child stories, an unstoried <code>epic</code> carries its own — so nothing is double-counted. Resolution dates drive the completed line.</p>

        {% if burndown.empty %}
        <p>No sized items yet.</p>
        {% else %}
        <div class="bd-cards">
            <div class="bd-card"><div class="n">{{ burndown.points.total }}</div><div class="l">Total points</div></div>
            <div class="bd-card"><div class="n">{{ burndown.points.done }}</div><div class="l">Completed</div></div>
            <div class="bd-card"><div class="n">{{ burndown.points.remaining }}</div><div class="l">Remaining</div></div>
            <div class="bd-card"><div class="n">{{ burndown.counts.story }}</div><div class="l">Stories</div></div>
            <div class="bd-card"><div class="n">{{ burndown.counts.epic }}</div><div class="l">Epics</div></div>
            <div class="bd-card"><div class="n">{{ burndown.counts.task }}</div><div class="l">Tasks</div></div>
        </div>

        {% if burndown.diverging %}
        <div class="bd-callout diverging">
            <strong>Diverging</strong> — over the last {{ burndown.rates.windowDays }} days scope is opening at
            <strong>{{ burndown.rates.intake.week | round(1) }} pts/wk</strong> but completing at only
            <strong>{{ burndown.rates.completion.week | round(1) }} pts/wk</strong> (net
            {{ burndown.rates.net.week | round(1) }} pts/wk), so there is no projected clear date at the current pace.
            If intake froze today, the {{ burndown.points.remaining }} remaining points would clear around
            <strong>{{ burndown.clearDateFrozen }}</strong>.
        </div>
        {% else %}
        <div class="bd-callout converging">
            <strong>Converging</strong> — completing
            <strong>{{ burndown.rates.completion.week | round(1) }} pts/wk</strong> against intake of
            {{ burndown.rates.intake.week | round(1) }} pts/wk (net +{{ burndown.rates.net.week | round(1) }} pts/wk).
            Projected to clear around <strong>{{ burndown.clearDateNet }}</strong> if both rates hold
            ({{ burndown.clearDateFrozen }} if intake froze today).
        </div>
        {% endif %}

        <table class="bd-ratetable">
            <thead><tr><th>Burn rate (trailing {{ burndown.rates.windowDays }}d)</th><th>/ day</th><th>/ week</th><th>/ month</th></tr></thead>
            <tbody>
                <tr><td>Completion</td><td>{{ burndown.rates.completion.day | round(1) }}</td><td>{{ burndown.rates.completion.week | round(1) }}</td><td>{{ burndown.rates.completion.month | round(1) }}</td></tr>
                <tr><td>Intake</td><td>{{ burndown.rates.intake.day | round(1) }}</td><td>{{ burndown.rates.intake.week | round(1) }}</td><td>{{ burndown.rates.intake.month | round(1) }}</td></tr>
                <tr><td>Net</td><td>{{ burndown.rates.net.day | round(1) }}</td><td>{{ burndown.rates.net.week | round(1) }}</td><td>{{ burndown.rates.net.month | round(1) }}</td></tr>
            </tbody>
        </table>

        <div class="bd-gran" role="group" aria-label="Chart granularity">
            <button type="button" data-bd-gran="daily">Daily</button>
            <button type="button" data-bd-gran="weekly" class="is-active">Weekly</button>
            <button type="button" data-bd-gran="monthly">Monthly</button>
        </div>
        <div class="bd-chart-wrap">
            <svg id="bd-chart" viewBox="0 0 900 360" role="img" aria-label="Backlog burndown chart of remaining, scope and completed agile points over time, with future projection"></svg>
            <div class="bd-legend">
                <span><i style="border-color:#0ea5e9"></i>Scope (opened)</span>
                <span><i style="border-color:#16a34a"></i>Completed</span>
                <span><i style="border-color:#7c3aed"></i>Remaining</span>
                <span><i style="border-color:#7c3aed; border-top-style:dashed"></i>Projection (intake frozen)</span>
                {% if not burndown.diverging %}<span><i style="border-color:#94a3b8; border-top-style:dotted"></i>Projection (intake continues)</span>{% endif %}
            </div>
        </div>
        <script type="application/json" id="burndown-data">{{ burndown | dump | safe }}</script>
        {% endif %}
    </section>
</div>{# /#panel-burndown #}

<script>
// Persist the open/closed state of the collapsible blurb + legends (open by default).
(function () {
    document.querySelectorAll('details.bk-collapse[data-persist]').forEach(function (d) {
        var key = 'backlog:collapse:' + d.dataset.persist;
        var saved = localStorage.getItem(key);
        if (saved === 'closed') d.open = false;
        else if (saved === 'open') d.open = true;
        d.addEventListener('toggle', function () {
            localStorage.setItem(key, d.open ? 'open' : 'closed');
        });
    });
})();
</script>
<script src="/assets/js/home-display.js"></script>
<script src="/assets/js/backlog-burndown.js"></script>
<script src="/assets/js/backlog-graph.js"></script>
<script src="/assets/js/backlog-table-sort.js"></script>
