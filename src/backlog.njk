---
layout: base.njk
title: Backlog
---

{# PARITY RULE: this is the tile index. Anything you expose on a tile here MUST also be exposed on the
   /backlog/{id}/ detail page (src/backlog-pages.njk) — the detail page is a superset of the tile.
   Add tile fields to both in the same change. See docs/agent/backlog-workflow.md ("Tile ⊆ detail"). #}

{% from "display-toolbar.njk" import displayToolbar %}

<style>
.backlog-tabs { display: flex; gap: 0.25rem; border-bottom: 1px solid var(--color-border); margin: 0 0 1.5rem; }
.backlog-tab { appearance: none; background: none; border: none; border-bottom: 2px solid transparent; padding: 0.6rem 1rem; font: inherit; font-weight: 600; color: var(--color-text-muted, #475569); text-decoration: none; cursor: pointer; margin-bottom: -1px; }
.backlog-tab:hover { color: var(--color-text); }
.backlog-tab.is-active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
.bd-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
.bd-card { border: 1px solid var(--color-border); border-radius: 0.6rem; padding: 0.85rem 1rem; background: var(--color-surface-alt, #f8fafc); }
.bd-card .n { font-size: 1.6em; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1.1; }
.bd-card .l { font-size: 0.78em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; }
.bd-callout { border-left: 4px solid; padding: 0.75rem 1rem; border-radius: 0 0.5rem 0.5rem 0; margin-bottom: 1.5rem; font-size: 0.92em; }
.bd-callout.diverging { border-color: #dc2626; background: #fef2f2; color: #991b1b; }
.bd-callout.converging { border-color: #16a34a; background: #f0fdf4; color: #166534; }
.bd-ratetable { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.88em; background: #fff; }
.bd-ratetable th, .bd-ratetable td { text-align: right; padding: 0.4rem 0.75rem; border-bottom: 1px solid var(--color-border); font-variant-numeric: tabular-nums; }
.bd-ratetable th:first-child, .bd-ratetable td:first-child { text-align: left; }
.bd-ratetable thead th { color: var(--color-text-muted); font-weight: 600; }
.bd-gran, .bg-filter { display: inline-flex; gap: 0.25rem; margin-bottom: 0.75rem; }
.bd-gran button, .bg-filter button { appearance: none; border: 1px solid var(--color-border); background: var(--color-surface, #fff); padding: 0.3rem 0.75rem; font: inherit; font-size: 0.85em; cursor: pointer; }
.bd-gran button:first-child, .bg-filter button:first-child { border-radius: 0.4rem 0 0 0.4rem; }
.bd-gran button:last-child, .bg-filter button:last-child { border-radius: 0 0.4rem 0.4rem 0; }
.bd-gran button.is-active, .bg-filter button.is-active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
.bd-chart-wrap { border: 1px solid var(--color-border); border-radius: 0.6rem; padding: 1rem; }
.bd-legend { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; font-size: 0.82em; color: var(--color-text-muted); }
.bd-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
.bd-legend i { width: 18px; height: 0; border-top-width: 3px; border-top-style: solid; display: inline-block; }
/* Collapsible top blurb + legends — open by default, state persisted to localStorage (data-persist key). */
.bk-collapse { margin-bottom: 1.5rem; }
.bk-collapse > summary { cursor: pointer; font-weight: 600; color: var(--color-text-muted, #475569); font-size: 0.82em; text-transform: uppercase; letter-spacing: 0.03em; list-style: none; display: inline-flex; align-items: center; gap: 0.4rem; user-select: none; padding: 0.15rem 0; width: fit-content; }
.bk-collapse > summary::-webkit-details-marker { display: none; }
.bk-collapse > summary::before { content: "\25B8"; font-size: 0.9em; transition: transform 0.15s ease; }
.bk-collapse[open] > summary::before { transform: rotate(90deg); }
.bk-collapse > summary:hover { color: var(--color-text); }
.bk-collapse[data-persist="intro"] { margin-bottom: 0; }
.bk-collapse[data-persist="intro"] > summary { margin-top: 0.25rem; }
/* Active-work LIVE board (#1854) — pulsing "live" dot + per-agent state chips. */
@keyframes active-pulse { 0% { box-shadow: 0 0 0 0 rgba(22,163,74,0.55); } 70% { box-shadow: 0 0 0 7px rgba(22,163,74,0); } 100% { box-shadow: 0 0 0 0 rgba(22,163,74,0); } }
.aw-agent { display:inline-flex; align-items:center; gap:0.35rem; padding:0.15rem 0.5rem; border-radius:9999px; font-size:0.78em; font-weight:600; border:1px solid; white-space:nowrap; }
.aw-agent.done { background:#dcfce7; color:#166534; border-color:#86efac; }
.aw-agent.running { background:#dbeafe; color:#1e40af; border-color:#93c5fd; }
.aw-agent.pending { background:#f1f5f9; color:#475569; border-color:#cbd5e1; }
.aw-agent.failed { background:#fef2f2; color:#991b1b; border-color:#fca5a5; }
.aw-agent .dot { width:7px; height:7px; border-radius:50%; background:currentColor; }
.aw-agent.running .dot { animation:active-pulse 1.4s infinite; }
/* Command-center lanes (#1854 v2) — operation-type lanes, vitals bar, per-item live digest. */
.aw-surface { background:var(--color-surface, #fff); border:1px solid var(--color-border); border-radius:0.75rem; padding:1.25rem 1.5rem; }
.aw-vitals { display:flex; flex-wrap:wrap; gap:0.5rem; margin:0 0 1.5rem; }
.aw-vital { display:inline-flex; align-items:center; gap:0.4rem; padding:0.3rem 0.7rem; border-radius:9999px; font-size:0.85em; font-weight:700; border:1px solid; white-space:nowrap; }
.aw-vital .n { font-variant-numeric:tabular-nums; }
.aw-lane { margin:0 0 1.5rem; }
.aw-lane-head { display:flex; align-items:center; gap:0.5rem; font-size:0.78em; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; margin:0 0 0.6rem; }
.aw-lane-dot { width:10px; height:10px; border-radius:50%; flex:none; }
.aw-rows { display:flex; flex-direction:column; gap:0.4rem; }
.aw-row { border:1px solid var(--color-border); border-radius:0.5rem; padding:0.5rem 0.7rem; background:var(--color-surface-alt, #f8fafc); }
.aw-row-head { display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; }
.aw-digest { margin-top:0.4rem; font-size:0.78em; color:var(--color-text-muted); display:flex; flex-direction:column; gap:0.15rem; }
.aw-digest .now { color:#1e40af; font-weight:600; }
.aw-digest .meta { font-variant-numeric:tabular-nums; opacity:0.85; }
.aw-batch { border:1px solid #c7d2fe; border-radius:0.6rem; padding:0.7rem 0.85rem; background:#eef2ff; margin-bottom:0.6rem; }
.aw-stream-toggle { appearance:none; background:none; border:none; padding:0; margin:0.1rem 0 0; font:inherit; font-size:0.76em; font-weight:600; color:var(--color-primary); cursor:pointer; }
.aw-stream { margin-top:0.35rem; border-left:2px solid var(--color-border); padding-left:0.6rem; display:flex; flex-direction:column; gap:0.2rem; }
.aw-step { font-size:0.76em; line-height:1.35; display:flex; gap:0.4rem; }
.aw-step .at { color:var(--color-text-muted); font-variant-numeric:tabular-nums; flex:none; opacity:0.8; }
.aw-step.tool .tx { color:#1e40af; font-family:var(--font-mono, monospace); }
.aw-step.text .tx { color:var(--color-text-muted); }
</style>

{% import "backlog-badges.njk" as bk with context %}
{# Badge/chip/circle macros + the childlessReasonMeta/tierLabel/tierMeaning vocabulary now live in
   src/_includes/backlog-badges.njk + src/_data/backlogMeta.js — ONE source shared with the detail
   page (backlog-pages.njk) so the two surfaces cannot drift. check:standards forbids re-defining
   these locally. #}

<section class="intro">
    <h1>Backlog</h1>
    <details class="bk-collapse" data-persist="intro" open>
        <summary>About the backlog</summary>
        <p>The single source of truth for ideas, issues, and decisions across Web Everything. Each item is one markdown file in <code>backlog/</code>, completely dynamic — its title, summary, and detail come from markdown (the item's own body, or a related report it mirrors), never hand-typed. Open questions raised on the standards' own pages are collected live below. Deep thinking stays in <code>reports/</code> — a backlog item links out to it or mirrors it.</p>
    </details>
</section>

<div class="backlog-tabs" role="tablist" aria-label="Backlog views">
    {# Tabs are real anchors to the view's hash URL so ⌘/Ctrl/middle-click opens it in a new browser
       tab (a <button> has no URL to open). JS intercepts plain left-click for in-page switching. #}
    <a href="#tracked" class="backlog-tab is-active" role="tab" aria-selected="true" aria-controls="panel-tracked" id="tab-tracked" data-bd-tab="tracked">Tracked work</a>
    <a href="#active" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-active" id="tab-active" data-bd-tab="active">Active work{% if backlog.activeWork.count %} <span class="count-badge">{{ backlog.activeWork.count }}</span>{% endif %}<span id="active-tab-live" hidden style="margin-left:0.4rem; display:inline-flex; align-items:center; gap:0.3rem; color:#16a34a; font-weight:700; font-size:0.8em;"><span style="width:8px; height:8px; border-radius:50%; background:#16a34a; animation:active-pulse 1.4s infinite;"></span><span id="active-tab-live-n"></span> live</span></a>
    <a href="#priority" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-priority" id="tab-priority" data-bd-tab="priority">Prioritisation</a>
    <a href="#humansetup" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-humansetup" id="tab-humansetup" data-bd-tab="humansetup">Human setup</a>
    <a href="#graph" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-graph" id="tab-graph" data-bd-tab="graph">Graph</a>
    <a href="#burndown" class="backlog-tab" role="tab" aria-selected="false" aria-controls="panel-burndown" id="tab-burndown" data-bd-tab="burndown">Burndown</a>
</div>

<div id="panel-tracked" role="tabpanel" aria-labelledby="tab-tracked">
{% set statusOrder = ["open", "active", "preparing", "parked", "resolved"] %}
{# Item kinds present in the backlog, in preferred order — the one merged nature+hierarchy axis (#466/#487). #}
{% set kindOrder = ["story", "epic", "task", "decision"] %}
{% set kindChips = [] %}
{% for k in kindOrder %}{% if (backlog | where("kind", k) | length) %}{% set kindChips = (kindChips.push(k), kindChips) %}{% endif %}{% endfor %}
{# Agile-point estimates, in Fibonacci order; only sizes actually present become chips. #}
{% set sizeOrder = [1, 2, 3, 5, 8, 13] %}
{% set sizeChips = [] %}
{% for s in sizeOrder %}{% if (backlog | where("size", s) | length) %}{% set sizeChips = (sizeChips.push(s), sizeChips) %}{% endif %}{% endfor %}
{# Agent-readiness tiers actually present (only open items carry one); chip lets you filter to Tier A. #}
{% set tierOrder = ["A", "B", "C"] %}
{% set tierChips = [] %}
{% for t in tierOrder %}{% if (backlog | where("tier", t) | length) %}{% set tierChips = (tierChips.push(t), tierChips) %}{% endif %}{% endfor %}
<section class="mb-12">
    <h2 class="section-title">Tracked work <span class="count-badge" data-count-target>{{ backlog | length }}</span></h2>
    <p class="section-desc">Stories, epics, tasks, and decisions — ordered by status. Filter by status, kind, or keyword, or switch to a compact list. Resolved items are hidden by default.</p>
    <div class="backlog-filter-row">
        <div class="filter-groups">
            <div class="status-filter" role="group" aria-label="Filter by status">
                {# #2280: seed the SSR baseline to the chip's REAL default state — every status is on
                   EXCEPT resolved (home-display.js's defaultExclude). Emit both the `selected` attribute
                   (FUI's initial-pressed contract on upgrade) and the `fui-filter-chip--selected` class
                   (the class the CSS tint now keys on) so the pre-JS render already distinguishes the
                   unpressed Resolved chip — no flash, no stale-attribute over-selection. #}
                {% for s in statusOrder %}
                <we-filter-chip data-status-chip="{{ s }}"{% if s != 'resolved' %} selected class="fui-filter-chip--selected"{% endif %}>{{ s | title }}</we-filter-chip>
                {% endfor %}
            </div>
            <div class="status-filter" role="group" aria-label="Filter by kind">
                {% for k in kindChips %}
                <we-filter-chip data-kind-chip="{{ k }}" selected class="fui-filter-chip--selected" title="{% if k == 'epic' %}umbrella — rolls up child stories/tasks{% elif k == 'task' %}bounded sub-work under a parent{% elif k == 'decision' %}a design fork to ratify (Tier B){% else %}an independently valuable, sized deliverable{% endif %}">{{ k | title }}</we-filter-chip>
                {% endfor %}
            </div>
            {% if sizeChips | length %}
            <div class="status-filter" role="group" aria-label="Filter by size">
                {% for s in sizeChips %}
                <we-filter-chip data-size-chip="{{ s }}" selected class="fui-filter-chip--selected">{{ s }} pt{% if s != 1 %}s{% endif %}</we-filter-chip>
                {% endfor %}
            </div>
            {% endif %}
            {% if tierChips | length %}
            <div class="status-filter" role="group" aria-label="Filter by agent-readiness">
                {% for t in tierChips %}
                <we-filter-chip data-tier-chip="{{ t }}" selected class="fui-filter-chip--selected" title="{{ backlogMeta.tierMeaning[t] }}">{{ backlogMeta.tierLabel[t] }}</we-filter-chip>
                {% endfor %}
            </div>
            {% endif %}
        </div>
        {{ displayToolbar("backlog") }}
    </div>
    {# Legend for the "Contains" circles on epic tiles — each child is a numbered circle coloured by the
       SAME agent-readiness palette as the dependency-graph nodes. Only shown if some epic has children. #}
    {% set hasEpicChildren = false %}
    {% for item in backlog %}{% if item.children | length %}{% set hasEpicChildren = true %}{% endif %}{% endfor %}
    {% if hasEpicChildren %}
    <details class="bk-collapse" data-persist="legend-epic-children" open>
    <summary>Readiness legend</summary>
    <div class="epic-children-legend" style="display:flex; flex-wrap:wrap; align-items:center; gap:0.4rem 1rem; margin:0.5rem 0 1rem; font-size:0.8em; color:var(--color-text-muted);">
        <span style="flex-basis:100%; font-weight:600;">Epic tiles list the items they <strong style="text-transform:uppercase; letter-spacing:0.03em; font-weight:700;">contain</strong> as numbered circles, coloured by readiness:</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#dcfce7; border:1.5px solid #16a34a;"></span><strong style="color:#166534;">Agent-ready</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#fef3c7; border:1.5px solid #d97706;"></span><strong style="color:#92400e;">Decision-ready</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#f1f5f9; border:1.5px solid #94a3b8;"></span><strong style="color:#475569;">Not ready</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#dbeafe; border:1.5px solid #2563eb;"></span><strong style="color:#1e40af;">In progress</strong></span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#f8fafc; border:1.5px solid #cbd5e1;"></span>Resolved</span>
    </div>
    </details>
    {% endif %}
    {# Legend for the `unsliced · <why>` badge — why a childless epic has no child stories yet. Only shown
       if some childless epic carries a recorded reason. Colours match childlessReasonMeta / the badges. #}
    {% set hasUnslicedReason = false %}
    {% for item in backlog %}{% if item.kind == 'epic' and not (item.children | length) and item.childlessReason %}{% set hasUnslicedReason = true %}{% endif %}{% endfor %}
    {% if hasUnslicedReason %}
    <details class="bk-collapse" data-persist="legend-unsliced" open>
    <summary>Epic status legend</summary>
    <div class="unsliced-legend" style="display:flex; flex-wrap:wrap; align-items:center; gap:0.4rem 1rem; margin:0.5rem 0 1rem; font-size:0.8em; color:var(--color-text-muted);">
        <span style="flex-basis:100%; font-weight:600;">An <strong style="text-transform:uppercase; letter-spacing:0.03em; font-weight:700;">unsliced</strong> epic has no child stories cut yet; the tag says <em>why</em>:</span>
        {% for key, m in backlogMeta.childlessReasonMeta %}
        <span style="display:inline-flex; align-items:center; gap:0.4rem;" title="{{ m.tip }}"><span style="padding:0.05rem 0.45rem; border-radius:9999px; font-size:0.92em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:{{ m.bg }}; color:{{ m.fg }};">{{ m.label }}</span><span>{% if key == 'blocked' %}waiting on prerequisites (see Blocked-by){% elif key == 'undecided' %}open decisions set where the slices fall{% elif key == 'untriaged' %}candidates to promote / fold / drop first{% else %}continuous program — no fixed child stories{% endif %}</span></span>
        {% endfor %}
        <span style="flex-basis:100%; font-weight:600; margin-top:0.2rem;">A <em>storied</em> epic (one with child slices) may also flag its completion state:</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;" title="Every child slice is resolved but the epic is still open — its scope looks delivered. Review the epic: resolve it, or add the remaining child work."><span style="padding:0.05rem 0.45rem; border-radius:9999px; font-size:0.92em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#dcfce7; color:#166534;">all slices done</span><span>every child resolved — review &amp; resolve the epic (or add stories)</span></span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;" title="The epic is resolved but some child slice is still open — a contradiction. Reopen the epic, re-parent, or resolve the children."><span style="padding:0.05rem 0.45rem; border-radius:9999px; font-size:0.92em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#fef2f2; color:#991b1b;">&#9888; open slice</span><span>epic resolved but a child is still open — contradiction to fix</span></span>
    </div>
    </details>
    {% endif %}
    {# #2018 (keystone #2016): the tracked-work tiles are SSR'd from our `we-card` at BUILD TIME. Each
       item's inner body (the badge/tag row, blockers, summary, epic-children circles, and meta links) is
       still composed HERE by the SHARED `backlog-badges.njk` macros — the anti-drift single source of
       truth — captured per-item into `backlogTiles`, then `weBacklogGrid` shells out to the pinned FUI
       build-CLI in ONE subprocess batch (render-from-data per #2007) and wraps each captured body in a real
       `<article class="fui-card">` (the `#num Title` becomes the card title). Correct with JS off,
       view-source-visible; the transient `<we-card>` client upgrade (base.njk) is a pure enhancement, and
       the badge/tag children stay transient-CE as before. The outer `.project-card` chrome (grid layout +
       the `data-status/kind/size/tier` filter facets `home-display.js` reads + the `.project-card-link`
       overlay) is emitted by the filter around the SSR card. #}
    {% set backlogTiles = [] %}
    {% for group in statusOrder %}{% for item in backlog %}{% if item.status == group %}
    {% set inner %}<div class="backlog-badges" style="margin-bottom: 0.6rem; display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;">{{ bk.kindBadge(item.kind) }}{{ bk.statusBadge(item.status) }}{{ bk.buildStateBadge(item.buildState) }}{% if item.size %}{{ bk.sizeBadge(item.size) }}{% endif %}{{ bk.tierBadge(item.tier) }}{{ bk.unshapedScopeBadge(item) }}{{ bk.epicStatusBadge(item) }}{{ bk.reasonPill(item) }}</div>{% if item.blockers | length %}<div class="backlog-blockers" style="position: relative; z-index: 2; display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem; margin: 0 0 0.6rem;"><span style="font-size: 0.72em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600;">Blocked by</span>{% for b in item.blockers %}{{ bk.blockerChip(b) }}{% endfor %}</div>{% endif %}<p class="backlog-summary" style="margin: 0 0 0.75rem 0; color: var(--color-text-muted); font-size: 0.9em;">{{ item.summary }}</p>{% if item.children | length %}<div class="epic-children" style="position: relative; z-index: 2; display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem; margin: 0 0 0.75rem;"><span style="font-size: 0.72em; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600;">Contains</span>{% for child in item.children %}{{ bk.childCircle(child) }}{% endfor %}</div>{% endif %}<div class="backlog-meta">{{ bk.tagsRow(item.tags) }}<div style="display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.8em;">{% if item.crossRef %}<a href="{{ item.crossRef.url }}" style="color: var(--color-primary); text-decoration: none;">&rarr; {{ item.crossRef.label }}</a>{% endif %}{% if item.relatedProject %}<a href="/projects/{{ item.relatedProject }}/" style="color: var(--color-primary); text-decoration: none;">&rarr; project: {{ item.relatedProject }}</a>{% endif %}{% if item.relatedReport %}<span style="color: var(--color-text-muted); font-family: var(--font-mono, monospace);">report{% if item.reportDate %} · {{ item.reportDate }}{% endif %}: {{ item.relatedReport }}</span>{% endif %}{% if item.graduatedTo %}<span style="color: #166534; font-weight: 600;">graduated &rarr; {{ item.graduatedTo }}</span>{% endif %}</div></div>{% endset %}
    {% set backlogTiles = (backlogTiles.push({ id: item.id, num: item.num, title: item.title, status: item.status, kind: item.kind, size: item.size, tier: item.tier, innerHtml: inner }), backlogTiles) %}
    {% endif %}{% endfor %}{% endfor %}
    {{ backlogTiles | weBacklogGrid | safe }}
</section>

{% set pqCount = 0 %}
{% for project in projects %}{% if project.openQuestions %}{% set pqCount = pqCount + 1 %}{% endif %}{% endfor %}
{% if pqCount %}
<section style="margin-top: 3rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
    <h2 class="section-title" style="margin-bottom: 0.5rem;">Live from the standards</h2>
    <p style="margin-bottom: 1.5rem; color: var(--color-text-muted); font-size: 0.9em;">Open questions declared on the standards' own pages, collected here automatically. Edit them on the project, not in the backlog.</p>
    <div class="project-grid">
        {% for project in projects %}{% if project.openQuestions %}
        <div class="project-card">
            <div class="project-header" style="margin-bottom: 0.75rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem;">
                <h3 class="project-title" style="margin: 0;"><a href="/projects/{{ project.id }}/" style="text-decoration: none; color: inherit;">{{ project.name }}</a></h3>
            </div>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
                {% for q in project.openQuestions %}
                <li style="font-size: 0.9em;">
                    <a href="/projects/{{ project.id }}/{% if q.anchor %}#{{ q.anchor }}{% endif %}" style="color: var(--color-text); text-decoration: none;">{{ q.question }}</a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}{% endfor %}
    </div>
</section>
{% endif %}

</div>{# /#panel-tracked #}

<div id="panel-active" role="tabpanel" aria-labelledby="tab-active" hidden>
{# ACTIVE WORK (#1854 v2) — a command center for everything in flight AT ONCE, grouped into OPERATION-TYPE
   lanes (Preparing · Deciding · Slicing · Batching · Building · Workflows) so someone juggling many
   concurrent runs can coordinate them. Two layers:
     • STRUCTURE (this Nunjucks) — backlog.activeWork.lanes, derived from status + kind + reservation.
       Refreshes on rebuild (claims trigger a rebuild). Each row carries data-active-num for the overlay.
     • LIVE (filled by /assets/js/backlog-active.js, polled from /active-progress.json) — running workflows
       (per-agent phase/state) AND a per-SESSION digest for each active item (current todo / last action /
       last line), so prepare/decide/slice/build all show live "chat progress", not just workflows. The
       watcher (scripts/dev/active-progress-watch.mjs) reads the harness transcripts; it 404s on a static
       publish, so the page falls back to the structural snapshot there. #}
{# One compact active-item row. `data-active-num` is the join key the client uses to overlay the live
   session digest; the digest container is unhidden + filled by the poller. Badges deduped — the lane
   already implies the status, so we show kind + size + tier only. #}
{% macro activeRow(it) %}
<div class="aw-row" data-active-num="{{ it.num }}">
    <div class="aw-row-head">
        <a href="/backlog/{{ it.id }}/" style="color:var(--color-primary); text-decoration:none; font-weight:600;"><span style="color:var(--color-text-muted, #94a3b8); font-variant-numeric:tabular-nums;">#{{ it.num }}</span> {{ it.title }}</a>
        <span style="display:inline-flex; align-items:center; gap:0.3rem; flex-wrap:wrap;">{{ bk.kindBadge(it.kind) }}{% if it.size %}{{ bk.sizeBadge(it.size) }}{% endif %}{{ bk.tierBadge(it.tier) }}</span>
    </div>
    <div class="aw-digest" data-digest-for="{{ it.num }}" hidden></div>
</div>
{% endmacro %}
{# A labelled lane of rows (no-op when empty). #}
{% macro lane(title, color, items, desc) %}
{% if items | length %}
<div class="aw-lane">
    <div class="aw-lane-head" style="color:{{ color }};"><span class="aw-lane-dot" style="background:{{ color }};"></span>{{ title }} <span class="count-badge">{{ items | length }}</span></div>
    {% if desc %}<p class="section-desc" style="margin:-0.3rem 0 0.6rem; font-size:0.8em;">{{ desc | safe }}</p>{% endif %}
    <div class="aw-rows">{% for it in items %}{{ activeRow(it) }}{% endfor %}</div>
</div>
{% endif %}
{% endmacro %}
{% set aw = backlog.activeWork %}
{% set v = aw.vitals %}
<section class="mb-12">
    <div class="aw-surface">
        <h2 class="section-title" style="margin-top:0;">Active work <span class="count-badge" data-count-target>{{ aw.count }}</span></h2>
        <p class="section-desc">A live command center for everything in flight at once — claimed work grouped by the <strong>operation</strong> driving it. Each row shows its live "chat progress" — current todo, last action, and an expandable <strong>step stream</strong> — when the dev watcher is running (<code>npm start</code> includes it); multi-agent <strong>workflows</strong> show every subagent's phase &amp; state. Lane membership refreshes on rebuild; the live overlay polls every few seconds.</p>

        {# VITALS — at-a-glance roll-up. Workflow/agent live totals are appended by the client. #}
        <div class="aw-vitals">
            <span class="aw-vital" style="background:#ede9fe; color:#6d28d9; border-color:#ddd6fe;"><span class="n">{{ v.preparing }}</span> preparing</span>
            <span class="aw-vital" style="background:#fef3c7; color:#92400e; border-color:#fde68a;"><span class="n">{{ v.deciding }}</span> deciding</span>
            <span class="aw-vital" style="background:#ecfeff; color:#155e75; border-color:#a5f3fc;"><span class="n">{{ v.slicing }}</span> slicing</span>
            <span class="aw-vital" style="background:#eef2ff; color:#3730a3; border-color:#c7d2fe;"><span class="n" id="aw-vital-batching-n">{{ v.batching }}</span> batching{% if v.batches %} <span style="opacity:0.7;">({{ v.batches }})</span>{% endif %}</span>
            <span class="aw-vital" style="background:#ffedd5; color:#9a3412; border-color:#fed7aa;"><span class="n">{{ v.building }}</span> building</span>
            {% if v.programs %}<span class="aw-vital" style="background:#e0f2fe; color:#075985; border-color:#bae6fd;"><span class="n">{{ v.programs }}</span> programs</span>{% endif %}
            <span id="aw-vital-workflows" class="aw-vital" hidden style="background:#dbeafe; color:#1e40af; border-color:#bfdbfe;"><span class="aw-lane-dot" style="background:#1e40af; animation:active-pulse 1.4s infinite;"></span><span class="n" id="aw-vital-workflows-n"></span> workflows live</span>
        </div>

        {# Lane colour legend — each colour is the OPERATION driving the work, not a status. Green is
           deliberately absent from the active lanes: it's reserved for resolved/done, which leaves this
           board (so building, an in-flight build, is rust — not green). #}
        <details class="bk-collapse" data-persist="legend-active-lanes" open>
        <summary>Lane colour legend</summary>
        <div class="active-lane-legend" style="display:flex; flex-wrap:wrap; align-items:center; gap:0.4rem 1rem; margin:0.5rem 0 1.25rem; font-size:0.8em; color:var(--color-text-muted);">
            <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#ede9fe; border:1.5px solid #6d28d9;"></span><strong style="color:#6d28d9;">Preparing</strong></span>
            <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#fef3c7; border:1.5px solid #92400e;"></span><strong style="color:#92400e;">Deciding</strong></span>
            <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#ecfeff; border:1.5px solid #155e75;"></span><strong style="color:#155e75;">Slicing</strong></span>
            <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#eef2ff; border:1.5px solid #3730a3;"></span><strong style="color:#3730a3;">Batching</strong></span>
            <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#ffedd5; border:1.5px solid #9a3412;"></span><strong style="color:#9a3412;">Building</strong></span>
            <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#e0f2fe; border:1.5px solid #075985;"></span><strong style="color:#075985;">Programs</strong></span>
            <span style="display:inline-flex; align-items:center; gap:0.35rem;"><span style="width:14px; height:14px; border-radius:50%; background:#dbeafe; border:1.5px solid #1e40af;"></span><strong style="color:#1e40af;">Workflows</strong></span>
            <span style="opacity:0.5;">|</span>
            <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Green is reserved for resolved/done work, which leaves this board — no active lane is green."><span style="width:14px; height:14px; border-radius:50%; background:#dcfce7; border:1.5px solid #16a34a;"></span><strong style="color:#166534;">Resolved</strong> <span style="font-weight:400;">— done, leaves this board</span></span>
        </div>
        </details>

        {# WORKFLOWS — live multi-agent runs (client-filled; hidden until the poller finds one). #}
        <div id="active-live" class="aw-lane" hidden>
            <div class="aw-lane-head" style="color:#1e40af;"><span class="aw-lane-dot" style="background:#1e40af; animation:active-pulse 1.6s infinite;"></span>Workflows · live <span id="active-live-count" class="count-badge"></span><span id="active-live-stamp" style="font-weight:500; text-transform:none; letter-spacing:0; color:var(--color-text-muted); margin-left:0.25rem;"></span></div>
            <div id="active-live-runs" style="display:flex; flex-direction:column; gap:0.85rem;"></div>
        </div>

        {# BATCHING — live, persistent (client-filled from the feed's kind:batch runs + batch-linked digests).
           A /batch stays visible here for as long as its reservation is live, even between items (when it
           has just resolved one and not yet flipped the next to active) — unlike the build-time lane below,
           which only shows items that happen to be `active` this instant. Hidden until the poller finds a batch. #}
        <div id="active-batches" class="aw-lane" hidden>
            <div class="aw-lane-head" style="color:#3730a3;"><span class="aw-lane-dot" style="background:#3730a3;"></span>Batching · live <span id="active-batches-count" class="count-badge"></span></div>
            <div id="active-batches-runs" style="display:flex; flex-direction:column; gap:0.85rem;"></div>
        </div>

        {{ lane('Preparing', '#6d28d9', aw.lanes.preparing, '<code>/prepare</code> — researching a decision\'s forks to Definition of Ready.') }}
        {{ lane('Deciding', '#92400e', aw.lanes.deciding, '<code>/decision</code> — a ratification call in progress.') }}
        {{ lane('Slicing', '#155e75', aw.lanes.slicing, '<code>/slice</code> — an epic being cut into child stories.') }}
        {{ lane('Programs', '#075985', aw.lanes.programs, 'Perpetual umbrellas (e.g. flagship exercise apps) — always active, advanced incrementally.') }}

        {# BATCHING (build-time fallback) — items soft-held by a running /batch that are ALSO active this
           instant. Usually empty (the held pack is status:open); the live #active-batches above is the real
           view. The client hides this when it renders the live section, to avoid a double batch listing. #}
        {% if aw.batches | length %}
        <div class="aw-lane" id="aw-static-batching">
            <div class="aw-lane-head" style="color:#3730a3;"><span class="aw-lane-dot" style="background:#3730a3;"></span>Batching <span class="count-badge">{{ v.batching }}</span></div>
            {% for b in aw.batches %}
            <div class="aw-batch">
                <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.5rem;">
                    <span style="font-weight:700; color:#3730a3;">⊘ {{ b.session }}</span>
                    <span style="font-size:0.78em; color:var(--color-text-muted); font-variant-numeric:tabular-nums;">{{ b.date }} · {{ b.items | length }} active{% if b.points %} · {{ b.points }} pts{% endif %}</span>
                </div>
                <div class="aw-rows">{% for it in b.items %}{{ activeRow(it) }}{% endfor %}</div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {{ lane('Building', '#9a3412', aw.lanes.building, 'A single <code>/next</code> or ad-hoc session building a story/task.') }}

        {% if not aw.count %}
        <p style="color:var(--color-text-muted); margin:0;">Nothing is claimed right now. When a <code>/prepare</code>, <code>/decision</code>, <code>/slice</code>, <code>/batch</code>, <code>/next</code>, or <code>/workflow</code> run claims work it appears here — with its live progress if the watcher is running.</p>
        {% endif %}
    </div>
</section>
</div>{# /#panel-active #}

<div id="panel-priority" role="tabpanel" aria-labelledby="tab-priority" hidden>
{# Open items ranked by how much work resolving them would free — derived deterministically in the
   loader (#254) by inverting `blockedBy`. `transitiveUnblocks` = every open item this one ultimately
   gates; `unblocksToReady` = open issue/idea dependents this is the LAST open blocker for (resolving it
   flips them to agent-ready). Sorted by `leverageScore` (transitive-dominant); only items that gate
   something appear. #}
{% set leverageItems = backlog | where("status", "open") | sort(attribute="leverageScore", reverse=true) %}
{% set leverageCount = leverageItems | length %}
{# In-flight decisions — a `decision` claimed (status:active) for a live /decision turn. It's no longer
   `open`, so the loader gives it no tier and it would normally drop out of this open-only table. We pin it
   back in (concatenated AHEAD of the open rows) flagged "deciding now", so the call you're currently making
   stays visible in the decision-ready view. Scoped to THIS table only — the loader tier rule and every
   other tab / rollup are untouched. #}
{% set activeDecisions = backlog | where("status", "active") | where("kind", "decision") | sort(attribute="leverageScore", reverse=true) %}
{% set countActiveDecisions = activeDecisions | length %}
{# Being-prepared decisions — a `decision` claimed (status:preparing) by a live /prepare turn (pre-research
   that brings the forks to DoR, not the ratification call). Like an in-flight decision it's no longer `open`,
   so the loader gives it no tier and it would drop out of this open-only table; we pin it back flagged
   "preparing" so the research underway stays visible and a concurrent session doesn't re-prepare the same
   fork. Scoped to THIS table only. #}
{% set preparingDecisions = backlog | where("status", "preparing") | sort(attribute="leverageScore", reverse=true) %}
{% set countPreparing = preparingDecisions | length %}
{# In-flight batch work — a batch-shaped item (task / story ≤8) claimed (status:active) by a running /batch.
   Like an active decision it has no tier and would drop out of this open-only table; we pin it back
   (concatenated AHEAD of the open rows) flagged "batching now" so a concurrent batcher sees the batch work
   genuinely underway — the authoritative status flip, not just the ephemeral reservations.json soft-hold
   strip below. Scoped to THIS table; the loader tier rule and every other tab are untouched. #}
{% set activeBatchables = backlog | where("activeBatchable", true) | sort(attribute="leverageScore", reverse=true) %}
{% set countActiveBatch = activeBatchables | length %}
{% set tableRows = activeDecisions.concat(preparingDecisions).concat(activeBatchables).concat(leverageItems) %}
{% set countBatch = backlog | where("batchable", true) | length %}
{% set countA = backlog.countAgentReady %}
{% set countSplit = backlog.countSplittable %}
{% set countSlice = backlog.countSliceable %}
{% set countEpicAction = backlog.countEpicActionable %}
{% set countEpicParked = backlog.countEpicParked %}
{% set countEpicUnsliced = backlog.countEpicUnsliced %}
{% set countEpicDone = backlog.countEpicDone %}
{% set countEpicProgram = backlog.countEpicProgram %}
{% set countB = backlog | where("tier", "B") | length %}
{% set countPrepared = backlog.countPreparedB %}
{% set countC = backlog | where("tier", "C") | length %}
{% set pointsBatch = backlog.pointsBatch %}
{% set pointsA = backlog.pointsTierA %}
{% set pointsSlice = backlog.pointsSlice %}
{% set readyBeyondBatch = countA - countBatch %}
{% set readySplit = backlog.countSplittableReady %}
{# Low-priority adjustment (#1620) — how much the "Hide low priority" toggle removes from each pill
   (agent-ready / decision / epics / not-ready) and the section total, computed once so the JS swap
   has both variants. Not Tier-A-only: a `priority: low` decision or epic is demoted just the same. #}
{% set countLowAgentReady = backlog.countLowAgentReady %}
{% set pointsLowAgentReady = backlog.pointsLowAgentReady %}
{% set countLowDecision = backlog.countLowDecision %}
{% set pointsLowDecision = backlog.pointsLowDecision %}
{% set countLowPreparedDecision = backlog.countLowPreparedDecision %}
{% set countLowSliceable = backlog.countLowSliceable %}
{% set countLowNotReady = backlog.countLowNotReady %}
{% set pointsLowNotReady = backlog.pointsLowNotReady %}
{% set countLowOpen = backlog.countLowOpen %}
{% set pointsB = backlog.pointsTierB %}
{% set pointsC = backlog.pointsTierC %}
<section class="mb-12">
    {# The "Hide low priority" toggle is a VIEW-LEVEL control — it drops low-priority work from the summary
       pills, the section count, AND the table below. It rides on the SUMMARY-PILLS row (right-edge, pushed
       there by margin-left:auto) so it sits directly beside the pills whose counts it recomputes — the
       control↔pills link reads explicitly (#2054). Still at/above what it filters: the pills row is above
       the table, and the section count badge on the title line is unaffected. (The table-only "Splittable
       only" toggle stays down in the table-filter row, above the rows it narrows.) #}
    <h2 class="section-title" style="margin:0 0 0.5rem;">Prioritisation <span class="count-badge" data-pcount-full="{{ leverageCount }}" data-pcount-nofiller="{{ leverageCount - countLowOpen }}">{{ leverageCount }}</span></h2>
    <p class="section-desc">Every <strong>open</strong> item (plus any <strong>decision being actively made</strong>, pinned on top), sortable — ranked by default by <strong>how much work resolving it would unblock</strong> (the inverse of the <code>blockedBy</code> edges, computed deterministically from structured fields only, no LLM). <strong>Frees now</strong> counts the items this is the <em>last</em> open prerequisite for — resolving it flips them to agent-ready. <strong>Gates (chain)</strong> counts every open item it ultimately blocks, directly or transitively. The <strong>Readiness</strong> column is the agent-readiness tier; sort by it to surface the batchable work.</p>
    {# #1874: the six Prioritisation summary pills migrated to <we-filter-chip> (the rich-count + structured
       sub-count dogfood, completing #1825's plain-chip half). Each pill's semantic background is WE-domain
       vocabulary (batchable/agentready/…), so it stays WE-side via `[data-pfilter]` CSS targeting the upgraded
       `.fui-filter-chip` button (FUI's chip stays generic — no backlog tones leak into it). The nested
       colour-coded sub-count <span>s are authored as children and survive the transient upgrade into the
       button's label (the #1873 passthrough). `data-pfilter` + the toggle JS (backlog-table-sort.js, #1825)
       are unchanged. #}
    <div style="display:flex; gap:0.6rem; flex-wrap:wrap; align-items:center; margin:0 0 1rem; font-size:0.85em;">
        <we-filter-chip data-pfilter="batchable" aria-pressed="false" title="Click to filter the table to the batch pool. Batchable (deterministic) — the candidate set a points-budgeted batch may pack: a Tier-A task or a story of size ≤ 8. The budget packs smallest-first, reaching a single size·8 when the remaining points fit. Story ≥13 and any epic are never packed.">{{ countBatch }} batchable <span style="font-weight:600; opacity:0.85;">({{ pointsBatch }} pts{% if countActiveBatch %} · <span style="color:#bfdbfe; font-weight:700;">{{ countActiveBatch }} in flight</span>{% endif %})</span></we-filter-chip>
        {% if readyBeyondBatch %}<we-filter-chip data-pfilter="agentready" aria-pressed="false" title="Click to filter to agent-ready work beyond the batch pool — an issue/idea with every prerequisite resolved, but outside the batch pool (see ‘batchable’). Most are oversized stories (size ≥ 13) that should be /split into ≤5-pt slices first (the ‘· N to split’ sub-tally; docs/agent → Splitting), but it also holds the few Tier-A items that build directly yet can't be batched — a stop-the-world migration, or an unsized story. Excludes container epics (see the epics pill). Note: a still-BLOCKED oversized story isn't agent-ready, so it sits under ‘not ready’ — isolate all split candidates (incl. blocked) via the ‘Splittable only’ chip."><span data-pcount-full="{{ readyBeyondBatch }}" data-pcount-nofiller="{{ readyBeyondBatch - countLowAgentReady }}">{{ readyBeyondBatch }}</span> agent-ready <span style="font-weight:600; opacity:0.8;">(<span data-pcount-full="{{ pointsA - pointsBatch }}" data-pcount-nofiller="{{ pointsA - pointsBatch - pointsLowAgentReady }}">{{ pointsA - pointsBatch }}</span> pts{% if readySplit %} · {{ readySplit }} to split{% endif %})</span></we-filter-chip>{% endif %}
        {% if countSlice %}<we-filter-chip data-pfilter="sliceable" aria-pressed="false" title="Click to filter to the unblocked (Tier A) epics. An epic isn't directly buildable — its work lives in child slices. Most here are just tracking open children (no action); only the ones tagged ‘slice’ (unsliced) or ‘resolve’ (all children done) need attention."><span data-pcount-full="{{ countSlice }}" data-pcount-nofiller="{{ countSlice - countLowSliceable }}">{{ countSlice }}</span> epic{{ "s" if countSlice != 1 }}{% if countEpicAction %} <span style="font-weight:600; opacity:0.8;">({% if countEpicUnsliced %}{{ countEpicUnsliced }} slice{% endif %}{% if countEpicUnsliced and countEpicDone %} · {% endif %}{% if countEpicDone %}{{ countEpicDone }} resolve{% endif %})</span>{% endif %}</we-filter-chip>{% endif %}
        <we-filter-chip data-pfilter="program" aria-pressed="false" title="Click to filter to ongoing programs — perpetual umbrellas (e.g. the flagship exercise apps) marked ongoing:true. NOT a resolve to-do: they legitimately have every child resolved between slices and are continuously advanced.">{{ countEpicProgram }} program{{ "s" if countEpicProgram != 1 }}</we-filter-chip>
        <we-filter-chip data-pfilter="decision" aria-pressed="false" title="Click to filter to decision-ready (Tier B) — a decision awaiting a nod; ratify it, then the build it gates becomes agent-ready. A ✓ prepared one has its forks researched + options stated (preparedDate) — ready to ratify, not research."><span data-pcount-full="{{ countB }}" data-pcount-nofiller="{{ countB - countLowDecision }}">{{ countB }}</span> decision <span style="font-weight:600; opacity:0.8;">(<span data-pcount-full="{{ pointsB }}" data-pcount-nofiller="{{ pointsB - pointsLowDecision }}">{{ pointsB }}</span> pts{% if countPrepared %} · <span style="color:#15803d;"><span data-pcount-full="{{ countPrepared }}" data-pcount-nofiller="{{ countPrepared - countLowPreparedDecision }}">{{ countPrepared }}</span> ✓ prepared</span>{% endif %}{% if countActiveDecisions %} · <span style="color:#1e40af;">{{ countActiveDecisions }} in flight</span>{% endif %}{% if countPreparing %} · <span style="color:#6d28d9;">{{ countPreparing }} preparing</span>{% endif %})</span></we-filter-chip>
        <we-filter-chip data-pfilter="notready" aria-pressed="false" title="Click to filter to not ready (Tier C) — an issue/idea that still has an open prerequisite; clear its blocker first."><span data-pcount-full="{{ countC }}" data-pcount-nofiller="{{ countC - countLowNotReady }}">{{ countC }}</span> not ready <span style="font-weight:600; opacity:0.8;">(<span data-pcount-full="{{ pointsC }}" data-pcount-nofiller="{{ pointsC - pointsLowNotReady }}">{{ pointsC }}</span> pts)</span></we-filter-chip>
        {# View-level "Hide low priority" toggle — right-edge of the pills row (margin-left:auto) so it reads as
           the control OVER these pills, not a stray section-title button (#2054). It recomputes every pill's
           count above, plus the section badge + table below. #}
        {% if tableRows | where("priority", "low") | length %}<div class="status-filter" role="group" aria-label="Hide low priority" style="margin:0 0 0 auto;">
            <we-filter-chip data-pfiller aria-pressed="false" title="When on, hide low-priority work — any item marked `priority: low` (#1620): settled &amp; valid but demoted, not worth doing now. Applies across the WHOLE view — the summary pills above, the count, and every readiness bucket in the table. Orthogonal to the facet chips (AND-composes). Off by default.">Hide low priority</we-filter-chip>
        </div>{% endif %}
    </div>
    {# Active batches (dev-only, advisory) — live soft-reservations from a running /batch, grouped by
       session (see backlog.js → items.activeBatches). Shows a concurrent batcher what's already in flight
       so a second batch packs around it. Ephemeral session state: live on the dev server, frozen at
       build-time on a static build. Hidden entirely when nothing is held. #}
    {% set activeBatches = backlog.activeBatches %}
    {% if activeBatches | length %}
    <div style="display:flex; gap:0.6rem; flex-wrap:wrap; align-items:center; margin:0 0 1rem; font-size:0.85em;">
        <span style="font-weight:700; color:#3730a3;" title="Live soft-reservations from a running /batch session (reservations.json). Advisory and dev-only — these clear when the batch finishes or its 120-min lease expires.">⊘ {{ activeBatches | length }} active batch{{ "es" if activeBatches | length != 1 }}</span>
        {% for b in activeBatches %}
        <span title="Batch {{ b.session }} — holding {{ b.nums | length }} item{{ 's' if b.nums | length != 1 }} ({{ b.points }} pts) since {{ b.date }}. Soft hold: a second concurrent batch deprioritizes these, the real lock is each item's status:open→active flip at claim." style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.2rem 0.6rem; border-radius:9999px; background:#eef2ff; color:#3730a3; border:1px solid #c7d2fe; font-weight:600;">{{ b.date }} · {% for n in b.nums %}#{{ n }}{% if not loop.last %} {% endif %}{% endfor %} <span style="font-weight:500; opacity:0.8;">({{ b.points }} pts)</span></span>
        {% endfor %}
    </div>
    {% endif %}
    <p class="section-desc" style="margin:-0.5rem 0 1rem; font-size:0.82em;"><strong style="color:#166534;">Batchable</strong> = the batch pool — <strong>Tier A</strong> (issue/idea with every prerequisite resolved) <em>and</em> small enough to chain: a <strong>task</strong> or a <strong>story&nbsp;≤&nbsp;8&nbsp;pts</strong>. A points-budgeted batch packs from this set smallest-first, reaching a single <code>size·8</code> when the remaining points fit. A <strong>story&nbsp;≥&nbsp;13</strong> is agent-ready but <em>never</em> batched (real work, too big for one chain) — it carries a <strong style="color:#9a3412;">split</strong> badge marking it as a <code>/split</code> candidate to cut into ≤5-pt slices first. An <strong>epic</strong> is unblocked but not directly buildable — its work lives in child slices, so it's counted separately and never as buildable work. Most epics here just <strong>track</strong> open children (no action — the work is those children); only an <strong style="color:#155e75;">unsliced</strong> epic (tag <code>slice</code>) or one whose children are all done (tag <code>resolve</code>) needs attention. All computed deterministically from the <code>type</code>/<code>blockedBy</code>/<code>size</code> fields — no LLM.</p>
    {# Epic-badge legend — defines every tag an epic row can carry, including the parked reasons. Kept on
       this tab (not just the Tracked-work one) because the readiness column shows these tags here. #}
    <details class="bk-collapse" data-persist="legend-epic-tags" style="margin:-0.5rem 0 1rem;">
        <summary>What the epic tags mean</summary>
        <ul style="margin:0.5rem 0 0; padding-left:1.1rem; font-size:0.82em; color:var(--color-text-muted); line-height:1.6;">
            <li><strong style="color:#155e75;">slice</strong> — unsliced and <em>no reason recorded</em>: cut it into child stories/tasks via <code>/slice</code> (or record why not).</li>
            <li><strong style="color:#166534;">resolve</strong> — every child slice is resolved but the epic is still open: just close it (a status update).</li>
            <li><strong style="color:#475569;">tracking</strong> — open child slices remain: no epic-level action, its work is those children (already in the pool above).</li>
            <li><strong style="color:#5b21b6;">needs triage</strong> — a holding-pen of candidates. <strong>Triage</strong> = go through each candidate and decide its fate — <em>promote</em> it to its own backlog item, <em>fold</em> it into an existing item, or <em>drop</em> it. Only the promoted survivors become child slices; until that pass happens the epic can't be sliced.</li>
            <li><strong style="color:#991b1b;">blocked</strong> — waiting on the prerequisites in its Blocked-by row; clear those first. An epic gated on an <em>open design decision</em> is blocked on a separate <code>kind: decision</code> item via <code>blockedBy</code> — never an inline "needs decisions" reason (that state is retired; ratify the decision, then it falls to <strong>slice</strong>).</li>
            <li><strong style="color:#075985;">ongoing program</strong> — no fixed child stories by design; measured by progress, not decomposed.</li>
        </ul>
    </details>
    {# Not-ready reason legend — defines the ⊗ pills that sit next to a "Not ready" badge in the Readiness
       column (rendered by bk.reasonPill). They expose WHY an item isn't agent-ready; one shows per item,
       by the same precedence the loader uses. Vocabulary mirrors backlogMeta (humanGateMeta / notBatchableMeta). #}
    <details class="bk-collapse" data-persist="legend-reason-pills" style="margin:-0.5rem 0 1rem;">
        <summary>What the ⊗ not-ready reasons mean</summary>
        <ul style="margin:0.5rem 0 0; padding-left:1.1rem; font-size:0.82em; color:var(--color-text-muted); line-height:1.6;">
            <li><strong style="color:#991b1b;">⊗ blocked by #NNN</strong> — waiting on an unresolved prerequisite (<code>blockedBy</code>); not workable until that item resolves.</li>
            <li><strong style="color:#5b21b6;">⊗ project pending · <em>name</em></strong> — held by D3-readiness: its <code>relatedProject</code> is a <code>concept</code> with no shipped surface, so the standard must exist first. The pill <strong>names and links the project</strong> — open it to ship/graduate it (resolving ≥1 item under it, or bumping its status off <code>concept</code>), or re-home the item.</li>
            <li><strong style="color:#991b1b;">⊗ human deploy / needs credential / needs review / needs feedback / needs setup</strong> — a <code>humanGate</code>: the only residual is a human-only action (not a <code>blockedBy</code> edge an agent can clear). Do the action, then remove the gate.</li>
            <li><strong style="color:#991b1b;">⊗ migration</strong> — a stop-the-world migration: touches the whole backlog, so it runs only when the backlog is quiescent (no active claims / reservations), never inside a routine batch.</li>
        </ul>
    </details>
    {% if leverageCount or countActiveDecisions or countPreparing or countActiveBatch %}
    {# Higher rank = more ready, so first-click (descending, like the other numeric columns) puts
       Agent-ready on top. Value is a hidden sort key only — never shown. #}
    {% set tierRank = { "A": 3, "B": 2, "C": 1 } %}
    <p class="section-desc" style="margin-top:-0.5rem; font-size:0.82em;">Click a column header to sort; click again to reverse. Default order is by leverage (Gates, then Direct).</p>
    {# Client-side filtering for the Prioritisation table (backlog-table-sort.js). Chips toggle; deselecting
       every chip in a group means "no filter" (show all). The count badge reflects the visible rows. #}
    <div class="ptable-filter" style="display:flex; gap:0.6rem 1rem; flex-wrap:wrap; align-items:center; margin-bottom:0.75rem;">
        <input type="search" data-ptable-search placeholder="Filter by # or title…" aria-label="Filter the table by id or title" style="appearance:none; border:1px solid var(--color-border); border-radius:0.4rem; padding:0.3rem 0.6rem; font:inherit; font-size:0.85em; min-width:200px;">
        <div class="status-filter" role="group" aria-label="Filter by readiness">
            {# #2280: seed the class the selected-tint CSS keys on (default-on = all readiness chips), matching the Tracked-work chips. #}
            <we-filter-chip data-pready="batchable" selected class="fui-filter-chip--selected" title="The batch pool — Tier-A task or story ≤8; a points-budgeted batch packs from here">Batchable</we-filter-chip>
            <we-filter-chip data-pready="agentready" selected class="fui-filter-chip--selected" title="Buildable agent-ready beyond the batch pool — a story ≥13 (too big to chain). Excludes epics.">Agent-ready</we-filter-chip>
            <we-filter-chip data-pready="sliceable" selected class="fui-filter-chip--selected" title="Epics — unblocked, not directly buildable. Tagged slice (unsliced), resolve (children all done), or tracking (open children, no action).">Epics</we-filter-chip>
            <we-filter-chip data-pready="program" selected class="fui-filter-chip--selected" title="Ongoing programs — perpetual umbrellas (e.g. the flagship exercise apps) marked ongoing:true. Never a resolve to-do; continuously advanced, a new slice each round.">Programs</we-filter-chip>
            <we-filter-chip data-pready="decision" selected class="fui-filter-chip--selected" title="Tier B — a decision to ratify">Decision</we-filter-chip>
            <we-filter-chip data-pready="notready" selected class="fui-filter-chip--selected" title="Tier C — has an open prerequisite">Not ready</we-filter-chip>
        </div>
        <div class="status-filter" role="group" aria-label="Filter by kind">
            {# Build a chip per kind PRESENT IN THE TABLE — `tableRows`, not just open items — so a pinned
               in-flight decision/batch (status:active) still gets its kind chip. Otherwise its row carries a
               kind with no matching chip, and the JS kind-filter (all chips pressed = that set only) hides it. #}
            {% for k in ["story", "epic", "task", "decision"] %}{% if tableRows | where("kind", k) | length %}
            <we-filter-chip data-pkind="{{ k }}" selected class="fui-filter-chip--selected">{{ k | title }}</we-filter-chip>
            {% endif %}{% endfor %}
        </div>
        {# Table-only refinement — "Splittable only" narrows the ROWS below it (it doesn't touch the summary
           pills), so it correctly sits here, above the table, after the two facet groups. The view-level
           "Hide low priority" toggle rides on the summary-pills row instead (it changes the pills too). #}
        {% if countSplit %}<div class="status-filter" role="group" aria-label="Filter to split candidates">
            <we-filter-chip data-psplit title="When on, show only /split candidates — open stories of size &gt; 8 (the 13 band). Orthogonal to readiness: combines with the readiness/type chips (AND), so it isolates split candidates within whatever else is selected. Off by default.">Splittable only</we-filter-chip>
        </div>{% endif %}
        <span style="font-size:0.82em; color:var(--color-text-muted);"><strong data-ptable-count>{{ leverageCount + countActiveDecisions + countPreparing + countActiveBatch }}</strong> shown</span>
    </div>
    <div style="overflow-x: auto;">
    <table class="bd-ratetable sortable" style="min-width: 860px;">
        <thead><tr>
            <th data-sort-key="item" data-sort-type="num" style="text-align:left;">Item <span class="sort-ind"></span></th>
            <th data-sort-key="kind" data-sort-type="text" title="story / epic / task / decision">Kind <span class="sort-ind"></span></th>
            <th data-sort-key="size" data-sort-type="num" title="Agile points — a story carries Fibonacci size (1/2/3/5/8/13); a task is unsized but shown at its nominal ~2 pt batch weight (TASK_COST); an epic rolls up its children. Batchable = task or story ≤8.">Size <span class="sort-ind"></span></th>
            <th data-sort-key="readiness" data-sort-type="num" title="Agent-readiness tier — sorts Batchable (task or story ≤8) first, then Agent-ready (A), Decision-ready (B), Not-ready (C)">Readiness <span class="sort-ind"></span></th>
            <th data-sort-key="frees" data-sort-type="num" title="Open items this is the last open prerequisite for — resolving it flips them to agent-ready">Frees now <span class="sort-ind"></span></th>
            <th data-sort-key="gates" data-sort-type="num" title="Every open item this one ultimately blocks, directly or transitively">Gates (chain) <span class="sort-ind"></span></th>
            <th data-sort-key="direct" data-sort-type="num" title="Open items directly blocked by this one">Direct <span class="sort-ind"></span></th>
            <th style="text-align:left;">Would free</th>
        </tr></thead>
        <tbody>
        {% for item in tableRows %}
            {% set isActiveDecision = item.status == 'active' and item.kind == 'decision' %}
            {% set isPreparing = item.status == 'preparing' %}
            {% set isActiveBatch = item.activeBatchable %}
            <tr data-kind="{{ item.kind }}" data-readiness="{% if isActiveDecision or isPreparing %}decision{% elif isActiveBatch %}batchable{% elif item.batchable %}batchable{% elif item.epicState == 'program' %}program{% elif item.sliceable %}sliceable{% elif item.tier == 'A' %}agentready{% elif item.tier == 'B' %}decision{% else %}notready{% endif %}"{% if item.splittable %} data-splittable="true"{% endif %}{% if item.priority == 'low' %} data-lowprio="true"{% endif %}{% if isActiveDecision or isPreparing or isActiveBatch %} data-pinned="true"{% endif %} data-search="{{ item.num }} {{ item.title | lower }}">
                <td style="text-align:left;" data-sort-val="{{ item.num }}">
                    <a href="/backlog/{{ item.id }}/" style="color: var(--color-primary); text-decoration: none; font-weight: 600;"><span style="color: var(--color-text-muted, #94a3b8); font-variant-numeric: tabular-nums;">#{{ item.num }}</span> {{ item.title }}</a>{% if item.reservedBy %} <span title="Held by a running batch ({{ item.reservedBy }}). Soft reservation — a concurrent batch deprioritizes it; the real lock is the status:open→active flip at claim." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#eef2ff; color:#3730a3; border:1px solid #c7d2fe; white-space:nowrap;">⊘ in batch</span>{% endif %}
                </td>
                <td data-sort-val="{{ item.kind }}">{{ bk.kindBadge(item.kind) }}</td>
                <td data-sort-val="{{ item.size if item.size else (item.batchCost if item.kind == 'task' else 0) }}">{% if item.size %}{{ bk.sizeBadge(item.size) }}{% elif item.kind == 'task' %}<span title="task — unsized; weighted at a nominal {{ item.batchCost }} pts (TASK_COST) for batch budgeting. Real points roll up to its parent." style="font-size:0.78em; color:var(--color-text-muted, #94a3b8); font-variant-numeric:tabular-nums;">~{{ item.batchCost }} pts</span>{% else %}<span title="{{ item.kind }} — unsized (rolls up its child stories)" style="font-size:0.78em; color:var(--color-text-muted, #94a3b8);">{{ item.kind }}</span>{% endif %}</td>
                <td data-sort-val="{{ 2.9 if isActiveDecision else (2.85 if isPreparing else (4 if (item.batchable or isActiveBatch) else (2.8 if (item.sliceable and (item.epicState == 'unsliced' or item.epicState == 'done')) else (2.6 if item.sliceable else (2.5 if (item.tier == 'B' and item.preparedDate) else (tierRank[item.tier] if item.tier else 0)))))) }}">{% if isActiveDecision %}{{ bk.tierBadge('B') }} <span title="In flight — this decision is claimed (status:active) and being made in a live /decision turn. Pinned to the top of the decision-ready view so the call in progress stays visible." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#1e40af; color:#fff; white-space:nowrap;">deciding now</span>{% elif isPreparing %}{{ bk.tierBadge('B') }} <span title="Preparing — this decision is claimed (status:preparing) by a live /prepare turn: its forks are being researched to Definition of Ready, ahead of the ratification call. Pinned to the top of the decision-ready view so the prep underway stays visible and a concurrent session doesn't re-prepare the same fork." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#6d28d9; color:#fff; white-space:nowrap;">preparing</span>{% elif isActiveBatch %}{{ bk.tierBadge('A') }} <span title="Batching now — this batch-shaped item (task / story ≤8) is claimed (status:active) and being worked in a live /batch run. Pinned to the top of the batch pool so a concurrent batcher packs around the work already underway — the authoritative status flip, not just the reservations.json soft-hold." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#1e40af; color:#fff; white-space:nowrap;">batching now</span>{% else %}{{ bk.tierBadge(item.tier) }}{% if item.batchable %} <span title="Batchable — a Tier-A task or story ≤8; a points-budgeted batch packs from this pool when the remaining budget fits." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#166534; color:#fff; white-space:nowrap;">batch</span>{% elif item.sliceable %}{% if item.epicState == 'unsliced' %} <span title="Unsliced epic — no child slices cut yet, and no reason recorded. /slice it into child stories/tasks, or record a childlessReason saying why not." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#155e75; color:#fff; white-space:nowrap;">slice</span>{% elif item.epicState == 'done' %} <span title="Every child slice is resolved but the epic is still open — its scope looks delivered. Resolve it (a status update), or add the remaining child work." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#15803d; color:#fff; white-space:nowrap;">resolve</span>{% elif item.epicState == 'parked' %}{% set rm = backlogMeta.childlessReasonMeta[item.childlessReason] %} <span title="Parked — decomposition is gated, so this is NOT a slice to-do. {{ rm.tip if rm else 'A childlessReason is recorded; clear it before slicing.' }}" style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:{{ rm.bg if rm else '#ede9fe' }}; color:{{ rm.fg if rm else '#5b21b6' }}; white-space:nowrap;">{{ rm.label if rm else 'parked' }}</span>{% elif item.epicState == 'program' %} <span title="Ongoing program — a continuous effort, not a fixed deliverable. NOT a resolve to-do: it legitimately has every child resolved between slices, and the next slice is added as the program advances." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#e0f2fe; color:#075985; white-space:nowrap;">ongoing program</span>{% else %} <span title="Tracking — open child slices remain. No epic-level action: its work is those children, which are already in the agent-ready/batch pool. The epic resolves once they finish." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#e2e8f0; color:#475569; white-space:nowrap;">tracking</span>{% endif %}{% endif %}{% if item.splittable %} <span title="Oversized story (size &gt; 8, the 13 band) — real buildable work, but too big to chain in a batch. /split it into ≤5-pt agent-ready slices first, then batch those. An orthogonal flag on top of the tier: the story stays agent-ready (or not-ready if still blocked)." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#9a3412; color:#fff; white-space:nowrap;">split</span>{% elif item.unsplittableReason and item.kind == 'story' and item.size > 8 %}{% set um = backlogMeta.unsplittableReasonMeta[item.unsplittableReason] %} <span title="Analyzed by /split and ruled could-not-split — NOT a split to-do. {{ um.tip if um else 'An unsplittableReason is recorded.' }}" style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:{{ um.bg if um else '#f1f5f9' }}; color:{{ um.fg if um else '#475569' }}; white-space:nowrap;">atomic &middot; {{ um.label if um else item.unsplittableReason }}</span>{% endif %}{% if item.tier == 'B' and item.preparedDate %} <span title="Prepared — its forks are researched (research published as a /research/ topic), each with options + a bold default, and preparedDate is set. Ready to ratify, not research; sorts above un-prepared decisions." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#15803d; color:#fff; white-space:nowrap;">✓ ready</span>{% endif %}{{ bk.unshapedScopeBadge(item) }}{{ bk.reasonPill(item) }}{% endif %}</td>
                <td style="font-weight: 700;{% if item.unblocksToReady %} color: #166534;{% endif %}" data-sort-val="{{ item.unblocksToReady }}">{{ item.unblocksToReady }}</td>
                <td data-sort-val="{{ item.transitiveUnblocks }}">{{ item.transitiveUnblocks }}</td>
                <td data-sort-val="{{ item.directUnblocks }}">{{ item.directUnblocks }}</td>
                <td style="text-align:left; font-size: 0.92em;">
                    {% for dep in item.dependents | where("status", "open") %}<a href="/backlog/{{ dep.id }}/" title="{{ dep.title }}" style="color: var(--color-text-muted); text-decoration: none; font-variant-numeric: tabular-nums;">#{{ dep.num }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
    <p class="section-desc" style="margin-top: 1rem;">All open items are listed; those that gate no open work simply show <strong>0</strong> in the leverage columns (sort by <strong>Gates</strong> to push them down, or by <strong>Readiness</strong> to surface the batchable ones). An <span style="color:#166534; font-weight:600;">Agent-ready</span> item with high leverage is the highest-value thing to start now; a <span style="color:#92400e; font-weight:600;">Decision-ready</span> or <span style="color:#475569; font-weight:600;">Not ready</span> one with high leverage is the highest-leverage <em>blocker</em> to clear first.</p>
    {% else %}
    <p>No open items.</p>
    {% endif %}
</section>
</div>{# /#panel-priority #}

<div id="panel-humansetup" role="tabpanel" aria-labelledby="tab-humansetup" hidden>
{# Human setup — the residuals that ONLY a person can clear (a `humanGate` in the loader: a non-`blockedBy`
   hold, kinds deploy/credential/setup/review/feedback). Nothing in the backlog resolves these — an agent
   can't run a credentialed deploy, register an npm account, or give a sign-off — so they sit OUTSIDE the
   leverage ranking on the Prioritisation tab (which is agent-workable, blockedBy-driven). This tab gathers
   them in one place and answers "if I sit down and do this, how much work does it free?": doing the action
   makes the gated item itself agent-workable (+1), and that item in turn gates `transitiveUnblocks` more
   open items downstream — so `frees = 1 + transitiveUnblocks`. Sorted most-freeing first. All derived from
   the same deterministic fields the Prioritisation tab uses (humanGate + the inverted blockedBy edges). #}
{% set setupItems = backlog | where("humanSetupPending", true) | sort(attribute="leverageScore", reverse=true) %}
{% set setupCount = setupItems | length %}
{% set setupFreesTotal = 0 %}{% for it in setupItems %}{% set setupFreesTotal = setupFreesTotal + it.transitiveUnblocks + 1 %}{% endfor %}
<section class="mb-12">
    <h2 class="section-title">Human setup <span class="count-badge">{{ setupCount }}</span></h2>
    <p class="section-desc">The things <strong>only you</strong> can do — held on a <strong>human-only action</strong> an agent can't perform (a credentialed deploy, an external account or npm publish, a one-time live verification, a sign-off). These aren't a <code>blockedBy</code> edge anything in the backlog will clear, so they don't appear in the Prioritisation leverage table. <strong>Frees</strong> = how much work doing the action unlocks: the gated item itself becomes agent-workable, plus every open item it then gates downstream. Sorted most-freeing first. Do these, then remove the <code>humanGate</code> from the item.</p>
    {% if setupCount %}
    {# Per-kind tally chips — what KINDS of action are waiting, by the same humanGateMeta vocabulary the pills use. #}
    {% set kindOrderHG = ["deploy", "credential", "setup", "review", "feedback"] %}
    <div style="display:flex; gap:0.6rem; flex-wrap:wrap; align-items:center; margin:0 0 1.25rem; font-size:0.85em;">
        <span style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.6rem; border-radius:9999px; background:#0f172a; color:#fff; font-weight:700; white-space:nowrap;">{{ setupCount }} action{{ "s" if setupCount != 1 }} <span style="font-weight:600; opacity:0.8;">(frees ~{{ setupFreesTotal }} items)</span></span>
        {% for k in kindOrderHG %}{% set n = setupItems | where("humanGateKind", k) | length %}{% if n %}{% set m = backlogMeta.humanGateMeta[k] %}
        <span title="{{ m.tip }}" style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.6rem; border-radius:9999px; background:{{ m.bg }}; color:{{ m.fg }}; font-weight:700; white-space:nowrap;">{{ n }} {{ m.label }}</span>
        {% endif %}{% endfor %}
    </div>
    <div style="overflow-x: auto;">
    <table class="bd-ratetable" style="min-width: 760px;">
        <thead><tr>
            <th style="text-align:left;">Item</th>
            <th style="text-align:left;">Action you do</th>
            <th title="How much doing this action unlocks: the gated item itself becomes agent-workable, plus every open item it then gates downstream (1 + chain).">Frees</th>
            <th title="Open items this gate is the last thing standing between and agent-ready">Direct</th>
            <th style="text-align:left;">Would free</th>
        </tr></thead>
        <tbody>
        {% for item in setupItems %}
            {% set hg = backlogMeta.humanGateMeta[item.humanGateKind] %}
            <tr>
                <td style="text-align:left;">
                    <a href="/backlog/{{ item.id }}/" style="color: var(--color-primary); text-decoration: none; font-weight: 600;"><span style="color: var(--color-text-muted, #94a3b8); font-variant-numeric: tabular-nums;">#{{ item.num }}</span> {{ item.title }}</a>
                    {% if item.status == 'active' %} <span title="Claimed (status:active) — already being worked." style="padding:0.05rem 0.4rem; border-radius:9999px; font-size:0.62em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:#dbeafe; color:#1e40af; white-space:nowrap;">in progress</span>{% endif %}
                </td>
                <td style="text-align:left; font-size:0.92em;">
                    <span title="{{ hg.tip if hg else 'A human-only action.' }}" style="display:inline-block; padding:0.05rem 0.45rem; border-radius:9999px; font-size:0.72em; font-weight:700; text-transform:uppercase; letter-spacing:0.03em; background:{{ hg.bg if hg else '#fef2f2' }}; color:{{ hg.fg if hg else '#991b1b' }}; white-space:nowrap; margin-right:0.4rem;">{{ hg.label if hg else 'human action' }}</span>
                    {% if item.humanGate.short %}{{ item.humanGate.short }}{% elif item.humanGate.what %}{{ item.humanGate.what }}{% endif %}
                </td>
                <td style="font-weight:700; color:#166534;">{{ item.transitiveUnblocks + 1 }}</td>
                <td>{{ item.directUnblocks }}</td>
                <td style="text-align:left; font-size:0.92em;">
                    {% for dep in item.dependents | where("status", "open") %}<a href="/backlog/{{ dep.id }}/" title="{{ dep.title }}" style="color: var(--color-text-muted); text-decoration: none; font-variant-numeric: tabular-nums;">#{{ dep.num }}</a>{% if not loop.last %}, {% endif %}{% else %}<span style="color: var(--color-text-muted);">just this item</span>{% endfor %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>
    <p class="section-desc" style="margin-top:1rem; font-size:0.82em;"><strong>Frees</strong> counts the gated item plus the open items it gates once it's workable — a setup task with a high number is the highest-leverage thing you can personally unblock. <strong>Direct</strong> is how many items name this one as a <code>blockedBy</code> prerequisite. After you do the action, edit the item and remove its <code>humanGate</code> so it drops off this list and re-enters the agent-ready pool.</p>
    {% else %}
    <p>No human-only setup pending — every open item is agent-workable or blocked only by other backlog items.</p>
    {% endif %}
</section>
</div>{# /#panel-humansetup #}

<div id="panel-graph" role="tabpanel" aria-labelledby="tab-graph" hidden>
{# Dependency relationship graph — the `blockedBy` network as a diagram (#255). Nodes/edges/layers are
   computed deterministically in src/_data/backlogGraph.js (reusing the #254 leverage fields); the SVG is
   laid out + drawn by src/assets/js/backlog-graph.js. Only items that participate in an edge appear. #}
<section class="mb-12">
    <h2 class="section-title">Dependency graph <span class="count-badge" id="bg-count">{{ backlogGraph.nodes | length }} items</span></h2>
    <p class="section-desc">The <code>blockedBy</code> network as a diagram — an arrow points <strong>prerequisite&nbsp;&rarr;&nbsp;dependent</strong>, so work flows left to right and the leftmost nodes are the roots that gate everything downstream. Nodes are coloured by agent-readiness (<span style="color:#166534;font-weight:600;">ready</span> / <span style="color:#92400e;font-weight:600;">decision</span> / <span style="color:#475569;font-weight:600;">blocked</span>; <span style="color:#475569;font-weight:600;">muted</span> = already resolved/claimed) and sized by how much they unblock. Click any node to open its item. <strong>Open &amp; blockers</strong> shows <em>every</em> open item — those with prerequisites laid out in chains, the rest (no live dependency) as a standalone grid below the divider; <strong>All</strong> shows the full dependency network, resolved history included (so it can show fewer nodes than Open&nbsp;&amp;&nbsp;blockers, which also counts the standalone open items).</p>
    {% if backlogGraph.empty %}
    <p>No <code>blockedBy</code> edges yet — nothing to graph. As items declare prerequisites, the dependency network appears here.</p>
    {% else %}
    <div class="bg-legend" style="display:flex; gap:1.2rem; flex-wrap:wrap; align-items:center; margin-bottom:0.5rem; font-size:0.85em; color:var(--color-text-muted);">
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Tier A — an issue/idea whose every prerequisite is already resolved. An agent can start it now (but a large one — story ≥13 / epic — is beyond the batch pool)."><span style="width:14px;height:14px;border-radius:50%;background:#dcfce7;border:2px solid #16a34a;"></span><strong style="color:#166534;">Agent-ready</strong> — startable now</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Batchable — a Tier-A task or story ≤8; a points-budgeted batch packs from this pool. Shown with a detached green ring. A subset of agent-ready."><span style="position:relative; width:16px; height:16px; display:inline-flex; align-items:center; justify-content:center;"><span style="position:absolute; width:16px;height:16px;border-radius:50%;border:1.5px solid #16a34a;"></span><span style="width:9px;height:9px;border-radius:50%;background:#dcfce7;border:2px solid #16a34a;"></span></span><strong style="color:#166534;">Batchable</strong> — ready &amp; small (ring)</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Tier B — a decision. Ratify the call first, then the build it gates becomes agent-ready."><span style="width:14px;height:14px;border-radius:50%;background:#fef3c7;border:2px solid #d97706;"></span><strong style="color:#92400e;">Decision-ready</strong> — ratify, then build</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Tier C — an issue/idea that still has an open prerequisite. Clear its blocker(s) first."><span style="width:14px;height:14px;border-radius:50%;background:#f1f5f9;border:2px solid #94a3b8;"></span><strong style="color:#475569;">Not ready</strong> — has an open blocker</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Human-gated — held on a human-only step (deploy, credential, account/setup, feedback, or review) that nothing in the backlog resolves. Shown with a dashed orange ring + corner dot; hover the node for the exact step needed."><span style="position:relative; width:16px; height:16px; display:inline-flex; align-items:center; justify-content:center;"><span style="position:absolute; width:16px;height:16px;border-radius:50%;border:1.5px dashed #ea580c;"></span><span style="position:absolute; top:0; right:0; width:6px;height:6px;border-radius:50%;background:#ea580c;border:1px solid #fff;"></span><span style="width:9px;height:9px;border-radius:50%;background:#f1f5f9;border:2px solid #94a3b8;"></span></span><strong style="color:#9a3412;">Human step needed</strong> — setup/deploy/review (hover)</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Claimed — an agent is actively working it (status: active)."><span style="width:14px;height:14px;border-radius:50%;background:#dbeafe;border:2px solid #2563eb;"></span><strong style="color:#1e40af;">In progress</strong> — claimed</span>
        <span style="display:inline-flex; align-items:center; gap:0.35rem;" title="Done — kept in the graph (in All view) for dependency history."><span style="width:14px;height:14px;border-radius:50%;background:#f8fafc;border:2px solid #cbd5e1;"></span>Resolved</span>
        <span title="Node radius grows with the number of open items this one ultimately unblocks.">larger node = unblocks more</span>
    </div>
    <p class="section-desc" style="margin-top:0; margin-bottom:1rem; font-size:0.82em;">Colour = <strong>agent-readiness</strong>, the same deterministic tier as the Prioritisation tab: whether an agent could pick the item up right now. <em>Agent-ready</em> nodes with no incoming edge are the live frontier; a <em>Not-ready</em> node points back (left) to the open blocker it's waiting on.</p>
    {# Filter toggle (#257): "Open & blockers" trims fully-resolved chains to the live frontier — open/active
       nodes plus the still-open prerequisites gating them. Filter + re-layout happen client-side in
       src/assets/js/backlog-graph.js (no second graph model); the choice persists in localStorage. #}
    <div class="bg-filter" role="group" aria-label="Graph filter">
        <button type="button" data-bg-filter="live" class="is-active">Open &amp; blockers</button>
        <button type="button" data-bg-filter="all">All</button>
    </div>
    <div style="overflow-x:auto; border:1px solid var(--color-border); border-radius:8px; background:var(--color-surface, #fff);">
        <svg id="backlog-graph" role="img" aria-label="Dependency graph of backlog items linked by blockedBy edges, prerequisite to dependent" style="display:block;"></svg>
    </div>
    <script type="application/json" id="backlog-graph-data">{{ backlogGraph | dump | safe }}</script>
    {% endif %}
</section>
</div>{# /#panel-graph #}

<div id="panel-burndown" role="tabpanel" aria-labelledby="tab-burndown" hidden>
    <section class="mb-12">
        <h2 class="section-title">Burndown <span class="count-badge">{{ burndown.points.remaining }} pts left</span></h2>
        <p class="section-desc">Continuous-flow burndown in <strong>agile points</strong>, not item counts — scope grows as items are opened and falls as they're resolved. Points are summed once per item: a <code>story</code> carries its <code>size</code>, a <code>task</code> never does, a storied <code>epic</code> defers to its child stories, an unstoried <code>epic</code> carries its own — so nothing is double-counted. Resolution dates drive the completed line.</p>

        {% if burndown.empty %}
        <p>No sized items yet.</p>
        {% else %}
        <div class="bd-cards">
            <div class="bd-card"><div class="n">{{ burndown.points.total }}</div><div class="l">Total points</div></div>
            <div class="bd-card"><div class="n">{{ burndown.points.done }}</div><div class="l">Completed</div></div>
            <div class="bd-card"><div class="n">{{ burndown.points.remaining }}</div><div class="l">Remaining</div></div>
            <div class="bd-card"><div class="n">{{ burndown.counts.story }}</div><div class="l">Stories</div></div>
            <div class="bd-card"><div class="n">{{ burndown.counts.epic }}</div><div class="l">Epics</div></div>
            <div class="bd-card"><div class="n">{{ burndown.counts.task }}</div><div class="l">Tasks</div></div>
        </div>

        {% if burndown.diverging %}
        <div class="bd-callout diverging">
            <strong>Diverging</strong> — over the last {{ burndown.rates.windowDays }} days scope is opening at
            <strong>{{ burndown.rates.intake.week | round(1) }} pts/wk</strong> but completing at only
            <strong>{{ burndown.rates.completion.week | round(1) }} pts/wk</strong> (net
            {{ burndown.rates.net.week | round(1) }} pts/wk), so there is no projected clear date at the current pace.
            If intake froze today, the {{ burndown.points.remaining }} remaining points would clear around
            <strong>{{ burndown.clearDateFrozen }}</strong>.
        </div>
        {% else %}
        <div class="bd-callout converging">
            <strong>Converging</strong> — completing
            <strong>{{ burndown.rates.completion.week | round(1) }} pts/wk</strong> against intake of
            {{ burndown.rates.intake.week | round(1) }} pts/wk (net +{{ burndown.rates.net.week | round(1) }} pts/wk).
            Projected to clear around <strong>{{ burndown.clearDateNet }}</strong> if both rates hold
            ({{ burndown.clearDateFrozen }} if intake froze today).
        </div>
        {% endif %}

        <table class="bd-ratetable">
            <thead><tr><th>Burn rate (trailing {{ burndown.rates.windowDays }}d)</th><th>/ day</th><th>/ week</th><th>/ month</th></tr></thead>
            <tbody>
                <tr><td>Completion</td><td>{{ burndown.rates.completion.day | round(1) }}</td><td>{{ burndown.rates.completion.week | round(1) }}</td><td>{{ burndown.rates.completion.month | round(1) }}</td></tr>
                <tr><td>Intake</td><td>{{ burndown.rates.intake.day | round(1) }}</td><td>{{ burndown.rates.intake.week | round(1) }}</td><td>{{ burndown.rates.intake.month | round(1) }}</td></tr>
                <tr><td>Net</td><td>{{ burndown.rates.net.day | round(1) }}</td><td>{{ burndown.rates.net.week | round(1) }}</td><td>{{ burndown.rates.net.month | round(1) }}</td></tr>
            </tbody>
        </table>

        <div class="bd-gran" role="group" aria-label="Chart granularity">
            <button type="button" data-bd-gran="daily">Daily</button>
            <button type="button" data-bd-gran="weekly" class="is-active">Weekly</button>
            <button type="button" data-bd-gran="monthly">Monthly</button>
        </div>
        <div class="bd-chart-wrap">
            <svg id="bd-chart" viewBox="0 0 900 360" role="img" aria-label="Backlog burndown chart of remaining, scope and completed agile points over time, with future projection"></svg>
            <div class="bd-legend">
                <span><i style="border-color:#0ea5e9"></i>Scope (opened)</span>
                <span><i style="border-color:#16a34a"></i>Completed</span>
                <span><i style="border-color:#7c3aed"></i>Remaining</span>
                <span><i style="border-color:#7c3aed; border-top-style:dashed"></i>Projection (intake frozen)</span>
                {% if not burndown.diverging %}<span><i style="border-color:#475569; border-top-style:dotted"></i>Projection (intake continues)</span>{% endif %}
            </div>
        </div>
        <script type="application/json" id="burndown-data">{{ burndown | dump | safe }}</script>
        {% endif %}
    </section>
</div>{# /#panel-burndown #}

<script>
// Persist the open/closed state of the collapsible blurb + legends (open by default).
(function () {
    document.querySelectorAll('details.bk-collapse[data-persist]').forEach(function (d) {
        var key = 'backlog:collapse:' + d.dataset.persist;
        var saved = localStorage.getItem(key);
        if (saved === 'closed') d.open = false;
        else if (saved === 'open') d.open = true;
        d.addEventListener('toggle', function () {
            localStorage.setItem(key, d.open ? 'open' : 'closed');
        });
    });
})();
</script>
