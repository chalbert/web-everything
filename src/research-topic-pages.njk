---
pagination:
    data: researchTopics
    size: 1
    alias: topic
permalink: "research/{{ topic.id }}/"
layout: base.njk
eleventyComputed:
    title: "Research - {{ topic.title }}"
---

{% from "project-status.njk" import projectStatus %}

<div class="plug-detail-header">
    <div class="plug-detail-header-inner">
        <nav class="plug-breadcrumb">
            <a href="/research/" class="plug-crumb">Research</a>
            <svg class="plug-crumb-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            <span class="plug-crumb plug-crumb-current">{{ topic.title }}</span>
        </nav>
        <div class="plug-title-row">
            <h1 class="plug-title">{{ topic.title }}</h1>
            <div class="plug-status">
                {{ projectStatus(topic.status) }}
            </div>
        </div>
    </div>
</div>

<div class="container block-detail-page">
    <div class="block-body content">
        <div class="section-card">
            <p class="mb-4 text-slate-600" style="font-size: 1.1em; line-height: 1.6;">{{ topic.summary }}</p>

            {% if topic.tags %}
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
                {% for tag in topic.tags %}
                <span style="display: inline-block; padding: 0.15rem 0.6rem; border-radius: 9999px; background: var(--color-surface-alt, #f1f5f9); color: var(--color-text-muted, #64748b); font-size: 0.8em;">{{ tag }}</span>
                {% endfor %}
            </div>
            {% endif %}

            <p style="font-size: 0.85em; color: var(--color-text-muted, #94a3b8);">Opened: {{ topic.dateOpened }}</p>
        </div>

        <div class="section-card mt-8">
            {% include "research-descriptions/" + topic.id + ".njk" %}
        </div>

        {% if topic.relatedBlocks %}
        <div class="section-card mt-8">
            <h2>Related Blocks</h2>
            <div class="standards-grid">
                {% for blockId in topic.relatedBlocks %}
                    {% for block in blocks %}
                        {% if block.id == blockId %}
                <a href="/blocks/{{ block.id }}/" class="standard-card">
                    <div style="display: flex; justify-content: space-between; gap: 12px; margin-bottom: 0.75rem;">
                        <h4 style="margin: 0; font-size: 1.1em;">{{ block.name }}</h4>
                        <span style="white-space: nowrap; padding: 0.1rem 0.5rem; border-radius: 9999px; background: var(--color-surface-alt, #f1f5f9); font-size: 0.75em;">{{ block.type }}</span>
                    </div>
                    <p style="font-size: 0.85em; color: var(--color-text-muted, #64748b); margin: 0;">{{ block.summary }}</p>
                </a>
                        {% endif %}
                    {% endfor %}
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>
</div>
