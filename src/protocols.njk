---
layout: base.njk
title: Web Everything — Protocols
---

<section class="intro">
  <h1>Protocols</h1>
  <p>
    Conformance references that define <strong>what implementations must agree on</strong> so independent
    creators can interoperate. Each protocol is owned by a Web Project and lives inside its specification.
    Blocks ship code; protocols ship contracts.
  </p>
</section>

<section style="margin: 1.5rem 0 2rem;">
  <div style="display: flex; flex-wrap: wrap; gap: 2rem; align-items: flex-start;">
    <div>
      <h3 style="margin: 0 0 0.5rem; font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted);">Project</h3>
      <div id="filter-project" style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
        {% for p in projects %}
          {% set hit = false %}
          {% for proto in protocols %}{% if proto.ownedByProject == p.id %}{% set hit = true %}{% endif %}{% endfor %}
          {% if hit %}
          <label style="display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.25rem 0.6rem; border: 1px solid var(--color-border); border-radius: 9999px; font-size: 0.85em; cursor: pointer; background: var(--color-surface, #fff);">
            <input type="checkbox" data-filter="project" value="{{ p.id }}" checked style="margin: 0;">
            {{ p.name }}
          </label>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div>
      <h3 style="margin: 0 0 0.5rem; font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted);">Status</h3>
      <div id="filter-status" style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
        {% for status in ['concept', 'draft', 'experimental', 'active'] %}
          {% set hit = false %}
          {% for proto in protocols %}{% if proto.status == status %}{% set hit = true %}{% endif %}{% endfor %}
          {% if hit %}
          <label style="display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.25rem 0.6rem; border: 1px solid var(--color-border); border-radius: 9999px; font-size: 0.85em; cursor: pointer; background: var(--color-surface, #fff);">
            <input type="checkbox" data-filter="status" value="{{ status }}" checked style="margin: 0;">
            {{ status | title }}
          </label>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<div class="project-grid" id="protocol-grid">
  {% for proto in protocols %}
    {% set proj = None %}
    {% for p in projects %}{% if p.id == proto.ownedByProject %}{% set proj = p %}{% endif %}{% endfor %}
    <a href="/projects/{{ proto.ownedByProject }}/#{{ proto.anchor }}"
       class="project-card"
       data-project="{{ proto.ownedByProject }}"
       data-status="{{ proto.status }}"
       style="text-decoration: none; color: inherit; display: block;">
      <div class="project-header" style="margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;">
        <h3 class="project-title" style="margin: 0;">{{ proto.name }}</h3>
        <span style="padding: 0.1rem 0.5rem; border-radius: 9999px; background: {% if proto.status == 'concept' %}#fef3c7{% elif proto.status == 'draft' %}#dbeafe{% elif proto.status == 'experimental' %}#fde68a{% elif proto.status == 'active' %}#dcfce7{% else %}#f1f5f9{% endif %}; color: {% if proto.status == 'concept' %}#92400e{% elif proto.status == 'draft' %}#1e40af{% elif proto.status == 'experimental' %}#854d0e{% elif proto.status == 'active' %}#166534{% else %}#475569{% endif %}; font-size: 0.75em; font-weight: 600; white-space: nowrap;">{{ proto.status | title }}</span>
      </div>
      <p style="margin: 0 0 0.75rem 0; color: var(--color-text-muted); font-size: 0.9em;">{{ proto.summary }}</p>
      <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center;">
        <span style="display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.15rem 0.55rem; border-radius: 9999px; background: var(--color-surface-alt, #f1f5f9); color: var(--color-text-muted, #475569); font-size: 0.75em;">
          {% if proj and proj.isSvg %}<img src="{{ proj.icon }}" alt="" width="14" height="14" style="display: inline-block;">{% endif %}
          {{ proj.name if proj else proto.ownedByProject }}
        </span>
        {% if proto.realizesIntent %}
        <span style="display: inline-block; padding: 0.15rem 0.55rem; border-radius: 9999px; background: rgba(99,102,241,0.08); color: #4338ca; font-size: 0.75em;">Intent: {{ proto.realizesIntent }}</span>
        {% endif %}
      </div>
    </a>
  {% endfor %}
</div>

<p id="protocol-empty" style="display: none; text-align: center; color: var(--color-text-muted); margin: 2rem 0;">No protocols match the selected filters.</p>

<script>
(function () {
  var grid = document.getElementById('protocol-grid');
  var empty = document.getElementById('protocol-empty');
  var cards = Array.prototype.slice.call(grid.querySelectorAll('.project-card'));
  var checkboxes = Array.prototype.slice.call(document.querySelectorAll('input[type="checkbox"][data-filter]'));

  function apply() {
    var projects = checkboxes.filter(function (c) { return c.dataset.filter === 'project' && c.checked; }).map(function (c) { return c.value; });
    var statuses = checkboxes.filter(function (c) { return c.dataset.filter === 'status' && c.checked; }).map(function (c) { return c.value; });
    var visible = 0;
    cards.forEach(function (card) {
      var ok = projects.indexOf(card.dataset.project) !== -1 && statuses.indexOf(card.dataset.status) !== -1;
      card.style.display = ok ? '' : 'none';
      if (ok) visible++;
    });
    empty.style.display = visible === 0 ? '' : 'none';
  }

  checkboxes.forEach(function (c) { c.addEventListener('change', apply); });
})();
</script>
