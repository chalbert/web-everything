---
pagination:
    data: blocks
    size: 1
    alias: block
permalink: "blocks/{{ block.id }}/"
layout: base.njk
eleventyComputed:
    title: "Web Blocks - {{ block.name }}"
---

{% from "project-status.njk" import projectStatus %}

<div class="plug-detail-header">
    <div class="plug-detail-header-inner">
        <nav class="plug-breadcrumb">
            <a href="/projects/webblocks/" class="plug-crumb">Web Blocks</a>
            <svg class="plug-crumb-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            <span class="plug-crumb plug-crumb-current">{{ block.name }}</span>
        </nav>
        <div class="plug-title-row">
            <h1 class="plug-title">
                {{ block.name }}<sup class="plug-type-sup plug-type-global">{{ block.type }}</sup>
            </h1>
            <div class="plug-status">
                {{ projectStatus(block.status) }}
            </div>
        </div>
    </div>
</div>

<div class="container block-detail-page">
    <div class="block-body content">
        <div class="section-card">
            {% include "block-descriptions/" + block.id + ".njk" %}
        </div>

        {% if block.fuiDemo %}
        <div class="section-card mt-8">
            <h2>Live example</h2>
            {% fuiDemo block.fuiDemo.file, block.fuiDemo.title, block.fuiDemo.height %}
        </div>
        {% endif %}

        {% if block.technicalConfig %}
        <div class="section-card mt-8">
            <h2>Configure technical aspects</h2>
            <p class="mb-4">These are <strong>technical</strong> delivery settings (render strategy, transport, trait lazy-loading, chunk splitting) — never UX dimensions on the block, and never a Web Everything mandate. Explore the tradeoffs for this block in the embedded <a href="/intents/">Plateau</a> configurator; the cost preview (chunk graph + bytes/requests/hydration) updates as you change a setting. Use <em>Open full configurator&nbsp;↗</em> for the project-wide decision.</p>
            {% technicalConfigurator block.technicalConfig, block.technicalConfig.height %}
        </div>
        {% endif %}

        {% if block.implementsIntent %}
        <div class="section-card mt-8">
            <h2>Implements Intent</h2>
            {% for intent in intents %}
                {% if intent.id == block.implementsIntent %}
            <p class="mb-4">This block is a technical implementation of the <a href="/intents/{{ intent.id }}/">{{ intent.name }}</a> — {{ intent.summary | lower }}</p>
                {% if block.intentDimensions and intent.dimensions %}
            <p class="mb-2 text-slate-600">The values this block realizes for the intent's <a href="/intents/{{ intent.id }}/">configurable dimensions</a> (axes it does not declare defer to a composed block):</p>
            <table>
                <thead>
                    <tr><th>Dimension</th><th>Realized value</th><th>Axis</th></tr>
                </thead>
                <tbody>
                    {% for dimKey, dimValue in block.intentDimensions %}
                    <tr>
                        <td><code>{{ dimKey }}</code></td>
                        <td><code>{{ dimValue }}</code></td>
                        <td class="text-slate-600">{% if intent.dimensions[dimKey] %}{{ intent.dimensions[dimKey].description }}{% endif %}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
                {% endif %}
                {% endif %}
            {% endfor %}
        </div>
        {% endif %}

        {% if block.composesIntents %}
        <div class="section-card mt-8">
            <h2>Composes Intents</h2>
            <p class="mb-4 text-slate-600">This block is a <strong>composition manifest</strong> — it defers each behavior to the intent that owns it, rather than re-specifying them. It composes:</p>
            <ul class="list-disc pl-5">
            {% for composedId in block.composesIntents %}
                {% for intent in intents %}
                    {% if intent.id == composedId %}
                <li><a href="/intents/{{ intent.id }}/">{{ intent.name }}</a> — {{ intent.summary | lower }}</li>
                    {% endif %}
                {% endfor %}
            {% endfor %}
            </ul>
        </div>
        {% endif %}

        {% if block.traits %}
        <div class="section-card mt-8">
            <h2>Traits</h2>
            <p class="mb-6 text-slate-600">Composable behaviors loaded on-demand based on the active intent profile. Only the traits matching the application's chosen configuration are bundled.</p>
            <table>
                <thead>
                    <tr>
                        <th>Trait</th>
                        <th>Intent Dimension</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    {% for trait in block.traits %}
                    <tr>
                        <td><code>{{ trait.name }}</code></td>
                        <td>{% if trait.intentDimension %}<code>{{ trait.intentDimension }}</code>{% else %}&mdash;{% endif %}</td>
                        <td>{{ trait.description }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        {# Accessibility & Web Standards — the per-component realization SoT (#803/#826): one row per
           concern in block.webStandards → how this block satisfies it + a Reference link to the governing
           spec. Graceful absence mirrors fuiDemo/composesIntents (no field → no panel). The flexible
           {concern:{usage,reference}} bag (the realization SoT, #803) is rendered through the
           `webStandardsRows` filter (#828): the raw camelCase concern key is humanized (ariaCurrentStep →
           "aria-current step"), and rows are grouped into a fixed category order (ARIA & accessibility →
           CSS → Platform APIs & DOM) and sorted by label within each group. Display-only — the on-disk
           field shape is untouched; the raw key is preserved as a hover title for traceability. #}
        {% if block.webStandards %}
        {% set wsRows = block.webStandards | webStandardsRows %}
        <div class="section-card mt-8">
            <h2>Accessibility &amp; Web Standards</h2>
            <p class="mb-6 text-slate-600">The web-platform standards this block realizes — each concern names how the block satisfies it, with a link to the governing specification. Concerns are grouped by area and ordered for scanning.</p>
            <table>
                <thead>
                    <tr>
                        <th>Concern</th>
                        <th>Usage</th>
                        <th>Reference</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in wsRows %}
                    {% if loop.first or row.category != wsRows[loop.index0 - 1].category %}
                    <tr class="bg-slate-50"><th colspan="3" class="text-left font-semibold text-slate-700">{{ row.category }}</th></tr>
                    {% endif %}
                    <tr>
                        <td><code title="{{ row.concern }}">{{ row.label }}</code></td>
                        <td>{{ row.usage }}</td>
                        <td>{% if row.reference %}<a href="{{ row.reference }}" target="_blank" rel="noopener">Reference&nbsp;↗</a>{% else %}&mdash;{% endif %}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        {# Anatomy — the composition graph straight from the registries (#748): the dependency edges this
           block sits on, each piece linking to its own page so they're independently browsable. "Used by" is
           the reverse edge (every block whose dependsOn names this one) — the bidirectional graph. The
           interactive exploded / toggle-a-piece-off-to-watch-it-degrade view needs in-document live render
           and layers on once that lands (#786 mode C); this is the static, buildable-now half. #}
        {% set usedByBlocks = [] %}
        {% for other in blocks %}{% if block.id in (other.dependsOn or []) %}{% set usedByBlocks = (usedByBlocks.push(other), usedByBlocks) %}{% endif %}{% endfor %}
        {% if (block.dependsOn | length) or (usedByBlocks | length) %}
        <div class="section-card mt-8">
            <h2>Anatomy</h2>
            <p class="mb-6 text-slate-600">Every piece this block composes, each linking to its own page. Together with the <strong>Implements / Composes Intents</strong> and <strong>Traits</strong> sections above, this is the block's full composition graph — the minimize-lock-in / graceful-degradation surface. A live <em>toggle-a-piece-off</em> exploded view layers on once in-document render lands (<a href="/backlog/786-mode-c-fui-embed-sdk-gains-a-shadow-dom-in-document-render-m/">#786</a>).</p>
            {% if block.dependsOn | length %}
            <h3>Built on</h3>
            <p class="mb-2 text-slate-600">The blocks and capabilities this one composes — disable any and the block degrades to what remains.</p>
            <ul class="list-disc pl-5 mb-4">
                {% for dep in block.dependsOn %}
                {% if (blocks | selectattr("id", "equalto", dep) | list | length) %}
                <li><a href="/blocks/{{ dep }}/">{{ dep }}</a></li>
                {% else %}
                <li><code>{{ dep }}</code> <span class="text-slate-600">(capability)</span></li>
                {% endif %}
                {% endfor %}
            </ul>
            {% endif %}
            {% if usedByBlocks | length %}
            <h3>Used by</h3>
            <p class="mb-2 text-slate-600">Blocks that compose this one — the reverse dependency edge.</p>
            <ul class="list-disc pl-5">
                {% for u in usedByBlocks %}
                <li><a href="/blocks/{{ u.id }}/">{{ u.name }}</a></li>
                {% endfor %}
            </ul>
            {% endif %}
        </div>
        {% endif %}

        {% set blockCases = cases[block.id] %}
        {% if blockCases %}
        <div class="section-card mt-8">
            <h2 class="text-2xl font-bold mb-4">Web Cases</h2>
            <p class="mb-6 text-slate-600">Standardized scenarios for testing and documentation. These definitions are sourced directly from the conformance suite.</p>

            <div class="grid gap-8">
                {% for webCase in blockCases %}
                <div class="case-item border-l-4 border-slate-200 pl-4">
                    <h3 class="text-lg font-bold text-slate-900 mb-1">
                        <span class="text-slate-400 font-mono mr-2">#{{ loop.index }}</span>
                        {{ webCase.title }}
                    </h3>
                    <p class="text-slate-600 mb-3 text-sm leading-relaxed">{{ webCase.description }}</p>
                    <div class="case-code">
                        {% highlight "html" %}{{ webCase.code | safe }}{% endhighlight %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>
</div>
