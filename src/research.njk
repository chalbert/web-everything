---
layout: base.njk
title: Research & References
---

<section class="intro">
    <h1>Research & References</h1>
    <p>A curated collection of external standards, proposals, and ecosystem libraries that influence the architectural decisions of Web Everything.</p>
</section>

{% if researchTopics.length %}
<section style="margin-bottom: 3rem;">
    <h2 style="margin-bottom: 1rem;">Open Research Topics</h2>
    <p style="margin-bottom: 1.5rem; color: var(--color-text-muted); font-size: 0.9em;">Active investigations into design problems and architectural decisions.</p>
    <div class="project-grid">
        {% for topic in researchTopics %}
        <a href="/research/{{ topic.id }}/" class="project-card" style="text-decoration: none; color: inherit;">
            <div class="project-header" style="margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center;">
                <h3 class="project-title" style="margin: 0;">{{ topic.title }}</h3>
                <span style="padding: 0.1rem 0.5rem; border-radius: 9999px; background: {% if topic.status == 'open' %}#fef3c7{% elif topic.status == 'resolved' %}#dcfce7{% else %}#f1f5f9{% endif %}; color: {% if topic.status == 'open' %}#92400e{% elif topic.status == 'resolved' %}#166534{% else %}#64748b{% endif %}; font-size: 0.75em; font-weight: 600; white-space: nowrap;">{{ topic.status | title }}</span>
            </div>
            <p style="margin: 0 0 0.75rem 0; color: var(--color-text-muted); font-size: 0.9em;">{{ topic.summary }}</p>
            {% if topic.tags %}
            <div style="display: flex; gap: 0.35rem; flex-wrap: wrap;">
                {% for tag in topic.tags %}
                <span style="display: inline-block; padding: 0.1rem 0.5rem; border-radius: 9999px; background: var(--color-surface-alt, #f1f5f9); color: var(--color-text-muted, #64748b); font-size: 0.75em;">{{ tag }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </a>
        {% endfor %}
    </div>
</section>
{% endif %}

<h2 style="margin-bottom: 1rem;">External References</h2>
<div class="project-grid">
    {% for section in references %}
    <div class="project-card" style="display: block; height: auto;">
        <div class="project-header" style="margin-bottom: 1rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem;">
            <h2 class="project-title">{{ section.category }}</h2>
        </div>
        <p style="margin-bottom: 1.5rem; color: var(--color-text-muted); font-size: 0.9em;">{{ section.description }}</p>
        
        <ul style="list-style: none; padding: 0; margin: 0;">
            {% for link in section.links %}
            <li style="margin-bottom: 1rem;">
                <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" style="font-weight: 600; text-decoration: none; color: var(--color-primary); display: flex; align-items: center; gap: 0.5rem;">
                    {{ link.title }}
                    <svg style="width: 14px; height: 14px; opacity: 0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
                {% if link.context %}
                <p style="margin: 0.25rem 0 0 0; font-size: 0.85em; color: var(--color-text-muted);">{{ link.context }}</p>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </div>
    {% endfor %}
</div>
