<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Web Everything") }}</title>
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/prism-theme.css">
</head>
<body>
    {#- Dogfoods our own nav:list spec: the link whose href is a prefix of page.url
        gets aria-current="page" (prefix, so a section link stays current on its child
        pages), styled by weight+border — never colour alone (WCAG 1.4.1). -#}
    {% macro weNavLink(href, label) %}
        {%- set isActive = page.url and page.url.startsWith(href) -%}
        <a href="{{ href }}" class="nav-link{% if isActive %} active{% endif %}"{% if isActive %} aria-current="page"{% endif %}>{{ label }}</a>
    {%- endmacro %}
    <header class="site-header">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="/" class="site-title">
                <img src="/assets/logo.svg" alt="Web Everything Logo" width="32" height="32">
                Web Everything
            </a>
            <p class="site-tagline" style="margin: 0; padding-left: 1rem; border-left: 1px solid var(--color-border, #e2e8f0); line-height: 1.2; position: relative; top: 2px;">Defining the missing standards for the modern web.</p>
        </div>
        <div class="header-controls">
            <button id="nav-toggle" class="nav-toggle header-icon" aria-label="Menu" aria-controls="site-nav" aria-expanded="false">
                <svg class="nav-toggle-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                <svg class="nav-toggle-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            <nav id="site-nav" class="site-nav" aria-label="Main">
                <!-- W3C APG Disclosure Navigation (#645, conform-to ref for #644).
                     Each section head is a real <button aria-expanded aria-controls>
                     disclosing its own link panel. Baseline (no JS): :hover/:focus-within
                     reveals the panel via CSS. Enhanced (reveal-nav.js): click toggles
                     aria-expanded, Esc + outside-click dismiss, focus returns to the head.
                     The in-panel group-label is redundant (the head button stands in) and
                     stays hidden; on mobile the sections render as an inline accordion. -->
                <div class="nav-menu">
                    <!-- Catalogs: browse the standards -->
                    <div class="nav-menu-section">
                        <button type="button" class="nav-menu-head" aria-expanded="false" aria-controls="nav-panel-standards">Standards</button>
                        <div class="nav-menu-panel" id="nav-panel-standards">
                            <div class="nav-group">
                                <span class="nav-group-label">Standards</span>
                                <div class="nav-group-links">
                                    {{ weNavLink("/intents/", "Intents") }}
                                    {{ weNavLink("/blocks/", "Blocks") }}
                                    {{ weNavLink("/capabilities/", "Capabilities") }}
                                    {{ weNavLink("/protocols/", "Protocols") }}
                                    {{ weNavLink("/presets/", "Presets") }}
                                    {{ weNavLink("/semantics/", "Semantics") }}
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Evidence: explore the standards in action -->
                    <div class="nav-menu-section">
                        <button type="button" class="nav-menu-head" aria-expanded="false" aria-controls="nav-panel-explore">Explore</button>
                        <div class="nav-menu-panel" id="nav-panel-explore">
                            <div class="nav-group">
                                <span class="nav-group-label">Explore</span>
                                <div class="nav-group-links">
                                    {{ weNavLink("/demos/", "Demos") }}
                                    {{ weNavLink("/validation-rules/", "Validation") }}
                                    {{ weNavLink("/research/", "Research") }}
                                    {{ weNavLink("/backlog/", "Backlog") }}
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- About the project -->
                    <div class="nav-menu-section">
                        <button type="button" class="nav-menu-head" aria-expanded="false" aria-controls="nav-panel-about">About</button>
                        <div class="nav-menu-panel" id="nav-panel-about">
                            <div class="nav-group">
                                <span class="nav-group-label">About</span>
                                <div class="nav-group-links">
                                    {{ weNavLink("/mission/", "Mission") }}
                                    {{ weNavLink("/governance/", "Governance") }}
                                    {{ weNavLink("/author/", "Author") }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
            <a href="https://github.com/chalbert/webeverything" class="header-icon" aria-label="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            </a>
            <button id="claude-panel-toggle" class="header-icon" aria-label="Spec Explorer" title="Spec Explorer">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path><circle cx="12" cy="10" r="1" fill="currentColor" stroke="none"></circle><circle cx="8" cy="10" r="1" fill="currentColor" stroke="none"></circle><circle cx="16" cy="10" r="1" fill="currentColor" stroke="none"></circle></svg>
            </button>
        </div>
    </header>

    <main class="{{ mainClass }}">
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <p>&copy; 2026 Web Everything. No cookies were used. | <a href="https://patreon.com/" style="color: inherit; text-decoration: underline; display: inline-flex; align-items: center; gap: 4px;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg> Support this project</a></p>

    <script src="/assets/js/copy-code.js"></script>
    <script src="/assets/js/mode-selector.js"></script>
    <script src="/assets/js/format-selector.js"></script>
    <script src="/assets/js/reveal-nav.js"></script>
    </footer>

    <!-- Mobile nav toggle (no effect on desktop — toggle is hidden there) -->
    <script>
    (function() {
        var header = document.querySelector('.site-header');
        var toggle = document.getElementById('nav-toggle');
        var nav = document.getElementById('site-nav');
        if (!header || !toggle || !nav) return;

        function setOpen(open) {
            header.classList.toggle('nav-open', open);
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }

        toggle.addEventListener('click', function() {
            setOpen(!header.classList.contains('nav-open'));
        });
        // Tapping a link navigates away — collapse the menu first.
        nav.addEventListener('click', function(e) {
            if (e.target.closest('a')) setOpen(false);
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') setOpen(false);
        });
        // Tap outside the open menu to dismiss.
        document.addEventListener('click', function(e) {
            if (header.classList.contains('nav-open') &&
                !nav.contains(e.target) && !toggle.contains(e.target)) {
                setOpen(false);
            }
        });
        // Returning to a desktop width hides the toggle; clear any open state.
        window.addEventListener('resize', function() {
            if (window.innerWidth > 940) setOpen(false);
        });
    })();
    </script>

    <!-- Spec Explorer side panel (dev only — loads from Vite dev server) -->
    <div id="claude-panel" class="claude-panel" aria-hidden="true">
        <div id="claude-panel-resizer" class="claude-panel-resizer" role="separator" aria-orientation="vertical" aria-label="Resize Spec Explorer"></div>
        <iframe id="claude-panel-frame" class="claude-panel-frame"></iframe>
    </div>

    <script>
    (function() {
        var toggle = document.getElementById('claude-panel-toggle');
        var panel = document.getElementById('claude-panel');
        var frame = document.getElementById('claude-panel-frame');
        var resizer = document.getElementById('claude-panel-resizer');
        var loaded = false;
        var pendingSelection = null;

        // ── Panel width (drag-resizable, persisted) ───────────
        var PANEL_WIDTH_KEY = 'claude-panel-width';
        var MIN_PANEL_WIDTH = 320;
        function maxPanelWidth() {
            // Leave at least 360px for page content.
            return Math.max(MIN_PANEL_WIDTH, window.innerWidth - 360);
        }
        function clampPanelWidth(w) {
            return Math.min(Math.max(w, MIN_PANEL_WIDTH), maxPanelWidth());
        }
        function setPanelWidth(w, persist) {
            w = clampPanelWidth(w);
            document.documentElement.style.setProperty('--panel-width', w + 'px');
            if (persist) {
                try { localStorage.setItem(PANEL_WIDTH_KEY, String(w)); } catch (e) {}
            }
            return w;
        }
        // Restore saved width before the panel can paint at the default.
        var savedWidth = null;
        try { savedWidth = parseInt(localStorage.getItem(PANEL_WIDTH_KEY), 10); } catch (e) {}
        if (savedWidth && !isNaN(savedWidth)) setPanelWidth(savedWidth, false);

        // Drag to resize from the left edge.
        if (resizer) {
            var startX = 0, startW = 0;
            function onMove(e) {
                // Panel grows as the pointer moves left (toward smaller clientX).
                setPanelWidth(startW + (startX - e.clientX), true);
            }
            function onUp() {
                document.removeEventListener('mousemove', onMove);
                document.removeEventListener('mouseup', onUp);
                document.body.classList.remove('panel-resizing');
                resizer.classList.remove('dragging');
            }
            resizer.addEventListener('mousedown', function(e) {
                e.preventDefault();
                startX = e.clientX;
                startW = panel.getBoundingClientRect().width;
                document.body.classList.add('panel-resizing');
                resizer.classList.add('dragging');
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
            });
        }
        // Keep within bounds if the window shrinks.
        window.addEventListener('resize', function() {
            if (savedWidth || document.documentElement.style.getPropertyValue('--panel-width')) {
                setPanelWidth(panel.getBoundingClientRect().width, false);
            }
        });

        // ── Header height → CSS var ───────────────────────────
        // The site header wraps/grows as nav changes, so the panel can't
        // assume a fixed offset. Measure it and expose --header-height so the
        // panel's `top`/`height` track the real header and its own header bar
        // never hides behind the sticky site header.
        var header = document.querySelector('.site-header');
        function syncHeaderHeight() {
            if (!header) return;
            document.documentElement.style.setProperty(
                '--header-height', header.offsetHeight + 'px'
            );
        }
        syncHeaderHeight();
        window.addEventListener('resize', syncHeaderHeight);
        if (window.ResizeObserver && header) {
            new ResizeObserver(syncHeaderHeight).observe(header);
        }

        function open() {
            if (!loaded) {
                // Pass the host page's path so the panel scopes its session +
                // transcript per page (navigate between specs → each spec keeps
                // its own agent conversation).
                frame.src = '/demos/dev-panel.html#page=' + encodeURIComponent(location.pathname);
                loaded = true;
            }
            panel.classList.add('open');
            panel.setAttribute('aria-hidden', 'false');
            document.body.classList.add('panel-open');
            toggle.classList.add('active');
            sessionStorage.setItem('claude-panel-open', '1');

            // Send pending selection once iframe is ready
            if (pendingSelection) {
                sendSelectionWhenReady(pendingSelection);
            }
        }

        function close() {
            panel.classList.remove('open');
            panel.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('panel-open');
            toggle.classList.remove('active');
            sessionStorage.removeItem('claude-panel-open');
        }

        // Restore panel state from previous page
        if (sessionStorage.getItem('claude-panel-open')) {
            open();
        }

        // ── Selection capture ──────────────────────────────
        // Capture the text selection from the parent page BEFORE
        // the click clears it, then forward it to the iframe.

        function getSelectionContext() {
            var sel = window.getSelection();
            var text = sel ? sel.toString().trim() : '';
            if (!text) return null;

            // Find nearest heading for section context
            var node = sel.anchorNode;
            var heading = '';
            while (node && node !== document.body) {
                if (node.nodeType === 1) {
                    var prev = node.previousElementSibling;
                    while (prev) {
                        if (/^H[1-6]$/.test(prev.tagName)) {
                            heading = prev.textContent.trim();
                            break;
                        }
                        prev = prev.previousElementSibling;
                    }
                    if (heading) break;
                    // Also check if current node IS a heading parent
                    var h = node.closest && node.closest('section, article, div');
                    if (h) {
                        var hEl = h.querySelector('h1, h2, h3, h4, h5, h6');
                        if (hEl) {
                            heading = hEl.textContent.trim();
                            break;
                        }
                    }
                }
                node = node.parentNode;
            }

            // Map URL path to source file for Claude Code
            var path = window.location.pathname.replace(/\/$/, '');
            var parts = path.split('/').filter(Boolean);
            var sourceFile = null;
            if (parts[0] === 'blocks' && parts[1]) {
                sourceFile = 'src/_includes/block-descriptions/' + parts[1] + '.njk';
            } else if (parts[0] === 'plugs' && parts[1]) {
                sourceFile = 'src/_includes/plug-descriptions/' + parts[1] + '.njk';
            } else if (parts[0] === 'research' && parts[1]) {
                sourceFile = 'src/_includes/research-descriptions/' + parts[1] + '.njk';
            } else if (parts[0] === 'demos' && parts[1]) {
                sourceFile = 'demos/' + parts[1] + '.html';
            } else if (parts[0] === 'projects' && parts[1]) {
                sourceFile = 'src/_includes/project-descriptions/' + parts[1] + '.njk';
            }

            return {
                text: text,
                page: window.location.pathname,
                title: document.title,
                heading: heading,
                sourceFile: sourceFile
            };
        }

        // Capture selection on mousedown (before click clears it)
        var capturedSelection = null;
        toggle.addEventListener('mousedown', function() {
            capturedSelection = getSelectionContext();
        });

        function sendSelectionWhenReady(ctx) {
            // If iframe not loaded yet, wait for it
            if (!frame.contentWindow) {
                pendingSelection = ctx;
                return;
            }
            frame.contentWindow.postMessage({
                type: 'selection-context',
                context: ctx
            }, '*');
            pendingSelection = null;
        }

        toggle.addEventListener('click', function() {
            if (panel.classList.contains('open')) {
                close();
            } else {
                // Send selection if we captured one
                if (capturedSelection) {
                    pendingSelection = capturedSelection;
                    capturedSelection = null;
                }
                open();
            }
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && panel.classList.contains('open')) close();
        });

        // When iframe signals it's ready, send any pending selection
        window.addEventListener('message', function(e) {
            if (e.data && e.data.type === 'dev-panel-ready' && pendingSelection) {
                sendSelectionWhenReady(pendingSelection);
            }
        });

        // ── Browser selection bridge ──────────────────────────
        // On mouseup, if there's a text selection:
        //   1. Write to .browser-selection.json (for Claude Code in VSCode)
        //   2. Send to dev panel iframe if open (for Spec Explorer chat)
        var selectionTimer = null;
        document.addEventListener('mouseup', function() {
            clearTimeout(selectionTimer);
            selectionTimer = setTimeout(function() {
                var ctx = getSelectionContext();
                if (ctx) {
                    // File bridge for Claude Code
                    fetch('/__dev-panel/selection', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(ctx)
                    }).catch(function() {});

                    // Forward to open dev panel iframe
                    if (panel.classList.contains('open') && frame.contentWindow) {
                        frame.contentWindow.postMessage({
                            type: 'selection-context',
                            context: ctx
                        }, '*');
                    }
                }
            }, 150);
        });
    })();
    </script>
</body>
</html>
