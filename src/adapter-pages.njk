---
pagination:
    data: collections.flatAdapters
    size: 1
    addAllPagesToCollections: true
    alias: adapter
permalink: "adapters/{{ adapter.id }}/"
layout: base.njk
eleventyComputed:
    title: "Web Adapters - {{ adapter.name }}"
---

{% from "project-status.njk" import projectStatus %}
{% from "we-component.njk" import weCard %}

<div class="plug-detail-header">
    <div class="plug-detail-header-inner">
        <nav class="plug-breadcrumb">
            <a href="/projects/webadapters/" class="plug-crumb">Web Adapters</a>
            <svg class="plug-crumb-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            <a href="/projects/webadapters/#{{ adapter.category }}" class="plug-crumb">{{ adapter.categoryTitle }}</a>
            <svg class="plug-crumb-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            <span class="plug-crumb plug-crumb-current">{{ adapter.name }}</span>
        </nav>
        <div class="plug-title-row">
            <h1 class="plug-title">{{ adapter.name }}</h1>
            <div class="plug-status">
                {{ projectStatus(adapter.status) }}
            </div>
        </div>
    </div>
</div>

<div class="container block-detail-page">
    <div class="block-body content">
        {#- #2106: convert the section-card to the #2098 weCard SSR primitive. The body is captured via set
            so the include output is available as a string for the macro. The className preserves the
            `.section-card` chrome that the prior frame carried. -#}
        {%- set _adapterBody %}{% include "adapter-descriptions/" + adapter.id + ".njk" %}{% endset -%}
        {{ weCard("", _adapterBody, "", "section-card") }}
    </div>
</div>
