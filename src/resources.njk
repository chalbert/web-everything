---
layout: base.njk
title: Web Everything — Resources
---

<section class="intro">
  <h1>Resources</h1>
  <p>
    Resources are <strong>standards for the data-access layer</strong> — caching, retention, clients, and
    middleware policies expressed declaratively. Each resource below links to its full specification.
  </p>
</section>

<div class="project-grid">
  {% for resource in resources %}
  {# #1870 (#1820 Fork 1a): <we-card> frame + status → <we-badge>; the anchor's own frame is stripped by
     `.project-card:has(> we-card)` in style.css so the card is the sole frame.
     Status vocab: active→success, draft→info, concept→warning, else→neutral. #}
  {% set statusTone = 'success' if resource.status == 'active' else ('info' if resource.status == 'draft' else ('warning' if resource.status == 'concept' else 'neutral')) %}
  <a href="/resources/{{ resource.id }}/"
     class="project-card"
     style="text-decoration: none; color: inherit; display: block;">
    <we-card>
      <div class="project-header" style="margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;">
        <h3 class="project-title" style="margin: 0;">{{ resource.name }}</h3>
        <we-badge tone="{{ statusTone }}">{{ resource.status | title }}</we-badge>
      </div>
      <p style="margin: 0; color: var(--color-text-muted); font-size: 0.9em;">{{ resource.summary | safe }}</p>
    </we-card>
  </a>
  {% endfor %}
</div>
