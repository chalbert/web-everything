<Project Sdk="Microsoft.NET.Sdk">

  <!--
    The #506 conformance runner's .NET *subprocess target* (backlog #549, slice 3 of #507).

    This console host compiles the BYTE-LOCKED generated origin (#548) AS-IS — OriginCore.cs +
    GeneratedMaaSOrigin.cs from generation/__goldens__/csharp/ — and drives it against the SAME
    golden.json the JS reference is driven against. Compiling the generated source here is itself the
    point: a string-match snapshot proves the bytes were emitted; THIS proves they execute. Any compile
    error or vector divergence surfaced here is a real #548 generation finding, not a harness bug.

    Run by `npm run check:maas-conformance` (an opt-in suite kept OUT of the default gate — #549 fork 1,
    option B), only when a capable `dotnet` toolchain is detected; skipped-with-notice otherwise.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>MaasConformanceHost</AssemblyName>
    <RootNamespace>FrontierUI.Maas.ConformanceHost</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- DO NOT EDIT these — they are @generated by `npm run gen:maas-origin` (#548). Compiled verbatim. -->
    <Compile Include="../../generation/__goldens__/csharp/OriginCore.cs" />
    <Compile Include="../../generation/__goldens__/csharp/GeneratedMaaSOrigin.cs" />
  </ItemGroup>

</Project>
