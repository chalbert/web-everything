# Parcel build cache (trait-enforcer #787 conformance harness)
.parcel-cache/

# Build sourcemaps (emitted alongside compiled output, never committed)
*.js.map
*.d.ts.map

# Publish-built compiled output emitted next to sources in package planes (#2085)
# — these packages ship .ts sources directly (contracts/package.json files: ['*.ts'])
contracts/**/*.js
contracts/**/*.d.ts
capability-manifest/**/*.js
capability-manifest/**/*.d.ts
error-summary/**/*.js
error-summary/**/*.d.ts
commitment-policy/**/*.js
commitment-policy/**/*.d.ts
.claude/lane-ports.json
# Delivery-agent learnings drop-box (#2614) — transient per-session capture (like claims.json). Agents
# append generalized-lesson entries during a session; the /closing-session sweep consumes it at close. Never
# committed — it holds pre-vetting, pre-dedup entries that the sweep + red-team curate before anything lands.
.conveyor/learnings/
# Per-session runtime bookkeeping (TTL'd, machine-local) — tooling recreates on demand (#952).
# SoT relocated to skills-src/ (#2266), so ignore the real path; capacity.json is durable calibration → stays tracked.
skills-src/batch-backlog-items/claims.json
skills-src/batch-backlog-items/queued.json
skills-src/batch-backlog-items/reservations.json
skills-src/batch-backlog-items/prepare-hold.json
skills-src/batch-backlog-items/id-ledger.json
# Review-escalation park-age clock (#2262) — local, machine-scoped, safe to lose (a PR just re-parks fresh)
# Both the built skill dir and the skills-src/ source dir the drain writes from (the source path leaked to the primary).
.claude/skills/drain/review-park-state.json
skills-src/drain/review-park-state.json
# First-drain-sighting manifest baseline (#2414) — same machine-scoped, safe-to-lose cache as the park-age
# clock above, and same skills-src/ source-path leak. Untracked → dirtied the daemon clone every pass, firing a
# false "recovering from interrupted pass" reset; ignoring it also lets the tamper baseline persist cross-pass.
.claude/skills/drain/review-baseline-state.json
skills-src/drain/review-baseline-state.json
