{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "_site/js",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      // #449 (per #606): plugs is FUI's impl; WE consumes it as a no-leakage client via the
      // `@frontierui/plugs` package, dev-time-resolved to the sibling FUI source (mirrors FUI's
      // proven `@webeverything/*` → `../webeverything` sibling-alias). Deep-subpath form so block
      // runtime imports (e.g. `@frontierui/plugs/webbehaviors/CustomAttribute`) resolve directly.
      "@frontierui/plugs": ["../frontierui/plugs/index.ts"],
      "@frontierui/plugs/*": ["../frontierui/plugs/*"],
      // #1910: the webtheme runtime relocated to fui:webtheme (#1907, per #1282). WE's remaining runtime
      // consumer (the reproduction-parity harness) imports it via `@frontierui/webtheme`; WE keeps only the
      // contract (`webtheme/contract.ts`) + vectors. Same dev-time sibling-source resolution as plugs.
      "@frontierui/webtheme": ["../frontierui/webtheme/index.ts"],
      "@frontierui/webtheme/*": ["../frontierui/webtheme/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/plateau"]
}
