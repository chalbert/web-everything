{
  "name": "web-everything",
  "version": "1.0.0",
  "description": "Web Everything - Grouping standards for better web library standardization",
  "customElements": "custom-elements.json",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "concurrently --restart-tries -1 --restart-after 1500 --names DOCS,DEMO,ACTIVE --prefix-colors blue,magenta,green \"npx @11ty/eleventy --serve --port=${WE_ELEVENTY_PORT:-8080} --quiet\" \"vite --port ${WE_VITE_PORT:-3000}\" \"node scripts/dev/active-progress-watch.mjs\"",
    "dev:docs": "eleventy --serve --port=${WE_ELEVENTY_PORT:-8080} --quiet",
    "dev:vite": "vite --port ${WE_VITE_PORT:-3000}",
    "dev:active-progress": "node scripts/dev/active-progress-watch.mjs",
    "build": "npm run build:docs && npm run build:demo",
    "build:docs": "eleventy",
    "build:check": "eleventy --output=/tmp/we-build-check --quiet",
    "verify": "vitest run && npm run check:cold-start && npm run build:check",
    "build:demo": "vite build",
    "check:cold-start": "node scripts/dev/check-cold-start.mjs",
    "start": "npm run dev",
    "clean": "rm -rf _site",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "playwright test",
    "test:e2e": "playwright test --project=chromium",
    "test:smoke": "playwright test --project=chromium tests/smoke",
    "test:a11y": "playwright test --project=chromium tests/a11y",
    "regression": "node scripts/dev/regression.mjs",
    "check:visual": "playwright test --project=chromium tests/visual",
    "check:visual:update": "playwright test --project=chromium tests/visual --update-snapshots",
    "check:visual:guard": "node scripts/check-visual-baseline-update.mjs --staged",
    "visual:review": "node scripts/dev/visual-baseline-review.mjs",
    "check:render": "node scripts/dev/render-check.mjs",
    "test:interaction": "playwright test --project=interaction",
    "test:coverage": "vitest run --coverage",
    "gen:inventory": "node scripts/gen-inventory.mjs",
    "gen:reference-index": "node scripts/gen-reference-index.mjs",
    "sweep:references": "node scripts/sweep-reference-liveness.mjs",
    "route:references": "node scripts/route-reference-remediation.mjs",
    "check:axis-vacancy": "node scripts/check-axis-vacancy.mjs",
    "pin:references": "node scripts/pin-reference-snapshots.mjs",
    "gen:maas-openapi": "node scripts/gen-maas-openapi.mjs",
    "check:standards": "node scripts/check-standards.mjs",
    "check:statute": "node scripts/check-statute.mjs",
    "check:backlog-workflow": "node scripts/check-backlog-workflow.mjs",
    "check:memory": "node scripts/check-memory.mjs",
    "check:memory-freshness": "node scripts/check-memory-freshness.mjs",
    "reflect": "node scripts/memory-reflect.mjs",
    "check:item": "node scripts/check-backlog-item.mjs",
    "check:app-conformance": "node scripts/check-app-conformance.mjs",
    "check:demos": "node scripts/check-demos.mjs",
    "check:fresh": "node scripts/dev/check-fresh.mjs",
    "ingest:component": "node scripts/ingest-adapter/cli.mjs",
    "check:validation-adherence": "vitest run capability-manifest/__tests__/check.test.ts",
    "validation:see": "node scripts/validation-normalize/live-config.mjs",
    "check:readiness": "node scripts/check-readiness.mjs",
    "check:health": "node scripts/audit-backlog-health.mjs",
    "lint:locus": "node scripts/lint-locus-prefix.mjs --staged",
    "fix:readiness": "node scripts/check-readiness.mjs --apply",
    "propose:readiness": "node scripts/propose-readiness.mjs",
    "normalize:graduated": "node scripts/normalize-graduated.mjs",
    "autofix": "node scripts/conformance-autofix.mjs",
    "parity:score": "node scripts/parity-conformance.mjs",
    "parity:check": "node scripts/parity-conformance.mjs --check",
    "grammar:score": "node scripts/grammar-scorecard.mjs",
    "grammar:check": "node scripts/grammar-scorecard.mjs --check",
    "design-refs": "node scripts/design-refs.mjs",
    "design-refs:frontier": "node scripts/design-refs/frontier.mjs",
    "gen:wrapper": "node scripts/gen-wrapper/cli.mjs",
    "gen:cem": "node scripts/gen-cem.mjs",
    "mine:corpus": "node scripts/mine-golden-corpus.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.2.0",
    "@axe-core/playwright": "^4.11.3",
    "@parcel/config-default": "^2.16.4",
    "@parcel/core": "^2.16.4",
    "@parcel/plugin": "^2.16.4",
    "@playwright/test": "^1.40.0",
    "@vitest/coverage-v8": "^1.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.21.5",
    "happy-dom": "^12.10.0",
    "urlpattern-polyfill": "^10.1.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "webpack": "^5.107.2",
    "wrangler": "^4.106.0"
  },
  "keywords": [
    "web-standards",
    "web-components",
    "polylfill",
    "dependency-injection"
  ],
  "author": "Web Everything Project",
  "license": "MIT",
  "dependencies": {
    "detect-gpu": "^5.0.70",
    "typescript": "^5.9.3",
    "web-features": "^3.30.0"
  }
}
