{
  "name": "web-everything",
  "version": "1.0.0",
  "description": "Web Everything - Grouping standards for better web library standardization",
  "customElements": "custom-elements.json",
  "scripts": {
    "dev": "concurrently --kill-others --names DOCS,DEMO --prefix-colors blue,magenta \"npx @11ty/eleventy --serve --port=8080 --quiet\" \"vite --port 3000\"",
    "dev:docs": "eleventy --serve --port=8080 --quiet",
    "dev:vite": "vite --port 3000",
    "build": "npm run build:docs && npm run build:demo",
    "build:docs": "eleventy",
    "build:check": "eleventy --output=/tmp/we-build-check --quiet",
    "verify": "vitest run && npm run build:check",
    "build:demo": "vite build",
    "start": "npm run dev",
    "clean": "rm -rf _site",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "playwright test",
    "test:coverage": "vitest run --coverage",
    "build:plugs": "tsc -p tsconfig.plugs.json",
    "gen:inventory": "node scripts/gen-inventory.mjs",
    "gen:reference-index": "node scripts/gen-reference-index.mjs",
    "gen:maas-openapi": "node scripts/gen-maas-openapi.mjs",
    "gen:maas-conformance": "node scripts/gen-maas-conformance.mjs",
    "check:maas-conformance": "node scripts/check-maas-conformance.mjs",
    "check:standards": "node scripts/check-standards.mjs",
    "check:app-conformance": "node scripts/check-app-conformance.mjs",
    "check:demos": "node scripts/check-demos.mjs",
    "check:validation-adherence": "vitest run capability-manifest/__tests__/check.test.ts",
    "validation:see": "node scripts/validation-normalize/live-config.mjs",
    "check:readiness": "node scripts/check-readiness.mjs",
    "check:health": "node scripts/audit-backlog-health.mjs",
    "fix:readiness": "node scripts/check-readiness.mjs --apply",
    "propose:readiness": "node scripts/propose-readiness.mjs",
    "normalize:graduated": "node scripts/normalize-graduated.mjs",
    "autofix": "node scripts/conformance-autofix.mjs",
    "design-refs": "node scripts/design-refs.mjs",
    "design-refs:frontier": "node scripts/design-refs/frontier.mjs",
    "gen:maas-origin": "node scripts/gen-maas-origin.mjs",
    "gen:wrapper": "node scripts/gen-wrapper/cli.mjs",
    "gen:cem": "node scripts/gen-cem.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.2.0",
    "@axe-core/playwright": "^4.11.3",
    "@parcel/config-default": "^2.16.4",
    "@parcel/core": "^2.16.4",
    "@parcel/plugin": "^2.16.4",
    "@playwright/test": "^1.40.0",
    "@vitest/coverage-v8": "^1.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.21.5",
    "happy-dom": "^12.10.0",
    "urlpattern-polyfill": "^10.1.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "webpack": "^5.107.2"
  },
  "keywords": [
    "web-standards",
    "web-components",
    "polylfill",
    "dependency-injection"
  ],
  "author": "Web Everything Project",
  "license": "MIT",
  "dependencies": {
    "detect-gpu": "^5.0.70",
    "typescript": "^5.9.3",
    "web-features": "^3.30.0"
  }
}
