#!/usr/bin/env sh
# #1574 gap (2) — locus-prefix pre-commit backstop. The #883 stack guards the Edit/Write tools (the
# PreToolUse `--pre` hook) and the backlog.mjs CLI write path (#1574 gap 1), but a `cat >>` / heredoc
# body-append still reaches disk unguarded. This hook runs the SAME staged sweep on every commit, so a
# bare code-path ref in a staged backlog/*.md or reports/*.md is caught here — regardless of HOW it landed —
# rather than at check:standards close-out. `lint:locus` (= lint-locus-prefix.mjs --staged) exits 2 on a
# finding, which blocks the commit. Wired via `core.hooksPath .githooks` (set by the `prepare` npm script).
#
# IMPORTANT: each gate must fail-fast to preserve its own exit code — in sh, the script exits with the
# last command's exit code, so sequencing without fail-fast silently swallows earlier failures. Use
# `|| exit $?` after each gate so the first failure stops the hook and propagates the right exit code.
npm run --silent lint:locus || exit $?

# #2179 — AI visual-baseline gate. Blocks a bare snapshot commit (PNG files in *-snapshots/ dirs)
# that lacks a corresponding approved AI verdict in tests/visual/verdicts/.
# WORKFLOW: check:visual → visual-baseline-review.mjs → approve verdict → check:visual:update → commit.
node scripts/check-visual-baseline-update.mjs --staged
