# scripts/auth-capture/.env.example — template for the managed-inbox auth-capture helper (#611).
# Copy to `scripts/auth-capture/.env` (gitignored by the repo-wide `.env` rule) and fill what your tier
# needs. NEVER commit the real .env. Use a DEDICATED `screenshots@…` identity, never real work mail.

# ── Tier 1: dev mail sink (Mailpit/Inbucket) — our own exercise apps. No account needed. ──
# Point the app under capture at the sink's SMTP; the helper reads it over HTTP.
MAILPIT_URL=http://localhost:8025

# ── Tier 2: dedicated Gmail/Workspace inbox via the Gmail API (BYO). ──
# The real mailbox the per-site +alias is minted from (screenshots+<site>@gmail.com all land here):
GMAIL_ADDRESS=screenshots@example.com
# An OAuth 2.0 bearer token with gmail.readonly scope (mint via your own OAuth client; refresh out-of-band):
GMAIL_ACCESS_TOKEN=

# ── Tier 3: throwaway public inbox (mail.tm) — zero setup, lowest reputation. ──
# No secrets required; the helper creates a disposable mailbox on demand. (Password is disposable.)
MAILTM_PASSWORD=screenshots-throwaway
